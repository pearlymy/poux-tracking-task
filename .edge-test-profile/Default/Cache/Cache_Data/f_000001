                    <div class="task-assignees flex gap-1.5 flex-wrap justify-end mt-1">
                        ${picsHtml}
                    </div>
                </div>
                ${noteHtml}
            `;
        }

        function renderTaskCard(card, state) {
            if (!card) return;
            setCardState(card, state);
            card.innerHTML = renderTaskCardInnerHtml(state);
            const normalizedState = normalizeTicketState(state);
            const isStatusLovOpen = normalizedState?.assignees?.some((record) => (
                [openAssigneeStatusLovKey, closingAssigneeStatusLovKey].includes(getAssigneeStatusLovKey(normalizedState.ticket_id, record.user_key))
            ));
            card.classList.toggle('is-status-lov-open', !!isStatusLovOpen);
