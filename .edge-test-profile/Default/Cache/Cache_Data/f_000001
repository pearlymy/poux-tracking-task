            const matchesUser = !taskDetailChecklistFilterKey || (item.assignee_user_key || '__unassigned__') === taskDetailChecklistFilterKey;
            const matchesStatus = taskDetailChecklistStatusFilter === 'all'
                || (taskDetailChecklistStatusFilter === 'done' && item.is_done)
                || (taskDetailChecklistStatusFilter === 'incomplete' && !item.is_done);
