        function initCustomDatePicker(wrapper) {
            if (!wrapper) return;
            const trigger = wrapper.querySelector('.dp-trigger');

            // Nhân bản để xóa các event rác cũ
            const newTrigger = trigger.cloneNode(true);
            trigger.parentNode.replaceChild(newTrigger, trigger);

            // BẮT BUỘC: Phải lấy lại biến từ newTrigger sau khi đã thay thế vào DOM
            const triggerText = newTrigger.querySelector('.dp-text');
            const hiddenInput = wrapper.querySelector('.hidden-date-input');
            const dates = wrapper.querySelectorAll('.dp-date:not(.empty)');
            const btnClear = wrapper.querySelector('.dpClear');
            const btnToday = wrapper.querySelector('.dpToday');

            newTrigger.addEventListener('click', function(e) {
                // Đóng tất cả popup khác
                document.querySelectorAll('.po-datepicker.open, .custom-select-wrapper.open').forEach(w => {
                    if (w !== wrapper) w.classList.remove('open');
                });
                wrapper.classList.toggle('open');
                e.stopPropagation();
            });

            dates.forEach(date => {
                date.addEventListener('click', function(e) {
                    dates.forEach(d => d.classList.remove('selected'));
                    this.classList.add('selected');
                    
                    const day = this.textContent.padStart(2, '0');
                    // Dùng innerHTML để giữ lại icon cuốn lịch
                    triggerText.innerHTML = `<i class="fa-regular fa-calendar mr-1.5"></i> ${day}/04/2026`; 
                    triggerText.style.color = 'var(--po-text-main)';
                    
                    // Lưu vào thẻ ẩn để code cũ lấy được
                    hiddenInput.value = `2026-04-${day}`;
                    
                    wrapper.classList.remove('open');
                    e.stopPropagation();
                });
            });

            if(btnClear) {
                btnClear.addEventListener('click', function(e) {
                    dates.forEach(d => d.classList.remove('selected'));
                    triggerText.innerHTML = `<i class="fa-regular fa-calendar mr-1.5"></i> dd/mm/yyyy`;
                    triggerText.style.color = 'var(--po-text-muted)';
                    hiddenInput.value = '';
                    wrapper.classList.remove('open');
                    e.stopPropagation();
                });
            }

            if(btnToday) {
                btnToday.addEventListener('click', function(e) {
                    dates.forEach(d => d.classList.remove('selected'));
                    const todayDate = Array.from(dates).find(d => d.textContent === '17');
                    if(todayDate) todayDate.classList.add('selected');
                    
                    triggerText.innerHTML = `<i class="fa-regular fa-calendar mr-1.5"></i> 17/04/2026`;
