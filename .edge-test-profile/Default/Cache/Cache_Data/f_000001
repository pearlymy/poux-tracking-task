        function getTaskCommentMentionOptions(ticketState) {
            const normalizedState = normalizeTicketState(ticketState);
            if (!normalizedState) return [];
            return Array.from(new Set([
                CURRENT_USER_ID,
                ...getAssignableUserKeys(),
                ...normalizedState.assignees.map((record) => record.user_key)
            ])).filter((userKey) => userKey && USERS[userKey] && USERS[userKey].is_active);
        }

        function updateTaskComments(ticketId, updater) {
            updateBoardTicket(ticketId, (ticketState) => {
                const comments = (ticketState.comments || []).map((item, index) => normalizeTaskCommentItem(item, index)).filter(Boolean);
                const nextComments = typeof updater === 'function' ? updater(comments, ticketState) : updater;
                return {
                    ...ticketState,
                    comments: (nextComments || []).map((item, index) => normalizeTaskCommentItem(item, index)).filter(Boolean)
                };
            });
            saveBoardState();
            if (currentTaskDetailTicketId === ticketId) {
                renderTaskDetailsDrawer();
            }
        }

        function getTaskCommentComposerElements() {
            const root = document.getElementById('taskDetailsDrawerRoot');
            if (!root) return {};
            return {
                root,
                editor: root.querySelector('#taskCommentComposerInput'),
                popup: root.querySelector('#taskCommentMentionPopup')
            };
        }

        function syncTaskCommentComposerPlaceholder(editor) {
            if (!editor) return;
            const hasText = !!getTaskCommentPlainText(editor.innerHTML);
            editor.classList.toggle('is-empty', !hasText);
        }

        function closeTaskCommentMentionPopup() {
            const { popup } = getTaskCommentComposerElements();
            if (!popup) return;
            popup.classList.remove('is-open');
            popup.innerHTML = '';
            taskCommentMentionActiveIndex = 0;
        }

        function renderTaskCommentMentionPopup(options = [], query = '') {
            const { popup } = getTaskCommentComposerElements();
            if (!popup) return;
            if (!options.length) {
                closeTaskCommentMentionPopup();
                return;
            }
            if (taskCommentMentionActiveIndex >= options.length) {
                taskCommentMentionActiveIndex = 0;
            }
            popup.innerHTML = options.map((userKey, index) => {
                const user = USERS[userKey];
                const jobTitle = getJobTitleName(user.job_title_id);
                return `
                    <button
                        type="button"
                        class="task-comment-mention-option ${index === taskCommentMentionActiveIndex ? 'is-active' : ''}"
                        data-user-key="${escapeHtml(userKey)}"
                        onmousedown="chooseTaskCommentMention('${escapeHtml(userKey)}', event)"
                    >
                        <span class="task-comment-mention-avatar" style="background:${escapeHtml(user.color || '#2563eb')}">${escapeHtml(adminUserInitials(user.full_name || userKey))}</span>
                        <span class="task-comment-mention-meta">
                            <span class="task-comment-mention-name">${escapeHtml(user.full_name || userKey)}</span>
                            <span class="task-comment-mention-subtitle">${escapeHtml(jobTitle)}${query ? ` • @${escapeHtml(query)}` : ''}</span>
                        </span>
                    </button>
                `;
            }).join('');
            popup.classList.add('is-open');
        }

        function getTaskCommentActiveMention(editor) {
            if (!editor) return null;
            const selection = window.getSelection();
            if (!selection || !selection.rangeCount || !selection.isCollapsed) return null;
            const range = selection.getRangeAt(0);
            if (!editor.contains(range.endContainer)) return null;
            if (range.endContainer.nodeType !== Node.TEXT_NODE) return null;
            const textBeforeCaret = range.endContainer.textContent.slice(0, range.endOffset);
            const mentionMatch = textBeforeCaret.match(/(^|\s)@([^\s@]*)$/);
            if (!mentionMatch) return null;
            const query = mentionMatch[2] || '';
            const startOffset = textBeforeCaret.lastIndexOf(`@${query}`);
            if (startOffset < 0) return null;
            return {
                textNode: range.endContainer,
                startOffset,
                query
            };
        }

        function updateTaskCommentMentionSuggestions(ticketId = currentTaskDetailTicketId) {
            if (!ticketId) return closeTaskCommentMentionPopup();
            const ticketState = getTaskDetailById(ticketId);
            const { editor } = getTaskCommentComposerElements();
            if (!ticketState || !editor) return closeTaskCommentMentionPopup();
            const activeMention = getTaskCommentActiveMention(editor);
            if (!activeMention) return closeTaskCommentMentionPopup();
            const normalizedQuery = activeMention.query.trim().toLowerCase();
            const options = getTaskCommentMentionOptions(ticketState).filter((userKey) => {
                const user = USERS[userKey];
                const haystack = `${user.full_name || ''} ${userKey}`.toLowerCase();
                return !normalizedQuery || haystack.includes(normalizedQuery);
            });
            renderTaskCommentMentionPopup(options, activeMention.query);
        }

        function chooseTaskCommentMention(userKey, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            const { editor } = getTaskCommentComposerElements();
            if (!editor || !USERS[userKey]) return;
            editor.focus();
            const activeMention = getTaskCommentActiveMention(editor);
            const selection = window.getSelection();
            if (!selection || !selection.rangeCount) return;
            const currentRange = selection.getRangeAt(0);
            if (activeMention && activeMention.textNode === currentRange.endContainer) {
                const replaceRange = document.createRange();
                replaceRange.setStart(activeMention.textNode, activeMention.startOffset);
                replaceRange.setEnd(currentRange.endContainer, currentRange.endOffset);
                selection.removeAllRanges();
                selection.addRange(replaceRange);
            }
            const mentionHtml = `<span class="task-comment-mention" data-user-key="${escapeHtml(userKey)}" contenteditable="false">@${escapeHtml(USERS[userKey].full_name || userKey)}</span>&nbsp;`;
            document.execCommand('insertHTML', false, mentionHtml);
            taskCommentComposerDraftHtml = sanitizeTaskCommentHtml(editor.innerHTML);
            syncTaskCommentComposerPlaceholder(editor);
            closeTaskCommentMentionPopup();
        }

        function handleTaskCommentComposerKeydown(event) {
            const { popup } = getTaskCommentComposerElements();
            if (!popup || !popup.classList.contains('is-open')) {
                if (event.key === 'Enter' && (event.metaKey || event.ctrlKey)) {
                    submitTaskComment(currentTaskDetailTicketId, event);
                }
                return;
            }
            const options = Array.from(popup.querySelectorAll('.task-comment-mention-option'));
            if (!options.length) return;
            if (event.key === 'ArrowDown') {
                event.preventDefault();
                taskCommentMentionActiveIndex = (taskCommentMentionActiveIndex + 1) % options.length;
                const userKey = options[taskCommentMentionActiveIndex]?.dataset.userKey || '';
                renderTaskCommentMentionPopup(options.map((option) => option.dataset.userKey), '');
                popup.querySelector(`[data-user-key="${userKey}"]`)?.scrollIntoView({ block: 'nearest' });
                return;
            }
            if (event.key === 'ArrowUp') {
                event.preventDefault();
                taskCommentMentionActiveIndex = (taskCommentMentionActiveIndex - 1 + options.length) % options.length;
                const userKey = options[taskCommentMentionActiveIndex]?.dataset.userKey || '';
                renderTaskCommentMentionPopup(options.map((option) => option.dataset.userKey), '');
                popup.querySelector(`[data-user-key="${userKey}"]`)?.scrollIntoView({ block: 'nearest' });
                return;
            }
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                const activeOption = options[taskCommentMentionActiveIndex] || options[0];
                if (activeOption?.dataset.userKey) {
                    chooseTaskCommentMention(activeOption.dataset.userKey, event);
                }
                return;
            }
            if (event.key === 'Escape') {
                event.preventDefault();
                closeTaskCommentMentionPopup();
            }
        }

        function formatTaskComment(command, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            const { editor } = getTaskCommentComposerElements();
            if (!editor) return;
            editor.focus();
            document.execCommand(command, false, null);
            taskCommentComposerDraftHtml = sanitizeTaskCommentHtml(editor.innerHTML);
            syncTaskCommentComposerPlaceholder(editor);
        }

        function openTaskCommentMentionPicker(event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            const { editor } = getTaskCommentComposerElements();
            if (!editor) return;
            editor.focus();
            taskCommentMentionActiveIndex = 0;
            renderTaskCommentMentionPopup(getTaskCommentMentionOptions(getTaskDetailById(currentTaskDetailTicketId)), '');
        }

        function submitTaskComment(ticketId, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            if (!ticketId) return;
            const { editor } = getTaskCommentComposerElements();
            if (!editor) return;
            const contentHtml = sanitizeTaskCommentHtml(editor.innerHTML);
            if (!getTaskCommentPlainText(contentHtml)) {
                editor.focus();
