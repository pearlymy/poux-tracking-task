        function normalizeTaskListColumnWidths(widths) {
            return TASK_LIST_COLUMN_ORDER.reduce((nextWidths, columnKey) => {
                const rawWidth = Number(widths?.[columnKey]);
                const minWidth = TASK_LIST_COLUMN_MIN_WIDTHS[columnKey] || 100;
                nextWidths[columnKey] = Number.isFinite(rawWidth)
                    ? Math.max(minWidth, Math.round(rawWidth))
                    : TASK_LIST_COLUMN_DEFAULT_WIDTHS[columnKey];
                return nextWidths;
            }, {});
        }

        function loadTaskListColumnWidths() {
            try {
                const storedWidths = JSON.parse(localStorage.getItem(TASK_LIST_COLUMN_WIDTHS_STORAGE_KEY) || '{}');
                taskListColumnWidths = normalizeTaskListColumnWidths(storedWidths);
            } catch (error) {
                taskListColumnWidths = { ...TASK_LIST_COLUMN_DEFAULT_WIDTHS };
            }
        }

        function saveTaskListColumnWidths() {
            localStorage.setItem(TASK_LIST_COLUMN_WIDTHS_STORAGE_KEY, JSON.stringify(taskListColumnWidths));
        }

        function applyTaskListColumnWidths() {
            const listView = document.getElementById('taskListView');
            if (!listView) return;
            const columns = TASK_LIST_COLUMN_ORDER
                .map((columnKey) => {
                    const width = taskListColumnWidths[columnKey];
                    const minWidth = TASK_LIST_COLUMN_MIN_WIDTHS[columnKey] || 100;
                    return `minmax(${minWidth}px, ${width}fr)`;
                })
                .join(' ');
            const minWidth = TASK_LIST_COLUMN_ORDER.reduce((sum, columnKey) => sum + (TASK_LIST_COLUMN_MIN_WIDTHS[columnKey] || 100), 0)
                + ((TASK_LIST_COLUMN_ORDER.length - 1) * TASK_LIST_COLUMN_GAP)
                + 64;
            listView.style.setProperty('--task-list-columns', columns);
            listView.style.setProperty('--task-list-min-width', `${minWidth}px`);
        }

        function finishTaskListColumnResize() {
            if (!taskListColumnResizeState) return;
            const { handle, pointerId } = taskListColumnResizeState;
            try {
                handle?.releasePointerCapture?.(pointerId);
            } catch (error) {}
            handle?.classList.remove('is-dragging');
            document.body.classList.remove('task-list-resize-active');
            taskListColumnResizeState = null;
            saveTaskListColumnWidths();
        }

        function handleTaskListColumnResizeMove(event) {
            if (!taskListColumnResizeState) return;
            event.preventDefault();
            const { columnKey, startX, startWidth } = taskListColumnResizeState;
            const minWidth = TASK_LIST_COLUMN_MIN_WIDTHS[columnKey] || 100;
            taskListColumnWidths[columnKey] = Math.max(minWidth, Math.round(startWidth + event.clientX - startX));
            applyTaskListColumnWidths();
        }

        function handleTaskListColumnResizeStart(event) {
            const handle = event.currentTarget;
            const columnKey = handle?.dataset?.taskListResizeColumn;
            if (!TASK_LIST_COLUMN_ORDER.includes(columnKey)) return;
            event.preventDefault();
            event.stopPropagation();
            closeTaskListPopovers();
            taskListColumnResizeState = {
                columnKey,
                handle,
                pointerId: event.pointerId,
                startX: event.clientX,
                startWidth: taskListColumnWidths[columnKey]
            };
            handle.setPointerCapture?.(event.pointerId);
            handle.classList.add('is-dragging');
            document.body.classList.add('task-list-resize-active');
        }

        function initializeTaskListColumnResize() {
            loadTaskListColumnWidths();
            applyTaskListColumnWidths();
            document.querySelectorAll('[data-task-list-resize-column]').forEach((handle) => {
                if (handle.dataset.taskListResizeBound === 'true') return;
                handle.dataset.taskListResizeBound = 'true';
                handle.addEventListener('pointerdown', handleTaskListColumnResizeStart);
                handle.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                });
            });
            document.addEventListener('pointermove', handleTaskListColumnResizeMove);
            document.addEventListener('pointerup', finishTaskListColumnResize);
            document.addEventListener('pointercancel', finishTaskListColumnResize);
        }

