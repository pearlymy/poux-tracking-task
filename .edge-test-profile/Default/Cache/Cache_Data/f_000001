        const h = React.createElement;
        const DOCUMENT_WORKSPACE_ROOT_ID = "documentWorkspaceRoot";
        const DEFAULT_DOCUMENT_PAGE = { id: "doc-po", name: "PO" };
        const normalizeWorkspacePage = (page) => {
            if (!page || typeof page !== "object") return DEFAULT_DOCUMENT_PAGE;
            const id = String(page.id || page.pageId || "").trim();
            const name = String(page.name || page.title || page.scopeTitle || id || "Tai lieu").trim();
            return id ? { id, name } : DEFAULT_DOCUMENT_PAGE;
        };
        const getWorkspacePage = () => normalizeWorkspacePage(window.POUX_DOCUMENT_WORKSPACE_PAGE || window.POUX_PENDING_DOCUMENT_PAGE || DEFAULT_DOCUMENT_PAGE);
        const getDocumentScope = () => getWorkspacePage().id;
        const getDocumentScopeTitle = () => getWorkspacePage().name;
        const IS_EMBEDDED = true;
        const scopedStorageKey = (baseKey) => {
            const scope = getDocumentScope();
            return scope ? `${baseKey}__${encodeURIComponent(scope)}` : baseKey;
        };
        const getStorageKey = () => scopedStorageKey("team_documents_dashboard_v1");
        const getBuilderDocumentsStorageKey = () => scopedStorageKey("document_builder_documents_v1");
        const getSearchHistoryKey = () => scopedStorageKey("team_documents_search_history_v1");
        const DATA_SOURCE = "local";
        const VIEW_MODES = [
            { id: "card", title: "Card" },
            { id: "timeline", title: "Timeline" }
        ];
        const SORT_MODES = [
            { id: "updated-desc", title: "Cập nhật mới nhất" },
            { id: "created-desc", title: "Ngày tạo mới nhất" },
            { id: "title-asc", title: "Tên A-Z" }
        ];

        const defaultInitialData = {
            categories: [
                { id: "cat-onboarding", name: "Onboarding" },
                { id: "cat-process", name: "Quy trình" },
                { id: "cat-technical", name: "Technical" }
            ],
            articles: [
                {
                    id: "art-welcome",
                    categoryId: "cat-onboarding",
                    title: "Checklist thành viên mới",
                    description: "Những việc cần hoàn tất trong tuần đầu tiên.",
                    content: "Cấp tài khoản, đọc quy định team, setup công cụ và tham gia buổi sync đầu tiên.",
                    createdAt: "2026-04-26T08:00:00.000Z",
                    author: "Phan Hiếu"
                },
                {
                    id: "art-release",
                    categoryId: "cat-process",
                    title: "Quy trình release",
                    description: "",
                    content: "Kiểm tra checklist QA trước khi release.\nThông báo thay đổi trên kênh team và cập nhật changelog.",
                    createdAt: "2026-04-26T09:30:00.000Z",
                    author: "An Nguyễn"
                },
                {
                    id: "art-api",
                    categoryId: "cat-technical",
                    title: "Hướng dẫn tích hợp API",
                    description: "Tài liệu mẫu cho các endpoint nội bộ.",
                    content: "Mỗi endpoint cần có request sample, response sample và mã lỗi thường gặp.",
                    createdAt: "2026-04-26T10:00:00.000Z",
                    author: "Đắc Lê"
                }
            ]
        };

        const scopedInitialData = {
            categories: [
                { id: "cat-general", name: "General" }
            ],
            articles: []
        };

        const getInitialData = () => getDocumentScope() ? scopedInitialData : defaultInitialData;

        const createId = (prefix) => `${prefix}-${Date.now()}-${Math.random().toString(16).slice(2)}`;

        const normalizeStatus = (status) => ["draft", "published", "archived"].includes(status) ? status : "published";

        const syncBuilderDocumentStatus = (article) => {
            if (DATA_SOURCE !== "local" || !article?.id) return;
            try {
                const raw = JSON.parse(localStorage.getItem(getBuilderDocumentsStorageKey()) || "{}");
                const docs = Array.isArray(raw) ? raw : raw.documents;
                if (!Array.isArray(docs)) return;
                let changed = false;
                const status = normalizeStatus(article.status);
                const nextDocs = docs.map((doc) => {
                    if (!doc || (doc.id !== article.id && doc.sourceArticleId !== article.id)) return doc;
                    changed = true;
                    return {
                        ...doc,
                        status,
                        archived: status === "archived",
                        publishedAt: article.publishedAt || null,
                        title: article.title || doc.title || 'Untitled document',
                        sourceArticleId: article.id,
                        sourceCategoryId: article.categoryId || doc.sourceCategoryId || null,
                        sourceAuthor: article.author || doc.sourceAuthor || null,
                        sourceDescription: article.description || "",
                        updatedAt: article.updatedAt || doc.updatedAt || new Date().toISOString(),
                        publishedSignature: status === "published" ? doc.publishedSignature || "" : ""
                    };
                });
                if (!changed) return;
                localStorage.setItem(getBuilderDocumentsStorageKey(), JSON.stringify(Array.isArray(raw) ? nextDocs : { ...raw, documents: nextDocs }));
            } catch (error) {
                console.warn("Không thể đồng bộ trạng thái sang builder draft.", error);
            }
        };

        const deleteBuilderDocumentForArticle = (articleId) => {
            if (DATA_SOURCE !== "local" || !articleId) return;
            try {
                const raw = JSON.parse(localStorage.getItem(getBuilderDocumentsStorageKey()) || "{}");
                const docs = Array.isArray(raw) ? raw : raw.documents;
                if (!Array.isArray(docs)) return;
                const nextDocs = docs.filter((doc) => doc && doc.id !== articleId && doc.sourceArticleId !== articleId);
                if (nextDocs.length === docs.length) return;
                localStorage.setItem(getBuilderDocumentsStorageKey(), JSON.stringify(Array.isArray(raw) ? nextDocs : { ...raw, documents: nextDocs }));
            } catch (error) {
                console.warn("KhÃ´ng thá»ƒ xÃ³a draft liÃªn káº¿t trong builder.", error);
            }
        };

        const getStatusMeta = (status) => {
            if (status === "draft") return { label: "Draft", className: "bg-amber-50 text-amber-700 border-amber-200" };
            if (status === "archived") return { label: "Archived", className: "bg-rose-50 text-rose-700 border-rose-200" };
            return { label: "Published", className: "bg-emerald-50 text-emerald-700 border-emerald-200" };
        };

        const normalizeArticle = (article) => {
            const createdAt = article?.createdAt || new Date().toISOString();
            return {
                id: article?.id || createId("art"),
                categoryId: article?.categoryId || "",
                title: article?.title || "Untitled document",
                description: article?.description || "",
                content: article?.content || "",
                builderBlocks: Array.isArray(article?.builderBlocks) ? article.builderBlocks : null,
                createdAt,
                updatedAt: article?.updatedAt || createdAt,
                publishedAt: article?.publishedAt || null,
                status: normalizeStatus(article?.status),
                author: article?.author || "Thành viên"
            };
        };

        const normalizeStore = (data) => {
            const source = data && typeof data === "object" ? data : getInitialData();
            return {
                categories: Array.isArray(source.categories) ? source.categories : [],
                articles: Array.isArray(source.articles) ? source.articles.map(normalizeArticle) : []
            };
        };

        const readStore = () => {
            if (DATA_SOURCE !== "local") return normalizeStore(getInitialData());

            try {
                const raw = localStorage.getItem(getStorageKey());
                if (!raw) {
                    const normalized = normalizeStore(getInitialData());
                    localStorage.setItem(getStorageKey(), JSON.stringify(normalized));
                    return normalized;
                }

                const parsed = JSON.parse(raw);
                const normalized = normalizeStore(parsed);
                if (JSON.stringify(parsed) !== JSON.stringify(normalized)) {
                    localStorage.setItem(getStorageKey(), JSON.stringify(normalized));
                }
                return normalized;
            } catch (error) {
                console.warn("Không thể đọc kho tài liệu. Đang dùng dữ liệu mặc định.", error);
                return normalizeStore(getInitialData());
            }
        };

        const writeStore = (data) => {
            if (DATA_SOURCE === "local") {
                localStorage.setItem(getStorageKey(), JSON.stringify(data));
            }
            return data;
        };

        const DataService = {
            getData() {
                return readStore();
            },
            getCategories() {
                return readStore().categories;
            },
            getArticles() {
                return readStore().articles;
            },
            addCategory(name) {
                const data = readStore();
                const category = { id: createId("cat"), name: name.trim() };
                return writeStore({ ...data, categories: [category, ...data.categories] });
            },
            reorderCategories(categories) {
                const data = readStore();
                return writeStore({ ...data, categories });
            },
            updateCategory(id, updates) {
                const data = readStore();
                return writeStore({
                    ...data,
                    categories: data.categories.map((category) =>
                        category.id === id ? { ...category, ...updates } : category
                    )
                });
            },
            deleteCategory(id) {
                const data = readStore();
                const fallbackCategory = data.categories.find((category) => category.id !== id);
                return writeStore({
                    categories: data.categories.filter((category) => category.id !== id),
                    articles: data.articles.map((article) =>
                        article.categoryId === id
                            ? { ...article, categoryId: fallbackCategory?.id || "" }
                            : article
                    )
                });
            },
            addArticle(article) {
                const data = readStore();
                const now = new Date().toISOString();
                const nextArticle = {
                    ...article,
                    id: createId("art"),
                    createdAt: now,
                    updatedAt: now,
                    publishedAt: null,
                    status: "draft",
                    author: "Bạn"
                };
                const nextData = writeStore({ ...data, articles: [nextArticle, ...data.articles] });
                syncBuilderDocumentStatus(nextArticle);
                return nextData;
            },
            updateArticle(id, updates) {
                const data = readStore();
                const now = new Date().toISOString();
                let updatedArticle = null;
                const nextData = writeStore({
                    ...data,
                    articles: data.articles.map((article) => {
                        if (article.id !== id) return article;
                        updatedArticle = {
                            ...article,
                            ...updates,
                            updatedAt: now,
                            status: normalizeStatus(updates.status || article.status),
                            publishedAt: updates.publishedAt === undefined ? article.publishedAt || null : updates.publishedAt
                        };
                        return updatedArticle;
                    })
                });
                if (updatedArticle) syncBuilderDocumentStatus(updatedArticle);
                return nextData;
            },
            deleteArticle(id) {
                const data = readStore();
                const nextData = writeStore({
                    ...data,
                    articles: data.articles.filter((article) => article.id !== id)
                });
                deleteBuilderDocumentForArticle(id);
                return nextData;
            }
        };

        const IconButton = ({ label, children, className = "", ...props }) =>
            h("button", {
                type: "button",
                "aria-label": label,
                title: label,
                className: `app-icon-btn h-9 w-9 shrink-0 rounded-xl ${className}`,
                ...props
            }, children);

        const EmptyState = ({ title, text, onAdd, actionLabel = "Thêm tài liệu", actionIcon = Plus }) =>
            h("div", { className: "flex min-h-[360px] flex-col items-center justify-center rounded-2xl border border-dashed border-slate-300 bg-white px-6 text-center shadow-sm" },
                h("div", { className: "mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-blue-50 text-blue-500" },
                    h(BookOpen, { className: "h-8 w-8", strokeWidth: 2 })
                ),
                h("h2", { className: "text-lg font-bold text-slate-800 tracking-tight" }, title),
                h("p", { className: "mt-2 max-w-md text-[13px] font-medium leading-6 text-slate-500" }, text),
                h("button", {
                    type: "button",
                    onClick: onAdd,
                    className: "app-btn-primary mt-5 rounded-xl px-5 py-2.5 text-sm"
                }, h(actionIcon, { className: "h-4 w-4" }), actionLabel)
            );

        const SmartSortLov = ({ value, onChange }) => {
            const [isOpen, setIsOpen] = useState(false);
            const rootRef = useRef(null);
            const activeMode = SORT_MODES.find((mode) => mode.id === value) || SORT_MODES[0];

            useEffect(() => {
                if (!isOpen) return undefined;
                const closeOnPointerDown = (event) => {
                    if (rootRef.current && !rootRef.current.contains(event.target)) setIsOpen(false);
                };
                const closeOnEscape = (event) => {
                    if (event.key === "Escape") setIsOpen(false);
                };
                document.addEventListener("pointerdown", closeOnPointerDown);
                document.addEventListener("keydown", closeOnEscape);
                return () => {
                    document.removeEventListener("pointerdown", closeOnPointerDown);
                    document.removeEventListener("keydown", closeOnEscape);
                };
            }, [isOpen]);

            const selectMode = (modeId) => {
                onChange(modeId);
                setIsOpen(false);
            };

            return h("div", { ref: rootRef, className: `smart-sort-lov relative ml-2 ${isOpen ? "is-open" : ""}` },
                h("button", {
                    type: "button",
                    className: "smart-sort-trigger px-3",
                    "aria-haspopup": "listbox",
                    "aria-expanded": isOpen ? "true" : "false",
                    onClick: () => setIsOpen((current) => !current)
