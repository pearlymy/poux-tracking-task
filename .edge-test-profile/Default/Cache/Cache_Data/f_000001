                window.POUX_DOCUMENT_WORKSPACE_PAGE = null;
                if (window.PouxDocumentWorkspace && typeof window.PouxDocumentWorkspace.showPage === 'function') {
                    window.PouxDocumentWorkspace.showPage(null);
                }
                setWorkspaceView('document');
                syncActiveNavState();
                return;
            }
            documentState.activeId = page.id;
            clearMemberActiveStates();
            const activeDocumentLink = document.querySelector(`.member-link[data-member-group="document"][data-page-id="${page.id}"]`);
            if (activeDocumentLink) activeDocumentLink.classList.add('is-active');
            const workspacePage = { id: page.id, name: page.name };
            window.POUX_DOCUMENT_WORKSPACE_ACTIVE = true;
            window.POUX_PENDING_DOCUMENT_PAGE = workspacePage;
            window.POUX_DOCUMENT_WORKSPACE_PAGE = workspacePage;
