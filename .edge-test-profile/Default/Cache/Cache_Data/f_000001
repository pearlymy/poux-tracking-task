        function renderTaskDetailsDrawer(options = {}) {
            const { animate = false, preserveScroll = true } = options;
            const root = document.getElementById('taskDetailsDrawerRoot');
            if (!root) return;

            const ticketState = currentTaskDetailTicketId ? getTaskDetailById(currentTaskDetailTicketId) : null;
            if (!ticketState) {
                root.innerHTML = '';
                return;
            }

            const hadOpenDrawer = !!root.querySelector('.task-detail-drawer-layer.is-open');
            const previousDrawer = root.querySelector('.task-detail-drawer');
            const previousScrollTop = previousDrawer ? previousDrawer.scrollTop : 0;
            const shouldRestoreScroll = preserveScroll && hadOpenDrawer;
            root.innerHTML = buildTaskDetailsDrawerHtmlV2(ticketState);
            const drawerLayer = root.querySelector('.task-detail-drawer-layer');
            if (!drawerLayer) return;
            const nextDrawer = root.querySelector('.task-detail-drawer');
            if (!animate || hadOpenDrawer) {
                drawerLayer.classList.add('is-open');
            }
            if (shouldRestoreScroll && nextDrawer) {
                nextDrawer.scrollTop = previousScrollTop;
            }
            root.querySelectorAll('.task-checklist-title-input').forEach((textarea) => {
                autoResize(textarea);
            });
            root.querySelectorAll('.task-document-note-input').forEach((textarea) => {
                autoResize(textarea);
            });
            if (pendingChecklistFocusItemId) {
                const targetItemId = pendingChecklistFocusItemId;
                pendingChecklistFocusItemId = null;
                window.requestAnimationFrame(() => {
                    focusChecklistItemInput(targetItemId);
                });
            }
            if (pendingTaskDocumentFocusItemId) {
                const targetItemId = pendingTaskDocumentFocusItemId;
                pendingTaskDocumentFocusItemId = null;
                window.requestAnimationFrame(() => {
                    focusTaskDocumentTitleInput(targetItemId);
                });
            }
            initializeTaskChecklistSortable(ticketState.ticket_id);
            initializeTaskDocumentSortable(ticketState.ticket_id);
            syncTaskChecklistTagStyles(ticketState);
            hydrateTaskDocumentLinks(root);
            hydrateTaskDocumentEditState(root);
            hydrateTaskDocumentEmptyState(root, ticketState.ticket_id);
            hydrateTaskCommentLinks(root);
            hydrateTaskCommentComposer(root, ticketState);
            if (taskDetailEditDraft?.ticket_id === ticketState.ticket_id) {
                const editDesc = root.querySelector('#taskDetailEditDesc');
                if (editDesc) {
                    autoResize(editDesc);
                    editDesc.addEventListener('input', function () { autoResize(this); });
                }
                const editNote = root.querySelector('#taskDetailEditNote');
                if (editNote) {
                    autoResize(editNote);
                    editNote.addEventListener('input', function () { autoResize(this); });
                }
                initCustomSelect(root.querySelector('#taskDetailEditPrivacyWrapper'));
                initCustomDatePicker(root.querySelector('#taskDetailEditDateWrapper'));
            }

            if (animate && !hadOpenDrawer) {
                window.requestAnimationFrame(() => {
                    window.requestAnimationFrame(() => {
                        drawerLayer.classList.add('is-open');
                    });
                });
            }
            if (shouldRestoreScroll && nextDrawer) {
                window.requestAnimationFrame(() => {
                    nextDrawer.scrollTop = previousScrollTop;
                });
            }
        }

        function syncTaskDetailsDrawer() {
            if (!currentTaskDetailTicketId) return;
            if (!getTaskDetailById(currentTaskDetailTicketId)) {
                currentTaskDetailTicketId = null;
                taskDetailEditDraft = null;
                const root = document.getElementById('taskDetailsDrawerRoot');
                if (root) root.innerHTML = '';
                if (currentWorkspaceView === 'board') updateTrackingUrl({ ticketId: null, replace: true });
                return;
            }
            renderTaskDetailsDrawer();
        }

        function openTaskDetailsDrawer(ticketId, options = {}) {
            const { updateUrl = true, replaceUrl = false } = options;
            if (!ticketId) return;
            if (!getTaskDetailById(ticketId)) return;
            currentTaskDetailTicketId = ticketId;
            taskDetailEditDraft = null;
            taskDetailChecklistFilterKey = localStorage.getItem(TASK_CHECKLIST_USER_FILTER_STORAGE_KEY) || '';
            taskDetailChecklistStatusFilter = localStorage.getItem(TASK_CHECKLIST_STATUS_FILTER_STORAGE_KEY) || 'all';
            taskDetailCommentFilterKey = '';
            isTaskChecklistCollapsed = localStorage.getItem(TASK_CHECKLIST_COLLAPSED_STORAGE_KEY) === 'true';
            isTaskDocumentsCollapsed = localStorage.getItem(TASK_DOCUMENTS_COLLAPSED_STORAGE_KEY) === 'true';
            openTaskChecklistDateItemId = null;
            taskCommentComposerDraftHtml = '';
            taskCommentMentionActiveIndex = 0;
            if (taskDetailDrawerCloseTimeout) {
                clearTimeout(taskDetailDrawerCloseTimeout);
                taskDetailDrawerCloseTimeout = null;
            }
            renderTaskDetailsDrawer({ animate: true });
            if (updateUrl && currentWorkspaceView === 'board') {
                updateTrackingUrl({ ticketId, replace: replaceUrl });
            }
        }

        function openTaskDetailsFromCard(card, event) {
            const target = event?.target;
            if (!card || !card.dataset.ticketId) return;
            if (isTaskCardDragging || Date.now() < suppressTaskCardClickUntil) {
                event?.preventDefault?.();
                event?.stopPropagation?.();
                return;
            }
            if (target?.closest('.card-actions-wrap, .edit-form, .tag-name, .delete-btn, .edit-btn, button, input, textarea, select, a')) return;
            openTaskDetailsDrawer(card.dataset.ticketId);
        }

        function closeTaskDetailsDrawer(options = {}) {
            const { updateUrl = true, replaceUrl = false, immediate = false } = options;
            const drawerLayer = document.querySelector('.task-detail-drawer-layer.is-open');
            const root = document.getElementById('taskDetailsDrawerRoot');
            if (!root) return;

            if (!drawerLayer || immediate) {
                if (taskDetailDrawerCloseTimeout) {
                    clearTimeout(taskDetailDrawerCloseTimeout);
                    taskDetailDrawerCloseTimeout = null;
                }
                currentTaskDetailTicketId = null;
                taskDetailEditDraft = null;
                openTaskChecklistDateItemId = null;
                taskDetailCommentFilterKey = '';
                taskCommentComposerDraftHtml = '';
                currentTaskCommentReplyId = '';
                currentTaskCommentReactionMenuId = '';
                root.innerHTML = '';
                if (updateUrl && currentWorkspaceView === 'board') {
                    updateTrackingUrl({ ticketId: null, replace: replaceUrl });
                }
                return;
            }

            drawerLayer.classList.remove('is-open');
            drawerLayer.classList.add('is-closing');
            if (updateUrl && currentWorkspaceView === 'board') {
                updateTrackingUrl({ ticketId: null, replace: replaceUrl });
            }
            if (taskDetailDrawerCloseTimeout) clearTimeout(taskDetailDrawerCloseTimeout);
            taskDetailDrawerCloseTimeout = window.setTimeout(() => {
                currentTaskDetailTicketId = null;
                taskDetailEditDraft = null;
                openTaskChecklistDateItemId = null;
                taskDetailCommentFilterKey = '';
                taskCommentComposerDraftHtml = '';
                currentTaskCommentReplyId = '';
                currentTaskCommentReactionMenuId = '';
                root.innerHTML = '';
                taskDetailDrawerCloseTimeout = null;
            }, 340);
        }

        function startTaskDetailEdit(ticketId, event) {
            event?.stopPropagation?.();
            const ticketState = getTaskDetailById(ticketId);
            if (!ticketState) return;
            taskDetailEditDraft = buildTaskDetailEditDraft(ticketState);
            renderTaskDetailsDrawer();
        }

        function cancelTaskDetailEdit(event) {
            event?.stopPropagation?.();
            taskDetailEditDraft = null;
            renderTaskDetailsDrawer({ animate: true });
        }

        function toggleTaskDetailEditPic(btn) {
            btn.classList.toggle('po-tag-active');
        }

        function saveTaskDetailEdit(event) {
            event?.stopPropagation?.();
            if (!taskDetailEditDraft?.ticket_id) return;

            const titleInput = document.getElementById('taskDetailEditTitle');
            const descInput = document.getElementById('taskDetailEditDesc');
            const noteInput = document.getElementById('taskDetailEditNote');
            const dateInput = document.getElementById('taskDetailEditDate');
            const isPersonalInput = document.getElementById('taskDetailEditIsPersonal');
            if (!titleInput || !descInput || !noteInput || !dateInput || !isPersonalInput) return;

            const title = titleInput.value.trim();
            if (!title) {
                titleInput.classList.add('input-error');
                titleInput.placeholder = 'Tiêu đề không được để trống!';
                titleInput.focus();
                setTimeout(() => titleInput.classList.remove('input-error'), 400);
                return;
            }

            const previousState = getTaskDetailById(taskDetailEditDraft.ticket_id);
            if (!previousState) return;

            const isPersonal = isPersonalInput.value === 'true';
            const selectedKeys = Array.from(document.querySelectorAll('#taskDetailsDrawerRoot [data-pic].po-tag-active'))
                .map((el) => el.dataset.pic)
                .filter((userKey) => userKey && USERS[userKey]);
            const assignees = isPersonal ? [] : buildAssigneeRecordsFromUserKeys(selectedKeys, previousState.assignees || []);
            const nextState = normalizeTicketState({
                ticket_id: previousState.ticket_id,
                title,
                desc: descInput.value.trim(),
                note: noteInput.value.trim(),
                date_raw: dateInput.value,
                is_personal: isPersonal,
                assignees,
                checklist: previousState.checklist || [],
                documents: previousState.documents || [],
                comments: previousState.comments || []
            });

            updateBoardTicket(nextState.ticket_id, nextState);
            saveBoardState();
            taskDetailEditDraft = null;
            renderBoardTickets();
            renderTaskDetailsDrawer();
        }

        function editTaskFromDrawer(ticketId, event) {
            startTaskDetailEdit(ticketId, event);
        }

        function normalizeTicketState(state) {
            if (!state) return null;

            const isPersonal = state.is_personal === true || state.isPersonal === true || state.is_personal === 'true' || state.isPersonal === 'true';
            const assignees = isPersonal
                ? []
                : (Array.isArray(state.assignees) ? state.assignees.map((record) => normalizeAssigneeRecord(record)).filter(Boolean) : []);

            return {
                ticket_id: state.ticket_id || state.ticketId || '',
                title: state.title || '',
                desc: state.desc || '',
                note: state.note || state.progress_note || state.progressNote || '',
                date_raw: state.date_raw || state.dateRaw || '',
                is_personal: isPersonal,
                assignees,
                checklist: Array.isArray(state.checklist) ? state.checklist.map((item, index) => normalizeChecklistItem(item, index)).filter(Boolean) : [],
                documents: Array.isArray(state.documents) ? state.documents.map((item, index) => normalizeTaskDocumentItem(item, index)).filter(Boolean) : [],
                comments: Array.isArray(state.comments) ? state.comments.map((item, index) => normalizeTaskCommentItem(item, index)).filter(Boolean) : []
            };
        }

        function getCardState(card) {
            if (!card) return null;

            if (card.dataset.ticketState) {
                try {
                    const parsedState = JSON.parse(card.dataset.ticketState);
                    const normalizedState = normalizeTicketState(parsedState);
                    if (normalizedState) return normalizedState;
                } catch (error) {
                }
            }

            const titleEl = card.querySelector('.task-title');
            const descEl = card.querySelector('.task-desc');
            const noteEl = card.querySelector('.task-note-text');
            const dateLabelEl = card.querySelector('.task-date-label');
            let dateRaw = '';
            if (dateLabelEl) {
                const dateText = dateLabelEl.textContent.trim();
                if (dateText && dateText !== 'Chưa có hạn') {
                    const parts = dateText.split('/');
                    if (parts.length === 3) dateRaw = `${parts[2]}-${parts[1]}-${parts[0]}`;
                }
            }

            return normalizeTicketState({
                ticket_id: card.dataset.ticketId || '',
                title: titleEl ? titleEl.innerText.replace(/^\d+\.\s/, '') : '',
                desc: descEl ? descEl.innerText : '',
                note: noteEl ? noteEl.innerText : '',
                date_raw: dateRaw,
                is_personal: card.dataset.isPersonal === 'true',
                assignees: getCardAssignees(card)
            });
        }

        function setCardState(card, state) {
            const normalizedState = normalizeTicketState(state);
            if (!card || !normalizedState) return;

            card.dataset.ticketId = normalizedState.ticket_id;
            card.dataset.isPersonal = normalizedState.is_personal ? 'true' : 'false';
            card.dataset.ticketState = JSON.stringify(normalizedState);
            setCardAssignees(card, normalizedState.assignees);
        }

        function renderTaskCardInnerHtml(state) {
            const normalizedState = normalizeTicketState(state);
            if (!normalizedState) return '';

            const { dateStr, statusTextHtml } = getTaskDateMeta(normalizedState.date_raw);
            const picsHtml = normalizedState.is_personal
                ? `<div class="w-3 h-3 rounded-full bg-orange-500 border-2 border-white shadow-sm ring-1 ring-orange-200" title="Task Cá nhân"></div>`
                : renderAssigneeTags(normalizedState.assignees, normalizedState.ticket_id);
            const noteHtml = normalizedState.note
                ? `
                <div class="task-card-note-shell">
                    <div class="task-card-note-chip">
                        <span class="task-card-note-label"><i class="fa-regular fa-note-sticky"></i> Note</span>
                        <p class="task-note-text">${normalizedState.note}</p>
                    </div>
                </div>`
                : '';

            return `
<div class="card-actions-wrap">
                    ${(typeof checkPermission === 'function' && typeof CURRENT_USER_ID !== 'undefined' && checkPermission(CURRENT_USER_ID, 'DELETE_TASK')) 
                        ? `<button type="button" onclick="confirmDelete(this, event)" class="icon-btn delete-btn">
                            <svg class="trash-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            <span class="delete-text">Xóa</span>
                           </button>` 
                        : ''}
