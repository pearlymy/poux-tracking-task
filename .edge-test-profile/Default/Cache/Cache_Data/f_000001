        function syncMemberGroupSelectors(preferredTeamId = null, options = {}) {
            const blockInput = document.getElementById('memberBlockId');
            const departmentInput = document.getElementById('memberDepartmentId');
            const teamInput = document.getElementById('memberTeamId');
            const triggerValue = document.getElementById('memberTeamLovValue');
            const triggerButton = document.querySelector('[data-member-team-lov-trigger]');
            const blockList = document.getElementById('memberTeamLovBlocks');
            const departmentList = document.getElementById('memberTeamLovDepartments');
            const teamList = document.getElementById('memberTeamLovTeams');
            const panel = document.getElementById('memberTeamLovPanel');
            if (!blockInput || !departmentInput || !teamInput || !triggerValue || !triggerButton || !blockList || !departmentList || !teamList || !panel) return;

            const { keepTeamSelection = true } = options;
            const isCreatingMember = currentMemberMode === 'edit' && !currentMemberEditId;
            const availableBlocks = getAvailableBlocksForCurrentMemberSelection();
            const scopedTeams = getAvailableTeamsForCurrentSelection();
            const activeTeam = scopedTeams.find((team) => team.id === preferredTeamId)
                || scopedTeams.find((team) => team.id === teamInput.value)
                || (isCreatingMember ? null : scopedTeams[0] || null);
            const activeDepartment = activeTeam ? getSeedDepartmentById(activeTeam.department_id) : null;

            let selectedBlockId = blockInput.value || activeDepartment?.block_id || availableBlocks[0]?.id || '';
            if (!availableBlocks.some((block) => block.id === selectedBlockId)) {
                selectedBlockId = activeDepartment?.block_id || availableBlocks[0]?.id || '';
            }
            blockInput.value = selectedBlockId;

            const availableDepartments = getAvailableDepartmentsForCurrentMemberSelection(selectedBlockId);
            let selectedDepartmentId = departmentInput.value || activeDepartment?.id || availableDepartments[0]?.id || '';
            if (!availableDepartments.some((department) => department.id === selectedDepartmentId)) {
                selectedDepartmentId = activeDepartment?.id || availableDepartments[0]?.id || '';
            }
            departmentInput.value = selectedDepartmentId;

            const availableTeams = getAvailableScopedTeamsForMemberSelection(selectedBlockId, selectedDepartmentId);
            let selectedTeamId = keepTeamSelection
                ? (preferredTeamId || teamInput.value || activeTeam?.id || (isCreatingMember ? '' : availableTeams[0]?.id || ''))
                : (preferredTeamId || teamInput.value || '');
            if (!availableTeams.some((team) => team.id === selectedTeamId)) {
                selectedTeamId = keepTeamSelection ? (activeTeam?.id || (isCreatingMember ? '' : availableTeams[0]?.id || '')) : '';
            }
            teamInput.value = selectedTeamId;

            triggerValue.textContent = getMemberTeamLovValue(selectedTeamId);
            triggerValue.classList.toggle('member-lov-placeholder', !selectedTeamId);
            panel.classList.toggle('hidden', !isMemberTeamLovOpen);
            triggerButton.classList.toggle('is-open', isMemberTeamLovOpen);

            blockList.innerHTML = availableBlocks.map((block) => `
                <button type="button" class="member-lov-item ${selectedBlockId === block.id ? 'is-active' : ''}" onclick="selectMemberLovBlock('${escapeHtml(block.id)}', event)">
                    <span class="member-lov-item-code">${escapeHtml(block.code)}</span>
                    <span class="member-lov-item-name is-hidden"></span>
                </button>
            `).join('') || '<div class="member-lov-empty">Chưa có khối khả dụng</div>';

            departmentList.innerHTML = availableDepartments.map((department) => `
                <button type="button" class="member-lov-item ${selectedDepartmentId === department.id ? 'is-active' : ''}" onclick="selectMemberLovDepartment('${escapeHtml(department.id)}', event)">
                    <span class="member-lov-item-code">${escapeHtml(department.code)}</span>
                    <span class="member-lov-item-name is-hidden"></span>
                </button>
            `).join('') || '<div class="member-lov-empty">Chưa có phòng khả dụng</div>';

            teamList.innerHTML = availableTeams.map((team) => `
                <button type="button" class="member-lov-item ${selectedTeamId === team.id ? 'is-active' : ''}" onclick="selectMemberLovTeam('${escapeHtml(team.id)}', event)">
                    <span class="member-lov-item-code">${escapeHtml(team.code)}</span>
                    <span class="member-lov-item-name is-hidden"></span>
                </button>
            `).join('') || '<div class="member-lov-empty">Chưa có nhóm khả dụng</div>';

            syncMemberRoleByTeam(selectedTeamId);
        }

