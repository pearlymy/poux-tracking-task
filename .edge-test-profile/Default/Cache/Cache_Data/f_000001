        function setTaskListGroupControlVisible(groupControl, isVisible, immediate = false) {
            if (!groupControl) return;
            window.clearTimeout(taskListGroupControlTimeout);
            groupControl.classList.remove('is-hiding');

            if (immediate || getTaskViewMotionDisabled()) {
                groupControl.classList.toggle('is-visible', isVisible);
                return;
            }

            if (isVisible) {
                groupControl.classList.add('is-visible');
                return;
            }

            if (!groupControl.classList.contains('is-visible')) return;
            groupControl.classList.remove('is-visible');
            groupControl.classList.add('is-hiding');
            taskListGroupControlTimeout = window.setTimeout(() => {
                groupControl.classList.remove('is-hiding');
            }, 160);
        }

        function finalizeTaskViewPanel(panel, shouldShow) {
            if (!panel) return;
            panel.classList.toggle('hidden', !shouldShow);
            panel.classList.toggle('is-active', shouldShow);
            panel.classList.remove('is-leaving');
        }

        function scheduleTaskViewPanelFinalize(previousPanel, nextPanel, nextMode, onComplete) {
            let hasFinalized = false;
            const finish = () => {
                if (hasFinalized || currentTaskViewMode !== nextMode) return;
                hasFinalized = true;
                window.clearTimeout(taskViewTransitionTimeout);
                previousPanel?.removeEventListener('transitionend', handleTransitionEnd);
                finalizeTaskViewPanel(previousPanel, false);
                finalizeTaskViewPanel(nextPanel, true);
                onComplete?.();
            };
            const handleTransitionEnd = (event) => {
                if (event.target !== previousPanel || event.propertyName !== 'opacity') return;
                finish();
            };

            previousPanel?.addEventListener('transitionend', handleTransitionEnd);
            taskViewTransitionTimeout = window.setTimeout(finish, 280);
        }

        function setTaskViewMode(mode, options = {}) {
            const nextMode = mode === 'list' ? 'list' : 'board';
            const kanbanShell = document.querySelector('#boardWorkspaceView .kanban-scroll-shell');
            const listView = document.getElementById('taskListView');
            const groupControl = document.getElementById('taskListGroupControl');
            const nextPanel = nextMode === 'list' ? listView : kanbanShell;
            const previousPanel = nextMode === 'list' ? kanbanShell : listView;
            const immediate = !!options.immediate || getTaskViewMotionDisabled();
            const completeBoardSetup = () => {
                requestAnimationFrame(() => {
                    updateKanbanScrollNavState();
                    ensureSortableColumns();
                });
            };

            currentTaskViewMode = nextMode;
            window.clearTimeout(taskViewTransitionTimeout);
            if (nextMode === 'board') {
                closeTaskListPopovers({ immediate: true });
                setTaskListGroupControlVisible(groupControl, false, true);
            }
            document.querySelectorAll('.task-view-switch').forEach((switchEl) => {
                switchEl.style.setProperty('--task-view-index', nextMode === 'list' ? '1' : '0');
            });

            document.querySelectorAll('[data-task-view-mode]').forEach((button) => {
                const isActive = button.dataset.taskViewMode === nextMode;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            });

            if (nextMode === 'board') {
                finalizeTaskViewPanel(listView, false);
                finalizeTaskViewPanel(kanbanShell, true);
                renderBoardTickets();
                completeBoardSetup();
                return;
            } else {
                renderTaskListView({ staticValues: true });
                setTaskListGroupControlVisible(groupControl, true, immediate);
                finalizeTaskViewPanel(kanbanShell, false);
                finalizeTaskViewPanel(listView, true);
                return;
            }
        }

