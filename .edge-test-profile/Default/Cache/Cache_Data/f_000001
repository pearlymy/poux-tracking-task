                                </div>
                                <button type="button" class="org-action-btn is-icon tooltip-btn flex-shrink-0" data-tooltip="Chỉnh sửa task" onclick="editTaskFromDrawer('${escapeHtml(normalizedState.ticket_id)}', event)">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
