        function createTaskCardElement(state, boardAssigneeUserKey = '') {
            const card = document.createElement('div');
            card.className = 'task-card relative bg-white p-4 rounded-xl border border-blue-400 shadow-md hover:shadow-lg transition-all group';
            card.setAttribute('onclick', 'openTaskDetailsFromCard(this, event)');
            renderTaskCard(card, state);
            card.dataset.boardAssigneeUserKey = normalizeUserKey(boardAssigneeUserKey) || '';
            return card;
        }

        function getVisibleBoardTicketEntries() {
            const boardUserKey = getBoardTrackingUserKey();
            const isAllTrackingUsers = isAllTrackingUsersKey(boardUserKey);
            const teamUsers = getCurrentSortedTeamUserKeys();

            return boardTickets
                .map((ticketState) => {
                    if (ticketState.is_personal) {
                        return isAllTrackingUsers
                            ? null
                            : (boardUserKey === CURRENT_USER_ID ? { ticketState, assignee: null } : null);
                    }
                    const assignee = isAllTrackingUsers
                        ? getTicketTeamAssignee(ticketState, teamUsers)
                        : getTicketAssignee(ticketState, boardUserKey);
                    return assignee ? { ticketState, assignee } : null;
                })
                .filter(Boolean);
        }

        function renderTaskListPicCell(ticketState, assignee) {
            const normalizedState = normalizeTicketState(ticketState);
            if (!normalizedState) return '';
            if (normalizedState.is_personal) {
                return `<div class="w-3 h-3 rounded-full bg-orange-500 border-2 border-white shadow-sm ring-1 ring-orange-200" title="Task Cá nhân"></div>`;
            }
            return renderAssigneeTags(normalizedState.assignees, normalizedState.ticket_id);
        }

        function renderTaskListStatusCell(ticketState, assignee) {
            const normalizedState = normalizeTicketState(ticketState);
            if (!normalizedState) return '';
            const stateMeta = normalizedState.is_personal
                ? getDefaultStateCode()
                : (getStateConfig(assignee?.workflow_state) || getDefaultStateCode());
            const statusColor = getColorOptionMeta(stateMeta.colorTheme).hex;
            return `
                <span class="task-list-status" style="--status-color:${statusColor}">
                    <span class="task-list-status-dot" aria-hidden="true"></span>
                    <span>${escapeHtml(stateMeta.stateName)}</span>
                </span>
            `;
