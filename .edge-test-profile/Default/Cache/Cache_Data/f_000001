                const prefix = blockCode ? `${blockCode}.` : '';
                return {
                    label: 'Mã phòng hiển thị',
                    full: getDepartmentFullCode(selection.entity.id),
                    prefix,
                    suffix: selection.entity.code || ''
                };
            }

            const draftDepartment = getSeedDepartmentById(selection.entity.department_id);
            const draftBlock = draftDepartment ? getSeedBlockById(draftDepartment.block_id) : null;
            const draftPrefix = [draftBlock?.code, draftDepartment?.code].filter(Boolean).join('.');
            const teamMeta = selection.entity.id && !String(selection.entity.id).startsWith('draft_')
                ? getTeamCodeMeta(selection.entity.id)
                : {
                    prefix: draftPrefix,
                    full: [draftPrefix, selection.entity.code || ''].filter(Boolean).join('.')
                };
