                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    </button>
                </div>
                <h4 class="task-title font-semibold text-[16px] text-blue-950 group-hover:text-blue-600 transition-colors mb-2 leading-tight pr-8">${normalizedState.title}</h4>
                ${normalizedState.desc
                    ? `<p class="task-desc text-[12px] text-slate-500 leading-relaxed mb-4">${normalizedState.desc}</p>`
                    : ''}
                <div class="flex justify-between items-start pt-3 border-t border-slate-100">
                    <div class="flex flex-col gap-0.5">
                        <div class="flex items-center gap-1.5 text-[12px] font-semibold text-slate-400">
