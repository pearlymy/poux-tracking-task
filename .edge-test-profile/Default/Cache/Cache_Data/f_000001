        function isBranchDivider(item) {
            return item?.type === 'divider';
        }

        function isBranchPage(item) {
            return !!item && !isBranchDivider(item);
        }

        function normalizeBranchVisibility(value) {
            return ['team', 'personal', 'shared'].includes(value) ? value : 'team';
        }

        function normalizeBranchSharedUsers(value) {
            return Array.from(new Set((Array.isArray(value) ? value : [])
                .map((userKey) => normalizeUserKey(userKey))
                .filter((userKey) => userKey && USERS[userKey] && USERS[userKey].is_active)));
        }

        function normalizeBranchItem(item, config) {
            if (!item || typeof item !== 'object') return null;
            if (item.type === 'divider') {
                const ownerUserId = normalizeUserKey(item.ownerUserId || item.owner_user_id || CURRENT_USER_ID);
                return {
                    type: 'divider',
                    id: item.id || `${config.pageIdPrefix}-divider-${Date.now()}-${Math.random().toString(16).slice(2)}`,
                    label: String(item.label || '').trim(),
                    visibility: normalizeBranchVisibility(item.visibility),
                    ownerUserId: USERS[ownerUserId] ? ownerUserId : CURRENT_USER_ID,
                    sharedUserIds: normalizeBranchSharedUsers(item.sharedUserIds || item.shared_user_ids)
                };
            }
            const id = String(item.id || '').trim();
            const name = String(item.name || '').trim();
            if (!id || !name) return null;
            const ownerUserId = normalizeUserKey(item.ownerUserId || item.owner_user_id || CURRENT_USER_ID);
            return {
                ...item,
                type: 'page',
                id,
                name,
                visibility: normalizeBranchVisibility(item.visibility),
                ownerUserId: USERS[ownerUserId] ? ownerUserId : CURRENT_USER_ID,
                sharedUserIds: normalizeBranchSharedUsers(item.sharedUserIds || item.shared_user_ids)
            };
        }

        function normalizeBranchItems(items, config) {
            return (Array.isArray(items) ? items : [])
                .map((item) => normalizeBranchItem(item, config))
                .filter(Boolean);
        }

        function getFirstBranchPage(branchKey) {
            return getBranchState(branchKey)?.pages.find((page) => isBranchPage(page) && canViewBranchPage(page)) || null;
        }

        function getRawBranchPage(branchKey, pageId) {
            const state = getBranchState(branchKey);
            if (!state) return null;
            return state.pages.find((page) => isBranchPage(page) && page.id === pageId) || null;
        }

        function getRawBranchItem(branchKey, itemId) {
            const state = getBranchState(branchKey);
            if (!state) return null;
            return state.pages.find((item) => item.id === itemId) || null;
        }

        function getBranchPage(branchKey, pageId) {
            const page = getRawBranchPage(branchKey, pageId);
            return page && canViewBranchPage(page) ? page : null;
        }

        function canManageBranchItem(item) {
            return !!item && (isAdminUser(CURRENT_USER_ID) || item.ownerUserId === CURRENT_USER_ID);
        }

        function canManageBranchPage(page) {
            return isBranchPage(page) && canManageBranchItem(page);
        }

        function canViewBranchItem(item) {
            if (!item) return false;
            if (isAdminUser(CURRENT_USER_ID) || item.ownerUserId === CURRENT_USER_ID) return true;
            if (item.visibility === 'personal') return false;
            if (item.visibility === 'shared') return item.sharedUserIds.includes(CURRENT_USER_ID);
            const teamUsers = getUsersByTeamCode(selectedTeamCode || getCurrentTeamCode());
            return !teamUsers.length || teamUsers.includes(CURRENT_USER_ID);
        }

        function canViewBranchPage(page) {
            return isBranchPage(page) && canViewBranchItem(page);
        }

        function getBranchVisibleItems(branchKey) {
            const state = getBranchState(branchKey);
            if (!state) return [];
            const hasVisiblePageBefore = (index) => state.pages.slice(0, index).some((item) => isBranchPage(item) && canViewBranchPage(item));
            const hasVisiblePageAfter = (index) => state.pages.slice(index + 1).some((item) => isBranchPage(item) && canViewBranchPage(item));
            const hasAnyVisiblePage = state.pages.some((item) => isBranchPage(item) && canViewBranchPage(item));
            return state.pages.reduce((items, item, index) => {
                if (isBranchPage(item)) {
                    if (canViewBranchPage(item)) items.push(item);
                    return items;
                }
                if (!canViewBranchItem(item)) return items;
                const hasDividerLabel = String(item?.label || '').trim();
                const shouldShowDivider = hasDividerLabel
                    ? hasAnyVisiblePage
                    : hasVisiblePageBefore(index) && hasVisiblePageAfter(index);
                if (isBranchDivider(item) && shouldShowDivider && !isBranchDivider(items[items.length - 1])) {
                    items.push(item);
                }
                return items;
            }, []);
        }

        function getBranchVisibilityLabel(item) {
            if (item.visibility === 'personal') return 'Me';
            if (item.visibility === 'shared') return 'Share';
