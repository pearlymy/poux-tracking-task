        .kanban-column[data-color-theme="red"] .task-card:hover { border-color: #f87171 !important; }

        @keyframes shake {

            0%,
            100% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-5px);
            }

            50% {
                transform: translateX(5px);
            }

            75% {
                transform: translateX(-5px);
            }
        }

        .input-error {
            animation: shake 0.3s ease-in-out;
            border-color: #ef4444 !important;
            background-color: #fef2f2 !important;
        }

        .input-error::placeholder {
            color: #ef4444 !important;
            font-style: italic;
        }

        .task-desc {
            white-space: pre-wrap;
            word-break: break-word;
        }

        .tag-name {
            --dot-color: #94a3b8;
            position: relative;
            z-index: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 28px;
            padding: 0 14px 0 12px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.12);
            white-space: nowrap;
            line-height: 1;
            transition: box-shadow 0.16s ease, filter 0.16s ease;
        }

        .tag-name:hover {
            box-shadow: 0 14px 24px rgba(15, 23, 42, 0.14);
            filter: saturate(1.05);
        }

        .tag-name[data-user-key] {
            cursor: pointer;
        }

        .tag-label {
            position: relative;
            z-index: 1;
            display: inline-flex;
            align-items: center;
        }

        .tag-status-dot {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 9px;
            height: 9px;
            border-radius: 9999px;
            background: var(--dot-color);
            box-shadow:
                0 0 0 1.5px rgba(255, 255, 255, 0.95),
                0 4px 9px color-mix(in srgb, var(--dot-color) 22%, transparent);
            overflow: hidden;
        }

        .tag-status-dot::before,
        .tag-status-dot::after {
            content: "";
            position: absolute;
            inset: 0;
        }

        .tag-status-dot::before {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.78) 0%, rgba(255, 255, 255, 0.18) 42%, transparent 43%);
        }

        .tag-status-dot::after {
            background: linear-gradient(315deg, rgba(0, 0, 0, 0.10) 0%, transparent 45%);
        }

        .tag-status-lov {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 148px;
            padding: 6px;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
