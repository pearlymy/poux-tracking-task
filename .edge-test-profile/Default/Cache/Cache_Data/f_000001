        function normalizeTaskDocumentLink(value) {
            const trimmedValue = String(value || '').trim();
            if (!trimmedValue) return '';
            if (/^https?:\/\//i.test(trimmedValue)) return trimmedValue;
            if (/^[\w.-]+\.[a-z]{2,}/i.test(trimmedValue)) return `https://${trimmedValue}`;
            return '';
        }

        function hydrateTaskDocumentLinks(root = document) {
            if (!root) return;
            root.querySelectorAll('.task-document-display-note').forEach((noteEl) => {
                if (noteEl.classList.contains('is-placeholder') || noteEl.querySelector('a')) return;
                const noteText = (noteEl.textContent || '').trim();
                const normalizedLink = normalizeTaskDocumentLink(noteText);
                if (!normalizedLink) return;
                noteEl.textContent = '';
                const linkEl = document.createElement('a');
                linkEl.href = normalizedLink;
                linkEl.target = '_blank';
                linkEl.rel = 'noopener noreferrer';
                linkEl.textContent = noteText;
                linkEl.addEventListener('click', (event) => {
                    event.stopPropagation();
                });
                noteEl.appendChild(linkEl);
            });
        }

        function buildLinkifiedTextFragment(text) {
            const fragment = document.createDocumentFragment();
            const sourceText = String(text || '');
            const urlPattern = /(https?:\/\/[^\s<]+|(?:www\.)?[\w.-]+\.[a-z]{2,}(?:\/[^\s<]*)?)/gi;
            let lastIndex = 0;
            let match;
            while ((match = urlPattern.exec(sourceText)) !== null) {
                const matchedText = match[0];
                const matchIndex = match.index;
                if (matchIndex > lastIndex) {
                    fragment.appendChild(document.createTextNode(sourceText.slice(lastIndex, matchIndex)));
                }
                const normalizedLink = normalizeTaskDocumentLink(matchedText);
                if (normalizedLink) {
                    const linkEl = document.createElement('a');
                    linkEl.href = normalizedLink;
                    linkEl.target = '_blank';
                    linkEl.rel = 'noopener noreferrer';
                    linkEl.textContent = matchedText;
                    linkEl.addEventListener('click', (event) => {
                        event.stopPropagation();
                    });
                    fragment.appendChild(linkEl);
                } else {
                    fragment.appendChild(document.createTextNode(matchedText));
                }
                lastIndex = matchIndex + matchedText.length;
            }
            if (lastIndex < sourceText.length) {
                fragment.appendChild(document.createTextNode(sourceText.slice(lastIndex)));
            }
            return fragment;
        }

        function hydrateTaskCommentLinks(root = document) {
            if (!root) return;
            root.querySelectorAll('.task-comment-body').forEach((commentBodyEl) => {
                const walker = document.createTreeWalker(commentBodyEl, NodeFilter.SHOW_TEXT, {
                    acceptNode(textNode) {
                        if (!textNode?.textContent?.trim()) return NodeFilter.FILTER_REJECT;
                        const parentEl = textNode.parentElement;
                        if (!parentEl) return NodeFilter.FILTER_REJECT;
                        if (parentEl.closest('a, .task-comment-mention')) return NodeFilter.FILTER_REJECT;
                        return /https?:\/\/|(?:^|\s)(?:www\.)?[\w.-]+\.[a-z]{2,}/i.test(textNode.textContent)
                            ? NodeFilter.FILTER_ACCEPT
                            : NodeFilter.FILTER_REJECT;
                    }
                });
                const textNodes = [];
                let currentNode = walker.nextNode();
                while (currentNode) {
                    textNodes.push(currentNode);
                    currentNode = walker.nextNode();
                }
                textNodes.forEach((textNode) => {
                    const fragment = buildLinkifiedTextFragment(textNode.textContent || '');
                    textNode.parentNode?.replaceChild(fragment, textNode);
                });
            });
        }

        function hydrateTaskDocumentEditState(root = document) {
            if (!root) return;
