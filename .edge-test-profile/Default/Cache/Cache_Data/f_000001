        function saveOrgSelectionChanges() {
            const selection = getOrgSelectionMeta();
            if (!selection) return;

            const codeInput = document.getElementById('orgDetailCode');
            const codeSuffixInput = document.getElementById('orgDetailCodeSuffix');
            const nameInput = document.getElementById('orgDetailName');
            const orderInput = document.getElementById('orgDetailOrder');
            const descriptionInput = document.getElementById('orgDetailDescription');
            const leaderInput = document.getElementById('orgDetailLeader');
            const trimmedCode = (codeSuffixInput?.value || codeInput?.value || '').trim();
            const trimmedName = nameInput?.value.trim() || '';

            clearCreateOrgValidation();
            if (isCreatingOrgSelection) {
                const invalidFields = [];
                if (!trimmedCode) invalidFields.push('code');
                if (!trimmedName) invalidFields.push('name');
                if (invalidFields.length) {
                    invalidFields.forEach(markCreateOrgFieldError);
                    return;
                }
            }

            selection.entity.code = trimmedCode || selection.entity.code;
            selection.entity.name = trimmedName || selection.entity.name;
            if (orderInput) selection.entity.display_order = Number(orderInput.value) || 1;
            if (descriptionInput) selection.entity.description = descriptionInput.value;
            if (leaderInput && selection.type === 'team') selection.entity.leader_user_id = leaderInput.value;

            if (isCreatingOrgSelection && currentOrgDraft) {
                const entityToSave = { ...selection.entity };
                if (selection.type === 'block') {
                    entityToSave.id = `blk_${Date.now()}`;
                    ADMIN_SEED.blocks.push(entityToSave);
                } else if (selection.type === 'department') {
                    entityToSave.id = `dep_${Date.now()}`;
                    ADMIN_SEED.departments.push(entityToSave);
                } else {
                    entityToSave.id = `team_${Date.now()}`;
                    ADMIN_SEED.teams.push(entityToSave);
                }
                currentOrgSelection = { type: selection.type, id: entityToSave.id };
                currentOrgDraft = null;
                showAdminToast(`Đã tạo ${getOrgEntityToastLabel({ type: selection.type, entity: entityToSave })}.`);
            } else {
                showAdminToast(`Đã lưu thay đổi cho ${getOrgEntityToastLabel(selection)}.`);
            }

            isCreatingOrgSelection = false;
            currentOrgDetailMode = 'view';
            renderAdminOrgPanel();
        }

