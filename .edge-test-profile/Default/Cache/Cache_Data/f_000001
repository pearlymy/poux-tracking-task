                            <div class="tracking-skeleton tracking-skeleton-line is-short"></div>
                        </div>
                    </div>
                `).join('');
                if (formNode) {
                    formNode.insertAdjacentHTML('afterend', skeletonHtml);
                } else {
                    columnEl.insertAdjacentHTML('beforeend', skeletonHtml);
                }
            });
        }

        function showTrackingSkeleton(viewMode, renderContent) {
            clearTrackingSkeletonTimer();
            if (window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches || !shouldShowTrackingSkeleton(viewMode)) {
                renderContent?.();
                return;
            }
            if (viewMode === 'list') renderTaskListSkeleton();
            else renderBoardSkeleton();
            trackingSkeletonTimeout = window.setTimeout(() => {
                trackingSkeletonTimeout = null;
                renderContent?.();
            }, 180);
        }

        function renderTaskListView(options = {}) {
            const body = document.getElementById('taskListBody');
            if (!body) return;
            const visibleTickets = getVisibleBoardTicketEntries();
            renderTaskListControls(visibleTickets);
            const filteredTickets = getFilteredTaskListEntries(visibleTickets);
            if (!filteredTickets.length) {
                body.innerHTML = '<div class="task-list-empty">Không có ticket nào khớp với bộ lọc hiện tại.</div>';
                return;
            }

            body.innerHTML = taskListGroupMode === 'none'
                ? filteredTickets.map((entry, index) => renderTaskListRow(entry, index, options)).join('')
                : renderTaskListGroupedView(filteredTickets, options);
        }

        function renderBoardTickets(options = {}) {
            document.querySelectorAll('.kanban-list .task-card, .kanban-list .tracking-skeleton-card').forEach((card) => card.remove());

            const visibleTickets = getVisibleBoardTicketEntries();

            visibleTickets.forEach(({ ticketState, assignee }) => {
                const stateCode = ticketState.is_personal
                    ? getDefaultStateCode().stateCode
                    : (assignee?.workflow_state || getDefaultStateCode().stateCode);
                const columnEl = document.getElementById(getStateColumnId(stateCode));
                if (!columnEl) return;
                columnEl.appendChild(createTaskCardElement(ticketState, assignee?.user_key || ''));
            });

            updateCounts();
            ensureSortableColumns();
            renderTaskListView({ staticValues: !!options.staticTaskListValues });
            syncTaskDetailsDrawer();
        }

        function getLovMotionDurationMs(varName = '--lov-close-duration') {
            const rawDuration = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
            const match = rawDuration.match(/^([\d.]+)\s*(ms|s)$/i);
            if (!match) return 180;
            const value = Number(match[1]);
            if (!Number.isFinite(value)) return 180;
            return match[2].toLowerCase() === 's' ? value * 1000 : value;
        }

        function clearAssigneeStatusLovCloseTimer() {
            if (!assigneeStatusLovCloseTimeout) return;
            window.clearTimeout(assigneeStatusLovCloseTimeout);
            assigneeStatusLovCloseTimeout = null;
        }

        function finishAssigneeStatusLovClose(lovKey) {
            if (lovKey && closingAssigneeStatusLovKey !== lovKey) return;
            closingAssigneeStatusLovKey = '';
            assigneeStatusLovCloseTimeout = null;
            renderBoardTickets({ staticTaskListValues: true });
        }

        function beginAssigneeStatusLovClose(lovKey = openAssigneeStatusLovKey, { immediate = false } = {}) {
            if (!lovKey && !closingAssigneeStatusLovKey) return false;
            clearAssigneeStatusLovCloseTimer();
            openAssigneeStatusLovKey = '';
            closingAssigneeStatusLovKey = lovKey || closingAssigneeStatusLovKey;
            const shouldCloseImmediately = immediate || window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
            if (shouldCloseImmediately) {
                finishAssigneeStatusLovClose(closingAssigneeStatusLovKey);
                return true;
            }
            renderBoardTickets({ staticTaskListValues: true });
            assigneeStatusLovCloseTimeout = window.setTimeout(() => {
                finishAssigneeStatusLovClose(lovKey);
            }, getLovMotionDurationMs());
            return true;
        }

        function toggleAssigneeStatusLov(ticketId, userKey, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            closeTaskListPopovers({ immediate: true });
            const normalizedUserKey = normalizeUserKey(userKey);
            if (!ticketId || !normalizedUserKey) return;
            const lovKey = getAssigneeStatusLovKey(ticketId, normalizedUserKey);
            if (openAssigneeStatusLovKey === lovKey) {
                beginAssigneeStatusLovClose(lovKey);
                return;
            }
            clearAssigneeStatusLovCloseTimer();
            closingAssigneeStatusLovKey = '';
            openAssigneeStatusLovKey = lovKey;
            renderBoardTickets({ staticTaskListValues: true });
        }

        function selectAssigneeStatus(ticketId, userKey, stateCode, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            const normalizedUserKey = normalizeUserKey(userKey);
            const stateMeta = getStateConfig(stateCode) || getDefaultStateCode();
            const ticketState = getTaskDetailById(ticketId);
            if (!ticketState || ticketState.is_personal) return;

            const updatedAssignees = ticketState.assignees.map((record) => {
                if (record.user_key !== normalizedUserKey) return record;
                return { ...record, workflow_state: stateMeta.stateCode };
            });

            const lovKey = openAssigneeStatusLovKey || getAssigneeStatusLovKey(ticketId, normalizedUserKey);
            updateBoardTicket(ticketState.ticket_id, {
                ...ticketState,
                assignees: updatedAssignees
            });
            beginAssigneeStatusLovClose(lovKey);
            saveBoardState();
        }

        function closeAssigneeStatusLov() {
            beginAssigneeStatusLovClose();
        }

        function cycleAssigneeStatus(tag, event) {
            const card = tag?.closest?.('.task-card');
            const ticketId = card?.dataset?.ticketId || currentTaskDetailTicketId || '';
            toggleAssigneeStatusLov(ticketId, tag?.dataset?.userKey || '', event);
        }

        function generateTicketId() {
            const today = new Date();
            const yyyy = today.getFullYear();
            const mm = String(today.getMonth() + 1).padStart(2, '0');
            const dd = String(today.getDate()).padStart(2, '0');
            const currentDateStr = `${yyyy}${mm}${dd}`;

            let storedDate = localStorage.getItem('ticket_date');
            let counter = parseInt(localStorage.getItem('ticket_counter') || '0');

            if (storedDate !== currentDateStr) {
                storedDate = currentDateStr;
                counter = 1;
            } else {
                counter++;
            }

            localStorage.setItem('ticket_date', storedDate);
            localStorage.setItem('ticket_counter', counter.toString());

            const counterStr = String(counter).padStart(4, '0');
            return `${currentDateStr}${counterStr}`;
        }

        function syncTagNames() {
            boardTickets = boardTickets.map((ticketState) => normalizeTicketState(ticketState)).filter(Boolean);
            renderBoardTickets();
