        function renderBoardSkeleton(cardCount = 3) {
            clearBoardSkeleton();
            document.querySelectorAll('.kanban-list .task-card').forEach((card) => card.remove());
            getWorkflowStates().forEach((state) => {
                const columnEl = document.getElementById(getStateColumnId(state.stateCode));
                if (!columnEl) return;
                const formNode = columnEl.querySelector('.edit-form, form, [data-inline-form]');
                const skeletonHtml = Array.from({ length: cardCount }).map((_, index) => `
                    <div class="tracking-skeleton-card" aria-hidden="true" style="--appear-index:${index}">
                        <div class="tracking-skeleton tracking-skeleton-line is-title"></div>
                        <div class="tracking-skeleton tracking-skeleton-line"></div>
                        <div class="flex items-center justify-between gap-3">
