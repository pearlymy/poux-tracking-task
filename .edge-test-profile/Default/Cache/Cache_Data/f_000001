        function saveMemberForm() {
            const userId = document.getElementById('memberUserId')?.value;
            const fullName = document.getElementById('memberFullName');
            const username = document.getElementById('memberUsername');
            const email = document.getElementById('memberEmail');
            const jobTitleId = document.getElementById('memberJobTitleId');
            const teamId = document.getElementById('memberTeamId');
            const roleId = document.getElementById('memberRoleId');
            const color = document.getElementById('memberColor');
            const sortOrder = document.getElementById('memberSortOrder');
            const active = document.getElementById('memberActive');
            const isCreatingMember = !currentMemberEditId;
            const trimmedFullName = fullName?.value.trim() || '';
            const trimmedUsername = username?.value.trim() || '';
            const trimmedEmail = email?.value.trim() || '';
            let user = isCreatingMember ? null : getSeedUserById(userId);

            clearCreateMemberValidation();
            if (isCreatingMember) {
                const invalidFields = [];
                if (!trimmedFullName) invalidFields.push('fullName');
                if (!trimmedUsername) invalidFields.push('username');
                if (!trimmedEmail) invalidFields.push('email');
                if (!(jobTitleId?.value || '').trim()) invalidFields.push('jobTitle');
                if (!(teamId?.value || '').trim()) invalidFields.push('team');
                if (invalidFields.length) {
                    invalidFields.forEach(markCreateMemberFieldError);
                    return;
                }
            }

            if (isCreatingMember) {
                const draft = currentMemberDraft || createMemberDraft();
                const newUser = {
                    id: draft.id,
                    username: trimmedUsername,
                    email: trimmedEmail,
                    full_name: trimmedFullName,
                    job_title_id: jobTitleId?.value || '',
                    color: color?.value.trim() || draft.color,
                    sort_order: Number(sortOrder?.value) || draft.sort_order,
                    is_active: active ? active.checked : true
                };
                ADMIN_SEED.users.push(newUser);
                user = newUser;
            }

            if (!user) return;

            if (fullName) user.full_name = trimmedFullName;
            if (username && !username.disabled) user.username = trimmedUsername || user.username;
            if (email && !email.disabled) user.email = trimmedEmail || user.email;
            if (jobTitleId) user.job_title_id = jobTitleId.value || user.job_title_id;
            if (color) user.color = color.value.trim() || user.color;
            if (sortOrder) user.sort_order = Number(sortOrder.value) || user.sort_order;
            if (active) user.is_active = active.checked;

            const selectedTeamId = teamId?.value || null;
            const selectedRoleId = roleId?.value || '';
            let assignment = ADMIN_SEED.userTeams.find((row) => row.user_id === userId && row.is_active);
            const previousTeamId = assignment?.team_id || null;
            if (assignment && selectedTeamId) {
                assignment.team_id = selectedTeamId;
            } else if (!assignment && selectedTeamId) {
                ADMIN_SEED.userTeams.push({
                    id: `ut_${Date.now()}`,
                    user_id: userId,
                    team_id: selectedTeamId,
                    is_primary: true,
                    is_active: true
                });
            }

            const teamAssignments = ADMIN_SEED.userRoleAssignments.filter((row) => row.user_id === userId && row.is_active && row.team_id);
            if (previousTeamId && selectedTeamId && previousTeamId !== selectedTeamId) {
                teamAssignments
                    .filter((row) => row.team_id === previousTeamId)
                    .forEach((row) => { row.is_active = false; });
            }

            const targetRoleAssignment = getTeamRoleAssignmentForUser(userId, selectedTeamId);
            if (selectedRoleId && selectedTeamId) {
                if (targetRoleAssignment) {
