        // ==========================================
        // 1. HỆ THỐNG LƯU TRỮ (LOCAL STORAGE)
        // ==========================================
        function updateCounts() {
            getWorkflowStates().forEach(state => {
                const countEl = document.getElementById(getStateCountId(state.stateCode));
                const columnEl = document.getElementById(getStateColumnId(state.stateCode));
                if (countEl && columnEl) {
                    countEl.innerText = Array.from(columnEl.querySelectorAll('.task-card'))
                        .filter((card) => card.style.display !== 'none').length;
                }
            });
        }

        function syncBoardTicketOrderFromRenderedCards() {
            const orderedTicketIds = Array.from(document.querySelectorAll('.kanban-list-body .task-card'))
                .map((card) => card.dataset.ticketId || '')
                .filter(Boolean)
                .filter((ticketId, index, ticketIds) => ticketIds.indexOf(ticketId) === index);
            if (!orderedTicketIds.length) return;

            const ticketById = new Map(boardTickets.map((ticketState) => [ticketState.ticket_id, ticketState]));
            const orderedVisibleTickets = orderedTicketIds
                .map((ticketId) => ticketById.get(ticketId))
                .filter(Boolean);
            if (!orderedVisibleTickets.length) return;

            const orderedIdSet = new Set(orderedTicketIds);
            let visibleIndex = 0;
            boardTickets = boardTickets.map((ticketState) => {
                if (!orderedIdSet.has(ticketState.ticket_id)) return ticketState;
                const nextTicketState = orderedVisibleTickets[visibleIndex];
                visibleIndex += 1;
                return nextTicketState || ticketState;
            });
        }

        function saveBoardState() {
            localStorage.setItem(BOARD_STORAGE_KEY, JSON.stringify(boardTickets));
            refreshTrackingSidebarAndBoard();
            syncTaskDetailsDrawer();
        }

        function loadLegacyBoardState() {
            const legacyState = {};
            let hasLegacyData = false;

            getWorkflowStates().forEach(state => {
                if (!state.legacyStorageKey) return;
                const raw = localStorage.getItem(state.legacyStorageKey);
                if (!raw) return;

                try {
                    legacyState[state.stateCode] = JSON.parse(raw) || [];
                    hasLegacyData = true;
                } catch (error) {
                    legacyState[state.stateCode] = [];
                }
            });

            return hasLegacyData ? legacyState : null;
        }

        function loadBoardState() {
            let boardState = null;
            let loadedFromLegacyStorage = false;

            try {
                boardState = JSON.parse(localStorage.getItem(BOARD_STORAGE_KEY));
            } catch (error) {
                boardState = null;
            }

            if (!boardState || typeof boardState !== 'object') {
                boardState = loadLegacyBoardState();
                loadedFromLegacyStorage = !!boardState;
            }

            boardTickets = [];
            if (Array.isArray(boardState)) {
                boardTickets = boardState.map((ticketState) => normalizeTicketState(ticketState)).filter(Boolean);
            } else if (boardState && typeof boardState === 'object') {
                getWorkflowStates().forEach((state) => {
                    const tasks = Array.isArray(boardState[state.stateCode]) ? boardState[state.stateCode] : [];
                    tasks.forEach((html) => {
                        const template = document.createElement('template');
                        template.innerHTML = html.trim();
                        const card = template.content.firstElementChild;
                        if (!card) return;
                        const ticketState = getCardState(card);
                        if (!ticketState) return;
                        const migratedTicketState = {
                            ...ticketState,
                            assignees: (ticketState.assignees || []).map((record) => ({
                                ...record,
                                workflow_state: state.stateCode
                            }))
                        };
                        boardTickets.push(normalizeTicketState(migratedTicketState));
                    });
                });
            }

            renderInlinePicSelection();
            syncTagNames();
            refreshTrackingSidebarAndBoard();

            if (loadedFromLegacyStorage) {
                saveBoardState();
            }
        }

