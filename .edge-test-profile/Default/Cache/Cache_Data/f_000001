            return getCardAssignees(card).map((record) => record.user_key);
        }

        function isAllTrackingUsersKey(userKey) {
            return userKey === ALL_TRACKING_USERS_KEY;
        }

        function normalizeTrackingUserKey(userKey) {
            const rawUserKey = String(userKey || '').trim();
            if (rawUserKey.toLowerCase() === ALL_TRACKING_USERS_ROUTE_VALUE || rawUserKey === ALL_TRACKING_USERS_KEY) {
                return ALL_TRACKING_USERS_KEY;
            }
            return normalizeUserKey(rawUserKey) || '';
        }

        function getTrackingRouteUserValue(userKey) {
            return isAllTrackingUsersKey(userKey) ? ALL_TRACKING_USERS_ROUTE_VALUE : userKey;
        }

        function getCurrentSortedTeamUserKeys(teamKey = selectedTeamCode) {
            return getSortedTrackingUsers(getUsersByTeamCode(teamKey));
        }

        function getTicketTeamAssignee(ticketState, teamUsers = getCurrentSortedTeamUserKeys()) {
            if (!ticketState || ticketState.is_personal) return null;
            return teamUsers
                .map((userKey) => getTicketAssignee(ticketState, userKey))
                .find(Boolean) || null;
        }

        function getBoardTrackingUserKey() {
            return activeTrackingUserKey || CURRENT_USER_ID;
        }

        function getTicketAssignee(ticketState, userKey = getBoardTrackingUserKey()) {
            const normalizedUserKey = normalizeUserKey(userKey);
            return (ticketState?.assignees || []).find((record) => record.user_key === normalizedUserKey) || null;
        }

        function getTicketWorkflowState(ticketState, userKey = getBoardTrackingUserKey()) {
            return getTicketAssignee(ticketState, userKey)?.workflow_state || getDefaultStateCode().stateCode;
        }

        function setTicketWorkflowState(ticketState, userKey, stateCode) {
            const normalizedUserKey = normalizeUserKey(userKey);
            const normalizedStateCode = getStateConfig(stateCode)?.stateCode || getDefaultStateCode().stateCode;
            return {
                ...ticketState,
                assignees: (ticketState.assignees || []).map((record) => (
                    record.user_key === normalizedUserKey
                        ? { ...record, workflow_state: normalizedStateCode }
                        : record
                ))
            };
        }

        function updateBoardTicket(ticketId, updater) {
            boardTickets = boardTickets.map((ticketState) => {
                if (ticketState.ticket_id !== ticketId) return ticketState;
                const nextState = typeof updater === 'function' ? updater(ticketState) : updater;
                return normalizeTicketState(nextState) || ticketState;
            });
        }

        function getTaskCountForUser(userKey) {
            const normalizedUserKey = normalizeUserKey(userKey);
            return boardTickets.filter((ticketState) => {
                if (ticketState.is_personal) {
                    return false;
                }
                return (ticketState.assignees || []).some((record) => record.user_key === normalizedUserKey);
            }).length;
        }

        function getTaskCountForTeam(teamKey = selectedTeamCode) {
            const teamUsers = new Set(getUsersByTeamCode(teamKey));
            if (!teamUsers.size) return 0;
            return boardTickets.filter((ticketState) => {
                if (ticketState.is_personal) return false;
                return (ticketState.assignees || []).some((record) => teamUsers.has(record.user_key));
            }).length;
        }

        function getPreferredTrackingUserKey(teamUsers) {
            if (!teamUsers.length) return null;
            if (isAllTrackingUsersKey(activeTrackingUserKey)) return ALL_TRACKING_USERS_KEY;
            if (activeTrackingUserKey && teamUsers.includes(activeTrackingUserKey)) return activeTrackingUserKey;
            return ALL_TRACKING_USERS_KEY;
        }

        function getTrackingRouteFromUrl() {
            const params = new URLSearchParams(window.location.search);
            return {
                workspace: params.get('workspace') || '',
                team: params.get('team') || '',
                user: normalizeTrackingUserKey(params.get('user') || '') || '',
                ticket: params.get('ticket') || ''
            };
        }

        function isTrackingRoute(route = getTrackingRouteFromUrl()) {
            return route.workspace === 'tracking' || !!route.team || !!route.user || !!route.ticket;
        }

        function buildTrackingUrl({ team = selectedTeamCode, user = activeTrackingUserKey, ticketId = null } = {}) {
            const url = new URL(window.location.href);
            url.search = '';
            url.searchParams.set('workspace', 'tracking');
            if (team) url.searchParams.set('team', team);
            if (user) url.searchParams.set('user', getTrackingRouteUserValue(user));
            if (ticketId) url.searchParams.set('ticket', ticketId);
            return url;
        }

        function getTrackingRouteHref(userKey, teamKey = selectedTeamCode) {
            return buildTrackingUrl({ team: teamKey, user: userKey, ticketId: null }).href;
        }

        function updateTrackingUrl({ ticketId = null, replace = false } = {}) {
            if (isApplyingTrackingRoute) return;
            const userKey = activeTrackingUserKey || getBoardTrackingUserKey();
            const nextUrl = buildTrackingUrl({ team: selectedTeamCode, user: userKey, ticketId });
            if (nextUrl.href === window.location.href) return;
            const method = replace ? 'replaceState' : 'pushState';
            window.history[method]({ workspace: 'tracking', team: selectedTeamCode, user: getTrackingRouteUserValue(userKey), ticket: ticketId || '' }, '', nextUrl);
        }

        function resolveTrackingRoute(route = getTrackingRouteFromUrl()) {
            const availableTeams = getAvailableTeamCodesForUser(CURRENT_USER_ID);
            const routeUser = normalizeTrackingUserKey(route.user || '') || '';
            const teamFromUser = routeUser
                ? availableTeams.find((teamCode) => getUsersByTeamCode(teamCode).includes(routeUser))
                : null;
            const savedTeam = localStorage.getItem(TEAM_STORAGE_KEY);
            const team = availableTeams.includes(route.team)
                ? route.team
                : (teamFromUser || (selectedTeamCode && availableTeams.includes(selectedTeamCode) ? selectedTeamCode : null) || (availableTeams.includes(savedTeam) ? savedTeam : null) || availableTeams[0] || null);
            const teamUsers = getSortedTrackingUsers(getUsersByTeamCode(team));
            const ticketState = route.ticket ? getTaskDetailById(route.ticket) : null;
            const ticketUser = ticketState && !ticketState.is_personal
                ? (ticketState.assignees || []).map((record) => record.user_key).find((userKey) => teamUsers.includes(userKey))
                : null;
            const user = isAllTrackingUsersKey(routeUser)
                ? ALL_TRACKING_USERS_KEY
                : teamUsers.includes(routeUser)
                ? routeUser
                : (ticketUser || ALL_TRACKING_USERS_KEY);

            return {
                team,
                user,
                ticket: ticketState ? route.ticket : '',
                hasInvalidTicket: !!route.ticket && !ticketState
            };
        }

        function applyTrackingRouteFromUrl({ replaceUrl = false } = {}) {
            const route = getTrackingRouteFromUrl();
            const resolved = resolveTrackingRoute(route);
            isApplyingTrackingRoute = true;
            try {
                preferredNavTarget = 'trackingMenu';
                preferredNavLink = null;
                activeTrackingUserKey = resolved.user;
                if (selectedTeamCode !== resolved.team) {
                    applySelectedTeam(resolved.team, { updateUrl: false, staticTaskListValues: true });
                } else {
                    renderTrackingList(resolved.team);
                    applyBoardFilter({ staticTaskListValues: true });
                }
                setWorkspaceView('board', { staticTaskListValues: true });
                syncActiveNavState();
                if (resolved.ticket) {
                    openTaskDetailsDrawer(resolved.ticket, { updateUrl: false });
                } else {
                    closeTaskDetailsDrawer({ updateUrl: false, immediate: true });
                }
            } finally {
                isApplyingTrackingRoute = false;
            }
            if (replaceUrl || resolved.hasInvalidTicket) {
                updateTrackingUrl({ ticketId: resolved.ticket || null, replace: true });
            }
        }

        function getSortedTrackingUsers(teamUsers) {
            return [...teamUsers].sort((userKeyA, userKeyB) => {
                const userA = USERS[userKeyA];
                const userB = USERS[userKeyB];
                const titleA = getJobTitleMetaById(userA.job_title_id);
                const titleB = getJobTitleMetaById(userB.job_title_id);
                const titleSortA = titleA?.sort ?? Number.MAX_SAFE_INTEGER;
                const titleSortB = titleB?.sort ?? Number.MAX_SAFE_INTEGER;

                if (titleSortA !== titleSortB) return titleSortA - titleSortB;

                if (!titleA && !titleB) {
                    const titleCompare = getJobTitleName(userA.job_title_id).localeCompare(getJobTitleName(userB.job_title_id), 'vi');
                    if (titleCompare !== 0) return titleCompare;
                }

                return (userA.sort ?? Number.MAX_SAFE_INTEGER) - (userB.sort ?? Number.MAX_SAFE_INTEGER);
            });
        }

        function applyBoardFilter(options = {}) {
            renderBoardTickets({ staticTaskListValues: !!options.staticTaskListValues });
        }

        function refreshTrackingSidebarAndBoard() {
            if (!selectedTeamCode) return;
            renderTrackingList(selectedTeamCode);
            applyBoardFilter();
        }

        function applyDefaultInlinePicSelection() {
            const assignableUserKeys = getAssignableUserKeys();
            const defaultUserKey = activeTrackingUserKey && !isAllTrackingUsersKey(activeTrackingUserKey) && assignableUserKeys.includes(activeTrackingUserKey)
                ? activeTrackingUserKey
                : (assignableUserKeys.includes(CURRENT_USER_ID) ? CURRENT_USER_ID : (assignableUserKeys[0] || DEFAULT_INLINE_PIC_ID));
            const defaultPicBtn = document.querySelector(`#inlinePicSelection button[data-user-key="${defaultUserKey}"]`);
            if (!defaultPicBtn) return;

            if (!inlineSelectedPICs.includes(defaultUserKey)) {
                inlineSelectedPICs.push(defaultUserKey);
            }
            defaultPicBtn.classList.add('po-tag-active');
        }

        // GIẢ LẬP ĐĂNG NHẬP: Đổi thành 'U0004' (Vân), 'U0006' (Thắng) để test
        const CURRENT_USER_ID = 'U0001'; 

        // Hàm áp dụng quyền lên giao diện
        function applyUIPermissions() {
            // Kiểm tra quyền tạo Task
            const canCreate = checkPermission(CURRENT_USER_ID, 'CREATE_TASK');
            
            // Tìm tất cả các nút có gọi hàm openInlineForm()
            const addButtons = document.querySelectorAll('[onclick="openInlineForm()"]');
            addButtons.forEach(btn => {
                // Nếu không có quyền -> Ẩn nút đi
                btn.style.display = canCreate ? 'flex' : 'none';
