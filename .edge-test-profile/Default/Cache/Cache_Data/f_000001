            if (type === 'block') {
                const block = getSeedBlockById(id);
                if (!block) return null;
                return {
                    type,
                    entity: block,
                    title: 'Thông tin khối',
                    subtitle: 'Chỉnh sửa thông tin khối và định hướng các phòng ban trực thuộc.',
                    parentLabel: 'Root',
                    stats: `${ADMIN_SEED.departments.filter((item) => item.block_id === id).length} phòng`
                };
            }

            if (type === 'department') {
                const department = getSeedDepartmentById(id);
                if (!department) return null;
                const block = getSeedBlockById(department.block_id);
                return {
                    type,
                    entity: department,
                    title: 'Thông tin phòng',
                    subtitle: 'Cập nhật phòng ban và quản lý các nhóm trực thuộc.',
                    parentLabel: block ? `${block.code} - ${block.name}` : 'Chưa có khối',
                    stats: `${ADMIN_SEED.teams.filter((item) => item.department_id === id).length} nhóm`
                };
            }

            const team = getSeedTeamById(id);
            if (!team) return null;
            const department = getSeedDepartmentById(team.department_id);
            const block = department ? getSeedBlockById(department.block_id) : null;
            return {
                type,
                entity: team,
                title: 'Thông tin nhóm',
                subtitle: 'Điều chỉnh nhóm, người phụ trách và cấu trúc triển khai.',
                parentLabel: [block?.code, department?.code].filter(Boolean).join(' / ') || 'Chưa có phòng',
                stats: `${ADMIN_SEED.userTeams.filter((item) => item.team_id === id && item.is_active).length} thành viên`
            };
        }

