        function buildTaskDetailsDrawerHtml(ticketState) {
            if (!ticketState) return '';

            const normalizedState = normalizeTicketState(ticketState);
            if (!normalizedState) return '';

            const { dateStr, statusTextHtml } = getTaskDateMeta(normalizedState.date_raw);
            const trackingUserKey = getBoardTrackingUserKey();
            const focusedAssignee = getTicketAssignee(normalizedState, trackingUserKey);
            const focusedWorkflowState = normalizedState.is_personal
                ? getDefaultStateCode()
                : (getStateConfig(getTicketWorkflowState(normalizedState, trackingUserKey)) || getDefaultStateCode());
            const boardAssigneeHtml = normalizedState.is_personal
                ? `<div class="w-3 h-3 rounded-full bg-orange-500 border-2 border-white shadow-sm ring-1 ring-orange-200" title="Task cá nhân"></div>`
                : renderAssigneeTags(normalizedState.assignees, normalizedState.ticket_id);
            const boardNoteHtml = normalizedState.note
                ? `<div class="mt-3 pt-3 border-t border-dashed border-slate-200">
                        <p class="text-left text-[12px] text-slate-600 leading-6 whitespace-pre-wrap break-words">${escapeHtml(normalizedState.note)}</p>
                   </div>`
                : '';

            return `
                <div class="task-detail-drawer-layer">
                    <div class="task-detail-backdrop" onclick="closeTaskDetailsDrawer()"></div>
                    <button type="button" class="org-action-btn is-icon tooltip-btn rounded-full task-detail-close-btn" data-tooltip="Đóng" onclick="closeTaskDetailsDrawer()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                    <div class="task-detail-drawer">
                        <div class="task-detail-panel space-y-5">
                            <div class="flex items-start justify-between gap-4 px-1">
                                <div class="min-w-0">
                                    <p class="task-detail-label">Chi tiết task #${escapeHtml(normalizedState.ticket_id || 'N/A')}</p>
