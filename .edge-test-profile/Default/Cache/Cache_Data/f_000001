        function getChecklistDeadlineDisplayMeta(dateRaw) {
            if (!dateRaw) {
                return {
                    is_placeholder: true,
                    date_label: 'dd/mm/yyyy',
                    days_value: null,
                    days_class: ''
                };
            }

            const parts = dateRaw.split('-');
            const dateLabel = parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : dateRaw;
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const targetDate = new Date(dateRaw);
            targetDate.setHours(0, 0, 0, 0);
            const diffDays = Math.ceil((targetDate - today) / (1000 * 60 * 60 * 24));

            if (diffDays > 0) {
                return {
                    is_placeholder: false,
                    date_label: dateLabel,
                    days_value: diffDays,
                    days_class: 'is-positive'
                };
            }

            if (diffDays < 0) {
                return {
                    is_placeholder: false,
                    date_label: dateLabel,
                    days_value: Math.abs(diffDays),
                    days_class: 'is-negative'
                };
            }

            return {
                is_placeholder: false,
                date_label: dateLabel,
                days_value: 0,
                days_class: 'is-today'
            };
        }

