        function getChecklistDateViewBase(dateRaw) {
            if (dateRaw) {
                const [year, month] = dateRaw.split('-').map(Number);
                if (year && month) {
                    return { year, month: month - 1 };
                }
            }
            const today = new Date();
            return { year: today.getFullYear(), month: today.getMonth() };
        }

        function buildTaskChecklistDateGrid(year, month, selectedDateRaw) {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const firstDay = new Date(year, month, 1);
            const startDate = new Date(year, month, 1 - firstDay.getDay());
            const selectedDate = selectedDateRaw ? new Date(selectedDateRaw) : null;
            if (selectedDate) selectedDate.setHours(0, 0, 0, 0);
            const cells = [];

            for (let index = 0; index < 42; index += 1) {
                const cellDate = new Date(startDate);
                cellDate.setDate(startDate.getDate() + index);
                cellDate.setHours(0, 0, 0, 0);
                const isOutside = cellDate.getMonth() !== month;
                const isToday = cellDate.getTime() === today.getTime();
                const isSelected = selectedDate && cellDate.getTime() === selectedDate.getTime();
                const raw = `${cellDate.getFullYear()}-${String(cellDate.getMonth() + 1).padStart(2, '0')}-${String(cellDate.getDate()).padStart(2, '0')}`;
                cells.push({
                    raw,
                    label: String(cellDate.getDate()),
                    isOutside,
                    isToday,
                    isSelected
                });
            }

            return cells;
        }

