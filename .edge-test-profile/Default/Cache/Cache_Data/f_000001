            const nextIndex = ADMIN_SEED.roles.filter((role) => role.id.startsWith('role_custom_')).length + 1;
            const roleId = `role_custom_${String(nextIndex).padStart(3, '0')}`;
            const code = `CUSTOM_ROLE_${String(nextIndex).padStart(2, '0')}`;
            previousRoleSelectionId = currentRoleSelectionId;
            currentRoleDraft = {
                id: roleId,
                code,
                name: `Custom Role ${nextIndex}`,
                scope_type: 'TEAM',
