        function renderInlinePicSelection() {
            const container = document.getElementById('inlinePicSelection');
            if (!container) return;
            container.innerHTML = '';
            getAssignableUserKeys().forEach(key => {
                const user = USERS[key];
                container.innerHTML += `<button type="button" onclick="toggleInlinePic(this, '${key}')" class="po-tag" data-user-key="${key}">${user.full_name}</button>`;
            });
        }

        function getAssigneeStatusLovKey(ticketId, userKey) {
            return `${ticketId || ''}::${userKey || ''}`;
        }

        function buildAssigneeStatusLovHtml(ticketId, assigneeRecord) {
            const normalizedAssignee = normalizeAssigneeRecord(assigneeRecord);
            if (!ticketId || !normalizedAssignee) return '';
            const lovKey = getAssigneeStatusLovKey(ticketId, normalizedAssignee.user_key);
            const isClosing = closingAssigneeStatusLovKey === lovKey;
            if (openAssigneeStatusLovKey !== lovKey && !isClosing) return '';
            return `
                <div class="tag-status-lov ${isClosing ? 'is-closing' : ''}" onclick="event.stopPropagation()">
                    ${getWorkflowStates().map((state, index) => {
                        const stateMeta = getStateConfig(state.stateCode) || getDefaultStateCode();
                        const isActive = normalizedAssignee.workflow_state === stateMeta.stateCode;
                        const stateColor = getColorOptionMeta(stateMeta.colorTheme).hex;
                        return `
                            <button type="button" class="tag-status-lov-option ${isActive ? 'is-active' : ''}" style="--status-option-color:${stateColor}; --option-index:${index}" onclick="selectAssigneeStatus('${escapeHtml(ticketId)}', '${escapeHtml(normalizedAssignee.user_key)}', '${escapeHtml(stateMeta.stateCode)}', event)">
                                <span class="tag-status-lov-dot" aria-hidden="true"></span>
                                <span>${escapeHtml(stateMeta.stateName)}</span>
                            </button>
                        `;
                    }).join('')}
                </div>
            `;
        }

        function applyAssigneeTagPresentation(tag, assigneeRecord, ticketId = '') {
            if (!tag || !assigneeRecord) return;
            const normalizedAssignee = normalizeAssigneeRecord(assigneeRecord);
            if (!normalizedAssignee) return;
            const user = USERS[normalizedAssignee.user_key];
            if (!user) return '';
            const workflowMeta = getStateConfig(normalizedAssignee.workflow_state) || getDefaultStateCode();
            const workflowColor = getColorOptionMeta(workflowMeta.colorTheme).hex;
            tag.dataset.userKey = normalizedAssignee.user_key;
            tag.dataset.workflowState = workflowMeta.stateCode;
            tag.setAttribute('onclick', `toggleAssigneeStatusLov('${ticketId}', '${normalizedAssignee.user_key}', event)`);
            const lovKey = getAssigneeStatusLovKey(ticketId, normalizedAssignee.user_key);
            const isStatusLovOpen = lovKey === openAssigneeStatusLovKey || lovKey === closingAssigneeStatusLovKey;
            tag.className = `tag-name ${getWorkflowStateClass(workflowMeta.stateCode)} ${isStatusLovOpen ? 'is-status-lov-open' : ''}`;
            tag.setAttribute('title', `${user.full_name} - ${workflowMeta.stateName}`);
            tag.setAttribute('style', `--dot-color:${workflowColor}; background-color:${user.color}; border:1px solid ${user.color}; color:#ffffff;`);
            tag.innerHTML = `<span class="tag-label">${user.full_name}</span><span class="tag-status-dot"></span>${buildAssigneeStatusLovHtml(ticketId, normalizedAssignee)}`;
        }

        function createTagHtml(assigneeRecord, ticketId = '') {
            const normalizedAssignee = normalizeAssigneeRecord(assigneeRecord);
            if (!normalizedAssignee) return '';
            const user = USERS[normalizedAssignee.user_key];
            if (!user) return '';
            const workflowMeta = getStateConfig(normalizedAssignee.workflow_state) || getDefaultStateCode();
            const workflowColor = getColorOptionMeta(workflowMeta.colorTheme).hex;
            const lovKey = getAssigneeStatusLovKey(ticketId, normalizedAssignee.user_key);
            const isStatusLovOpen = lovKey === openAssigneeStatusLovKey || lovKey === closingAssigneeStatusLovKey;
            return `<div class="tag-name ${getWorkflowStateClass(workflowMeta.stateCode)} ${isStatusLovOpen ? 'is-status-lov-open' : ''}" data-user-key="${normalizedAssignee.user_key}" data-workflow-state="${workflowMeta.stateCode}" onclick="toggleAssigneeStatusLov('${escapeHtml(ticketId)}', '${escapeHtml(normalizedAssignee.user_key)}', event)" title="${escapeHtml(`${user.full_name} - ${workflowMeta.stateName}`)}" style="--dot-color:${workflowColor}; background-color:${user.color}; border:1px solid ${user.color}; color:#ffffff;"><span class="tag-label">${escapeHtml(user.full_name)}</span><span class="tag-status-dot"></span>${buildAssigneeStatusLovHtml(ticketId, normalizedAssignee)}</div>`;
        }

        function renderAssigneeTags(assignees, ticketId = '') {
            if (!assignees.length) {
                return `<div class="tag-name bg-slate-100 border-slate-200 text-slate-400">Chưa giao</div>`;
            }
            return assignees.map((record) => createTagHtml(record, ticketId)).join('');
        }

        function getTaskDateMeta(dateRaw) {
            if (!dateRaw) {
                return {
                    dateStr: 'Chưa có hạn',
                    statusTextHtml: ''
                };
            }

            const parts = dateRaw.split('-');
            const dateStr = `${parts[2]}/${parts[1]}/${parts[0]}`;
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const taskDate = new Date(dateRaw);
            taskDate.setHours(0, 0, 0, 0);
            const diffDays = Math.ceil((taskDate - today) / (1000 * 60 * 60 * 24));

            let statusTextHtml = '';
            if (diffDays < 0) statusTextHtml = `<span class="text-[10px] font-bold text-red-500 animate-pulse pl-4">Trễ ${Math.abs(diffDays)} ngày</span>`;
            else if (diffDays === 0) statusTextHtml = `<span class="text-[10px] font-bold text-amber-500 pl-4">Hôm nay</span>`;
            else statusTextHtml = `<span class="text-[10px] font-bold text-blue-500 pl-4">Còn ${diffDays} ngày</span>`;

            return { dateStr, statusTextHtml };
        }

        function getTaskDetailStateBadgeClass(stateCode) {
            const normalizedStateCode = getStateConfig(stateCode)?.stateCode || getDefaultStateCode().stateCode;
            if (normalizedStateCode === 'IN_PROGRESS') return 'bg-blue-50 text-blue-700 border border-blue-200';
            if (normalizedStateCode === 'IN_REVIEW') return 'bg-violet-50 text-violet-700 border border-violet-200';
            if (normalizedStateCode === 'PENDING') return 'bg-amber-50 text-amber-700 border border-amber-200';
            if (normalizedStateCode === 'DONE') return 'bg-emerald-50 text-emerald-700 border border-emerald-200';
            if (normalizedStateCode === 'CANCEL') return 'bg-rose-50 text-rose-700 border border-rose-200';
            return 'bg-slate-100 text-slate-700 border border-slate-200';
        }

