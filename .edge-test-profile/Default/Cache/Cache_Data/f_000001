        function reorderTaskChecklist(ticketId, orderedIds) {
            updateTaskChecklist(ticketId, (checklist) => {
                const itemMap = new Map(checklist.map((item) => [item.id, item]));
                if (!taskDetailChecklistFilterKey && taskDetailChecklistStatusFilter === 'all') {
                    return orderedIds.map((id) => itemMap.get(id)).filter(Boolean);
                }

                const visibleIds = checklist
                    .filter((item) => matchesTaskChecklistActiveFilters(item))
                    .map((item) => item.id);
                const visibleSet = new Set(visibleIds);
                const reorderedVisibleItems = orderedIds.map((id) => itemMap.get(id)).filter(Boolean);
                let visibleIndex = 0;

                return checklist.map((item) => {
                    if (!visibleSet.has(item.id)) return item;
                    const nextVisibleItem = reorderedVisibleItems[visibleIndex];
                    visibleIndex += 1;
                    return nextVisibleItem || item;
                });
            });
        }

