        function shouldShowTrackingSkeleton(viewMode) {
            const visibleTickets = getVisibleBoardTicketEntries();
            if (viewMode === 'list') {
                const body = document.getElementById('taskListBody');
                const hasFilteredRows = getFilteredTaskListEntries(visibleTickets).length > 0;
                return hasFilteredRows && (!body || !body.children.length);
            }
            return visibleTickets.length > 0 && !document.querySelector('.kanban-list .task-card');
        }

        function clearBoardSkeleton() {
            document.querySelectorAll('.tracking-skeleton-card').forEach((card) => card.remove());
