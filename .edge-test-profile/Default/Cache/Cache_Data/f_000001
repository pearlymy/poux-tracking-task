                const targetStateCode = evt.to?.closest('.kanban-column')?.dataset.stateCode;
                const boardUserKey = getBoardTrackingUserKey();
                suppressTaskCardClickUntil = Date.now() + 250;

                try {
                    if (ticketId && targetStateCode && boardUserKey) {
                        updateBoardTicket(ticketId, (ticketState) => {
                            const targetUserKey = isAllTrackingUsersKey(boardUserKey)
                                ? (normalizeUserKey(card?.dataset.boardAssigneeUserKey) || getTicketTeamAssignee(ticketState)?.user_key)
                                : boardUserKey;
                            return targetUserKey
                                ? setTicketWorkflowState(ticketState, targetUserKey, targetStateCode)
                                : ticketState;
                        });
                    }

                    syncBoardTicketOrderFromRenderedCards();
                    renderBoardTickets();
                    saveBoardState();
