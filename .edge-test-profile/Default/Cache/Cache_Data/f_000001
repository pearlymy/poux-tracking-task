        function updateKanbanScrollNavState() {
            const scrollArea = document.getElementById('kanbanScrollArea');
            const leftBtn = document.getElementById('kanbanScrollLeft');
            const rightBtn = document.getElementById('kanbanScrollRight');
            if (!scrollArea || !leftBtn || !rightBtn) return;

            const maxScrollLeft = Math.max(0, scrollArea.scrollWidth - scrollArea.clientWidth);
            const canScroll = maxScrollLeft > 12;
            const isAtStart = scrollArea.scrollLeft <= 8;
            const isAtEnd = scrollArea.scrollLeft >= maxScrollLeft - 8;

            leftBtn.disabled = !canScroll || isAtStart;
            rightBtn.disabled = !canScroll || isAtEnd;
            leftBtn.classList.toggle('is-disabled', leftBtn.disabled);
            rightBtn.classList.toggle('is-disabled', rightBtn.disabled);
        }

        function scrollKanbanBoard(direction) {
            const scrollArea = document.getElementById('kanbanScrollArea');
            if (!scrollArea) return;

            const step = Math.max(280, Math.floor(scrollArea.clientWidth * 0.72));
            scrollArea.scrollBy({ left: direction * step, behavior: 'smooth' });
        }

        function initializeKanbanScrollNav() {
            const scrollArea = document.getElementById('kanbanScrollArea');
            const leftBtn = document.getElementById('kanbanScrollLeft');
            const rightBtn = document.getElementById('kanbanScrollRight');
            if (!scrollArea || !leftBtn || !rightBtn) return;

            if (!scrollArea.dataset.navInitialized) {
                scrollArea.addEventListener('scroll', updateKanbanScrollNavState, { passive: true });
                leftBtn.addEventListener('click', () => scrollKanbanBoard(-1));
                rightBtn.addEventListener('click', () => scrollKanbanBoard(1));
                window.addEventListener('resize', updateKanbanScrollNavState);
                scrollArea.dataset.navInitialized = 'true';
            }

            requestAnimationFrame(updateKanbanScrollNavState);
        }

