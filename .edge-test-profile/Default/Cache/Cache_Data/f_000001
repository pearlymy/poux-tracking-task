            currentRoleDraft = null;
            currentRoleDetailMode = 'view';
            currentRoleSelectionId = roleId;
            renderAdminRolesPanel();
        }

        function setRoleDetailMode(mode) {
            currentRoleDetailMode = mode === 'edit' ? 'edit' : 'view';
            if (currentRoleDetailMode === 'edit') {
                const role = getSeedRoleById(currentRoleSelectionId);
                if (role) currentRoleDraft = buildRoleDraft(role);
            } else {
                currentRoleDraft = null;
                isRoleScopeLovOpen = false;
            }
            renderAdminRolesPanel();
        }

        function updateRoleField(roleId, field, value) {
            const role = currentRoleDetailMode === 'edit' ? currentRoleDraft : getSeedRoleById(roleId);
            if (!role) return;
            const nextValue = String(value ?? '').trim();
            if (!nextValue) {
                showAdminToast('Thông tin role không được để trống.');
                renderAdminRolesPanel();
                return;
            }
            if (field === 'code') {
                const normalizedCode = nextValue.toUpperCase().replace(/\s+/g, '_');
                const duplicatedRole = ADMIN_SEED.roles.find((item) => item.id !== roleId && item.code === normalizedCode);
                if (duplicatedRole) {
                    showAdminToast(`Code ${normalizedCode} đã tồn tại.`);
                    renderAdminRolesPanel();
                    return;
                }
                role.code = normalizedCode;
            } else {
                role[field] = nextValue;
            }
            if (currentRoleDetailMode === 'edit') {
                currentRoleDraft = { ...role };
                return;
            }
            addAuditLog('Permission', 'UPDATE_ROLE', `Cập nhật ${field} cho ${role.code}`);
            renderAdminRolesPanel();
        }

        function updateRoleScope(roleId, scopeType) {
            const role = currentRoleDetailMode === 'edit' ? currentRoleDraft : getSeedRoleById(roleId);
            if (!role) return;
            role.scope_type = scopeType === 'GLOBAL' ? 'GLOBAL' : 'TEAM';
            isRoleScopeLovOpen = false;
            if (role.scope_type === 'GLOBAL') {
                currentRoleDraft = { ...role };
            }
            if (currentRoleDetailMode === 'edit') {
                renderAdminRolesPanel();
                return;
            }
            ADMIN_SEED.userRoleAssignments.forEach((assignment) => {
                if (assignment.role_id === role.id) assignment.team_id = null;
            });
            addAuditLog('Permission', 'UPDATE_ROLE_SCOPE', `Đổi phạm vi role ${role.code} sang ${role.scope_type}`);
            renderAdminRolesPanel();
        }

        function toggleRoleStatus(roleId, event) {
            const role = currentRoleDetailMode === 'edit' ? currentRoleDraft : getSeedRoleById(roleId);
            if (!role) return;
            role.is_active = !role.is_active;
            const button = event?.currentTarget;
            if (button) {
                button.classList.toggle('is-on', role.is_active);
                button.classList.toggle('is-off', !role.is_active);
            }
            if (currentRoleDetailMode === 'edit') {
                currentRoleDraft = { ...role };
                window.setTimeout(() => {
                    renderAdminRolesPanel();
                }, 180);
                return;
            }
            addAuditLog('Permission', 'TOGGLE_ROLE', `${role.is_active ? 'Kích hoạt' : 'Ngưng'} role ${role.code}`);
            showAdminToast(`${role.is_active ? 'Đã kích hoạt' : 'Đã ngưng'} role ${role.code}.`);
            window.setTimeout(() => {
                renderAdminRolesPanel();
            }, 180);
        }

        function toggleRolePermission(roleId, permissionId, event) {
            const role = currentRoleDetailMode === 'edit' ? currentRoleDraft : getSeedRoleById(roleId);
            const permission = getSeedPermissionById(permissionId);
            if (!role || !permission) return;
            const button = event?.currentTarget;
            if (currentRoleDetailMode === 'edit' && currentRoleDraft) {
                const nextPermissionIds = new Set(currentRoleDraft.permission_ids || []);
                if (nextPermissionIds.has(permissionId)) {
                    nextPermissionIds.delete(permissionId);
                } else {
                    nextPermissionIds.add(permissionId);
                }
                currentRoleDraft = {
                    ...currentRoleDraft,
                    permission_ids: Array.from(nextPermissionIds)
                };
                if (button) {
                    button.classList.toggle('is-on', nextPermissionIds.has(permissionId));
                    button.classList.toggle('is-off', !nextPermissionIds.has(permissionId));
                }
                window.setTimeout(() => {
                    renderAdminRolesPanel();
                }, 180);
                return;
            }
            const itemIndex = ADMIN_SEED.rolePermissions.findIndex((item) => item.role_id === roleId && item.permission_id === permissionId);
            if (itemIndex >= 0) {
                ADMIN_SEED.rolePermissions.splice(itemIndex, 1);
                if (button) {
                    button.classList.remove('is-on');
                    button.classList.add('is-off');
                }
                showAdminToast(`Đã tắt quyền ${permission.code} cho ${role.code}.`);
            } else {
                ADMIN_SEED.rolePermissions.push({ role_id: roleId, permission_id: permissionId });
                if (button) {
                    button.classList.remove('is-off');
                    button.classList.add('is-on');
                }
                showAdminToast(`Đã bật quyền ${permission.code} cho ${role.code}.`);
            }
            addAuditLog('Permission', 'UPDATE_ROLE', `Cập nhật permission ${permission.code} cho ${role.code}`);
            window.setTimeout(() => {
                renderAdminRolesPanel();
            }, 180);
        }

