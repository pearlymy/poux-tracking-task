                                            <span class="document-delete-confirm-icon" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M6 18L18 6M6 6l12 12" />
                                                </svg>
                                            </span>
                                        </button>
                                    </div>
                                ` : ''}
                            </div>` : ''}
                        </div>
                        ${state.permissionEditingId === page.id ? renderBranchPermissionPanel(branchKey, page) : ''}
                    `;
                }

                visiblePageIndex += 1;
                const activeClass = state.activeId === page.id ? 'member-link is-active' : 'member-link';
                const deleteButtonClass = state.deleteConfirmId === page.id
                    ? `menu-action-btn delete document-delete-toggle is-confirming ${branchKey}-delete-toggle`
                    : `menu-action-btn delete document-delete-toggle ${branchKey}-delete-toggle`;
                const canManage = canManageBranchPage(page);
                const isActionMenuOpen = state.actionMenuId === page.id;
                const rowClass = ['document-page-row', isActionMenuOpen ? 'is-action-menu-open' : '', state.removingId === page.id ? 'is-removing' : '', state.animatingId === page.id ? 'is-entering' : ''].filter(Boolean).join(' ');

                return `
                    <div class="${rowClass}" ${config.rowAttr}="${page.id}" data-branch-item-id="${page.id}" data-branch-item-type="page">
                        <a href="#" class="${activeClass}" data-member-group="${config.memberGroup}" data-page-id="${page.id}">
                            <span class="member-index">${visiblePageIndex}</span>
                            <span class="member-name">${escapeHtml(page.name)}</span>
                            <span class="document-visibility-badge">${getBranchVisibilityLabel(page)}</span>
                        </a>
                        ${canManage ? `
                            <div class="document-page-actions">
                                <button type="button" class="menu-action-btn document-action-menu-btn ${isActionMenuOpen ? 'is-active' : ''} ${branchKey}-action-menu-btn" data-page-id="${page.id}" aria-label="Mở thao tác page">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                                        <circle cx="12" cy="5" r="1.7"></circle><circle cx="12" cy="12" r="1.7"></circle><circle cx="12" cy="19" r="1.7"></circle>
                                    </svg>
                                </button>
                                ${isActionMenuOpen ? `
                                    <div class="document-action-popover">
                                        <button type="button" class="menu-action-btn ${branchKey}-edit-btn" data-page-id="${page.id}" aria-label="Sửa tên page">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                            </svg>
                                        </button>
                                        <button type="button" class="menu-action-btn document-privacy-toggle ${state.permissionEditingId === page.id ? 'is-active' : ''} ${branchKey}-permission-btn" data-page-id="${page.id}" aria-label="Chỉnh quyền page">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c1.657 0 3-1.567 3-3.5S13.657 4 12 4 9 5.567 9 7.5s1.343 3.5 3 3.5zM5 20a7 7 0 0114 0" />
                                            </svg>
                                        </button>
                                        <button type="button" class="${deleteButtonClass}" data-page-id="${page.id}" aria-label="Xóa page">
                                            <span class="document-delete-icon" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3M4 7h16" />
                                                </svg>
                                            </span>
                                            <span class="document-delete-confirm-icon" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M6 18L18 6M6 6l12 12" />
                                                </svg>
                                            </span>
                                        </button>
                                    </div>
                                ` : ''}
                            </div>
                        ` : ''}
                    </div>
                    ${state.permissionEditingId === page.id ? renderBranchPermissionPanel(branchKey, page) : ''}
                `;
            }).join('');

            document.querySelectorAll(`.${branchKey}-edit-btn`).forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    state.actionMenuId = null;
                    startEditBranchPage(branchKey, button.dataset.pageId);
                });
            });

            document.querySelectorAll(`.${branchKey}-action-menu-btn`).forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    state.deleteConfirmId = null;
                    state.actionMenuId = state.actionMenuId === button.dataset.pageId ? null : button.dataset.pageId;
                    renderBranchPages(branchKey);
                });
            });

            document.querySelectorAll(`.${branchKey}-delete-toggle`).forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    const pageId = button.dataset.pageId;
                    if (state.deleteConfirmId === pageId) {
                        state.actionMenuId = null;
                        deleteBranchPage(branchKey, pageId);
                        return;
                    }
                    state.deleteConfirmId = pageId;
                    renderBranchPages(branchKey);
                });
            });

            document.querySelectorAll(`.${branchKey}-permission-btn`).forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    const page = getRawBranchItem(branchKey, button.dataset.pageId);
                    if (!canManageBranchItem(page)) return;
                    state.deleteConfirmId = null;
                    state.actionMenuId = null;
                    state.permissionEditingId = state.permissionEditingId === page.id ? null : page.id;
                    renderBranchPages(branchKey);
                });
            });

            document.querySelectorAll(`.${branchKey}-permission-close-btn`).forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    state.permissionEditingId = null;
                    renderBranchPages(branchKey);
                });
            });

            document.querySelectorAll('[data-permission-visibility]').forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    updateBranchPageVisibility(branchKey, button.dataset.pageId, button.dataset.permissionVisibility);
                });
            });

            document.querySelectorAll('[data-permission-share-user]').forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    toggleBranchPageSharedUser(branchKey, button.dataset.pageId, button.dataset.permissionShareUser);
                });
            });

            document.querySelectorAll(`.${branchKey}-edit-save-btn`).forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    saveEditedBranchPage(branchKey, button.dataset.pageId);
                });
            });

            document.querySelectorAll(`.${branchKey}-edit-cancel-btn`).forEach((button) => {
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    cancelEditBranchPage(branchKey);
                });
            });

            document.querySelectorAll(`.${branchKey}-edit-input`).forEach((input) => {
                input.addEventListener('input', () => clearBranchInvalidState(branchKey, 'edit'));
                input.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        saveEditedBranchPage(branchKey, input.dataset.pageId);
                    }
                    if (event.key === 'Escape') {
                        event.preventDefault();
                        cancelEditBranchPage(branchKey);
                    }
                });
                setTimeout(() => {
                    input.focus();
                    input.select();
                }, 0);
            });

            initializeBranchSortable(branchKey);
            initializeSelectableMembers();
            syncBranchMenuHeight(branchKey);
        }

        function openBranchCreateForm(branchKey) {
            const config = getBranchConfig(branchKey);
            const state = getBranchState(branchKey);
            const createForm = document.getElementById(config.createFormId);
            const createInput = document.getElementById(config.createInputId);
            state.editingId = null;
            state.permissionEditingId = null;
            state.deleteConfirmId = null;
            state.createVisibility = 'team';
            state.createSharedUserIds = [];
            createForm.classList.remove('hidden');
            createInput.value = '';
            clearBranchInvalidState(branchKey, 'create');
            renderBranchCreatePrivacyControls(branchKey);
            if (!accordionState[config.menuId]) toggleAccordion(config.menuId, config.chevronId);
            syncBranchMenuHeight(branchKey);
            setTimeout(() => createInput.focus(), 0);
        }

        function closeBranchCreateForm(branchKey) {
            const config = getBranchConfig(branchKey);
            document.getElementById(config.createFormId).classList.add('hidden');
            document.getElementById(config.createInputId).value = '';
            getBranchState(branchKey).createVisibility = 'team';
            getBranchState(branchKey).createSharedUserIds = [];
            renderBranchCreatePrivacyControls(branchKey);
            clearBranchInvalidState(branchKey, 'create');
            syncBranchMenuHeight(branchKey);
        }

        function renderBranchCreatePrivacyControls(branchKey) {
            const state = getBranchState(branchKey);
            const visibilityInput = document.getElementById('documentCreateVisibility');
            const controls = document.getElementById('documentCreatePrivacyControls');
            const shareList = document.getElementById('documentCreateShareList');
            if (!visibilityInput || !controls || !shareList) return;
            const visibility = normalizeBranchVisibility(state.createVisibility);
            state.createVisibility = visibility;
            visibilityInput.value = visibility;
            controls.innerHTML = ['team', 'personal', 'shared'].map((mode) => {
                const label = mode === 'personal' ? 'Cá nhân' : (mode === 'shared' ? 'Share' : 'Team');
                return `<button type="button" class="document-privacy-chip ${visibility === mode ? 'is-active' : ''}" data-create-visibility="${mode}">${label}</button>`;
            }).join('');
            shareList.classList.toggle('is-hidden', visibility !== 'shared');
            shareList.innerHTML = `
                <div class="document-share-title">Người được share</div>
                <div class="document-share-body">
                    ${getUsersByTeamCode(selectedTeamCode || getCurrentTeamCode()).map((userKey) => {
                        const user = USERS[userKey];
                        const isActive = state.createSharedUserIds.includes(userKey);
                        const isOwner = userKey === CURRENT_USER_ID;
                        return `<button type="button" class="document-share-chip ${isActive ? 'is-active' : ''}" data-create-share-user="${userKey}" ${isOwner ? 'disabled' : ''}>${escapeHtml(user.full_name)}</button>`;
                    }).join('')}
                </div>
            `;
            syncBranchMenuHeight(branchKey);
        }

        function setBranchCreateVisibility(branchKey, visibility) {
            const state = getBranchState(branchKey);
            state.createVisibility = normalizeBranchVisibility(visibility);
            renderBranchCreatePrivacyControls(branchKey);
        }

        function toggleBranchCreateSharedUser(branchKey, userKey) {
            const state = getBranchState(branchKey);
            const normalizedUserKey = normalizeUserKey(userKey);
            if (!normalizedUserKey || normalizedUserKey === CURRENT_USER_ID) return;
            state.createSharedUserIds = state.createSharedUserIds.includes(normalizedUserKey)
                ? state.createSharedUserIds.filter((key) => key !== normalizedUserKey)
                : [...state.createSharedUserIds, normalizedUserKey];
            renderBranchCreatePrivacyControls(branchKey);
        }

        function updateBranchPageVisibility(branchKey, pageId, visibility) {
            const state = getBranchState(branchKey);
            const page = getRawBranchItem(branchKey, pageId);
            if (!canManageBranchItem(page)) return;
            page.visibility = normalizeBranchVisibility(visibility);
            if (page.visibility !== 'shared') page.sharedUserIds = [];
            state.permissionEditingId = page.id;
            saveBranchPages(branchKey);
            renderBranchPages(branchKey);
            if (branchKey === 'document' && currentWorkspaceView === 'document' && state.activeId === page.id && !canViewBranchPage(page)) {
                showDocumentWorkspace(getFirstBranchPage(branchKey)?.id || null);
            }
        }

        function toggleBranchPageSharedUser(branchKey, pageId, userKey) {
            const page = getRawBranchItem(branchKey, pageId);
            if (!canManageBranchItem(page)) return;
            const normalizedUserKey = normalizeUserKey(userKey);
            if (!normalizedUserKey || normalizedUserKey === page.ownerUserId) return;
            page.visibility = 'shared';
            page.sharedUserIds = page.sharedUserIds.includes(normalizedUserKey)
                ? page.sharedUserIds.filter((key) => key !== normalizedUserKey)
                : [...page.sharedUserIds, normalizedUserKey];
            page.sharedUserIds = normalizeBranchSharedUsers(page.sharedUserIds).filter((key) => key !== page.ownerUserId);
            saveBranchPages(branchKey);
            renderBranchPages(branchKey);
        }

        function createBranchPage(branchKey) {
            const config = getBranchConfig(branchKey);
            const state = getBranchState(branchKey);
            const createInput = document.getElementById(config.createInputId);
            const trimmedName = createInput.value.trim();
            if (!trimmedName) {
                showBranchInvalidInputState(branchKey, 'create', createInput);
                return;
            }
            const dividerMatch = trimmedName.match(/^(.*?)\s*---$/);
            if (dividerMatch) {
                const newDivider = {
                    type: 'divider',
                    id: `${config.pageIdPrefix}-divider-${Date.now()}-${Math.random().toString(16).slice(2)}`,
                    label: dividerMatch[1].trim(),
                    visibility: normalizeBranchVisibility(state.createVisibility),
                    ownerUserId: CURRENT_USER_ID,
                    sharedUserIds: normalizeBranchSharedUsers(state.createSharedUserIds).filter((userKey) => userKey !== CURRENT_USER_ID)
                };
                state.pages.push(newDivider);
                state.animatingId = newDivider.id;
                saveBranchPages(branchKey);
                closeBranchCreateForm(branchKey);
                renderBranchPages(branchKey);
                setTimeout(() => { state.animatingId = null; }, 320);
                return;
            }
            const newPage = {
                type: 'page',
                id: `${config.pageIdPrefix}-${Date.now()}`,
                name: trimmedName,
                visibility: normalizeBranchVisibility(state.createVisibility),
                ownerUserId: CURRENT_USER_ID,
                sharedUserIds: normalizeBranchSharedUsers(state.createSharedUserIds).filter((userKey) => userKey !== CURRENT_USER_ID)
            };
            state.pages.push(newPage);
            state.activeId = newPage.id;
            state.animatingId = newPage.id;
            saveBranchPages(branchKey);
            closeBranchCreateForm(branchKey);
            renderBranchPages(branchKey);
            if (branchKey === 'document') showDocumentWorkspace(newPage.id);
            setTimeout(() => { state.animatingId = null; }, 320);
        }

        function startEditBranchPage(branchKey, pageId) {
            const state = getBranchState(branchKey);
            const page = getRawBranchPage(branchKey, pageId);
            if (!canManageBranchPage(page)) return;
            closeBranchCreateForm(branchKey);
            state.deleteConfirmId = null;
            state.permissionEditingId = null;
            state.actionMenuId = null;
            animateBranchRowExit(branchKey, pageId, 'is-edit-transitioning', () => {
                state.editingId = pageId;
                renderBranchPages(branchKey);
            });
        }

        function cancelEditBranchPage(branchKey) {
            const state = getBranchState(branchKey);
            const pageId = state.editingId;
            state.editingId = null;
            state.animatingId = pageId;
            renderBranchPages(branchKey);
            setTimeout(() => { state.animatingId = null; }, 320);
        }

        function saveEditedBranchPage(branchKey, pageId) {
            const state = getBranchState(branchKey);
            const page = getRawBranchPage(branchKey, pageId);
            const editInput = document.querySelector(`.${branchKey}-edit-input[data-page-id="${pageId}"]`);
            if (!canManageBranchPage(page) || !editInput) return;
            const trimmedName = editInput.value.trim();
            if (!trimmedName) {
                showBranchInvalidInputState(branchKey, 'edit', editInput);
                return;
            }
            page.name = trimmedName;
            state.editingId = null;
            state.animatingId = pageId;
            saveBranchPages(branchKey);
            renderBranchPages(branchKey);
            if (branchKey === 'document' && currentWorkspaceView === 'document' && state.activeId === pageId) {
                showDocumentWorkspace(pageId);
            }
            setTimeout(() => { state.animatingId = null; }, 320);
        }

        function deleteBranchPage(branchKey, pageId) {
            const state = getBranchState(branchKey);
            const deletedItem = state.pages.find((item) => item.id === pageId);
            if (!canManageBranchItem(deletedItem)) return;
            state.deleteConfirmId = null;
            state.actionMenuId = null;
            state.removingId = pageId;
            animateBranchRowExit(branchKey, pageId, 'is-removing', () => {
                state.pages = state.pages.filter((item) => item.id !== pageId);
                if (state.activeId === pageId) state.activeId = getFirstBranchPage(branchKey)?.id || null;
                if (state.editingId === pageId) state.editingId = null;
                state.removingId = null;
                saveBranchPages(branchKey);
                renderBranchPages(branchKey);
                if (branchKey === 'document' && currentWorkspaceView === 'document' && isBranchPage(deletedItem)) showDocumentWorkspace(state.activeId);
            }, 300);
        }

        function renderTrackingList(teamKey) {
            const trackingList = document.getElementById('trackingList');
            const members = getSortedTrackingUsers(getUsersByTeamCode(teamKey));

            if (!members.length) {
                activeTrackingUserKey = null;
                trackingList.innerHTML = '<li class="pl-4 py-2 text-xs text-slate-400">Không có user trong team</li>';
                syncActiveNavState();
                return;
            }

            activeTrackingUserKey = getPreferredTrackingUserKey(members);

            const allTrackingHref = getTrackingRouteHref(ALL_TRACKING_USERS_KEY, teamKey);
            const allTrackingHtml = `
                <li class="app-appear-item" style="--appear-index:0">
                    <a href="${escapeHtml(allTrackingHref)}" class="${isAllTrackingUsersKey(activeTrackingUserKey) ? 'member-link is-active' : 'member-link'}" data-member-group="tracking" data-tracking-current="false" data-user-key="${ALL_TRACKING_USERS_KEY}">
                        <span class="member-index" style="width:1.75rem">All</span>
                        <span class="member-name">Tất cả</span>
                        <span class="member-count">${getTaskCountForTeam(teamKey)}</span>
                    </a>
                </li>
            `;

            trackingList.innerHTML = allTrackingHtml + members.map((userKey, index) => {
                const user = USERS[userKey];
                const isLoggedInUser = userKey === CURRENT_USER_ID;
                const isSelected = userKey === activeTrackingUserKey;
                const currentIndexClass = isLoggedInUser ? 'member-index member-index-current' : 'member-index';
                const activeClass = isSelected ? 'member-link is-active' : 'member-link';
                const previousUser = index > 0 ? USERS[members[index - 1]] : null;
                const shouldRenderDivider = !previousUser || previousUser.job_title_id !== user.job_title_id;
                const trackingHref = getTrackingRouteHref(userKey, teamKey);
                return `
                    ${shouldRenderDivider ? `<li class="member-group-divider">${getJobTitleName(user.job_title_id)}</li>` : ''}
                    <li class="app-appear-item" style="--appear-index:${index + 1}">
                        <a href="${escapeHtml(trackingHref)}" class="${activeClass}" data-member-group="tracking" data-tracking-current="${isLoggedInUser ? 'true' : 'false'}" data-user-key="${userKey}">
                            <span class="${currentIndexClass}">${index + 1}</span>
                            <span class="member-name">${user.full_name}</span>
                            <span class="member-count">${getTaskCountForUser(userKey)}</span>
                        </a>
                    </li>
                `;
            }).join('');
            if (accordionState.trackingMenu && !isSidebarCollapsed) {
                const trackingMenu = document.getElementById('trackingMenu');
                trackingMenu.style.maxHeight = trackingMenu.scrollHeight + 'px';
            }
            initializeSelectableMembers();
        }

        function setTeamDropdownOpen(isOpen) {
            document.getElementById('teamSelectorButton').classList.toggle('is-open', isOpen);
            document.getElementById('teamSelectorMenu').classList.toggle('is-open', isOpen);
        }

        function applySelectedTeam(teamKey, options = {}) {
            const { updateUrl = true, replaceUrl = false, staticTaskListValues = false } = options;
            selectedTeamCode = teamKey;
            document.getElementById('teamSelectorValue').textContent = teamKey || 'Không có phòng ban';
            document.querySelectorAll('.team-option').forEach((option) => {
                option.classList.toggle('is-active', option.dataset.teamValue === teamKey);
            });
            if (teamKey) {
                localStorage.setItem(TEAM_STORAGE_KEY, teamKey);
            } else {
                localStorage.removeItem(TEAM_STORAGE_KEY);
            }
            renderInlinePicSelection();
            renderTrackingList(teamKey);
            if (getBranchState('document')) {
                renderBranchCreatePrivacyControls('document');
                renderBranchPages('document');
            }
            initializeCurrentUserProfile();
            applyBoardFilter({ staticTaskListValues });
            if (updateUrl && currentWorkspaceView === 'board') {
                updateTrackingUrl({ ticketId: null, replace: replaceUrl });
            }
        }

        function initializeTeamSelector() {
            const teamSelectorButton = document.getElementById('teamSelectorButton');
            const teamSelectorMenu = document.getElementById('teamSelectorMenu');
            const availableTeams = getAvailableTeamCodesForUser(CURRENT_USER_ID);
            const savedTeam = localStorage.getItem(TEAM_STORAGE_KEY);
            const initialTrackingRoute = getTrackingRouteFromUrl();
            const routeTeam = isTrackingRoute(initialTrackingRoute) ? resolveTrackingRoute(initialTrackingRoute).team : null;
            const defaultTeam = availableTeams.includes(routeTeam) ? routeTeam : (availableTeams.includes(savedTeam) ? savedTeam : (availableTeams[0] || null));
            if (isTrackingRoute(initialTrackingRoute) && isAllTrackingUsersKey(initialTrackingRoute.user)) {
                activeTrackingUserKey = ALL_TRACKING_USERS_KEY;
            } else if (isTrackingRoute(initialTrackingRoute) && initialTrackingRoute.user && getUsersByTeamCode(defaultTeam).includes(initialTrackingRoute.user)) {
                activeTrackingUserKey = initialTrackingRoute.user;
            }

            teamSelectorMenu.innerHTML = availableTeams.map((teamCode) => `
                <button type="button" class="team-option" data-team-value="${teamCode}">
                    <span class="team-option-label">${teamCode}</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="team-option-check" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M5 13l4 4L19 7" />
                    </svg>
                </button>
            `).join('');

            const teamOptions = teamSelectorMenu.querySelectorAll('.team-option');
            if (!defaultTeam) {
                teamSelectorButton.style.display = 'none';
                applySelectedTeam(null, { updateUrl: false });
                return;
            }
            teamSelectorButton.style.display = '';
            applySelectedTeam(defaultTeam, { updateUrl: false });

            teamSelectorButton.addEventListener('click', () => {
                setTeamDropdownOpen(!document.getElementById('teamSelectorMenu').classList.contains('is-open'));
            });

            teamOptions.forEach((option) => {
                option.addEventListener('click', () => {
                    applySelectedTeam(option.dataset.teamValue);
                    setTeamDropdownOpen(false);
                });
            });

            document.addEventListener('click', (event) => {
                if (!event.target.closest('.profile-context')) setTeamDropdownOpen(false);
                if (!event.target.closest('.document-page-actions')) {
                    Object.keys(branchConfigs).forEach((branchKey) => {
                        const state = getBranchState(branchKey);
                        if (state.deleteConfirmId !== null || state.actionMenuId !== null) {
                            state.deleteConfirmId = null;
                            state.actionMenuId = null;
                            renderBranchPages(branchKey);
                        }
                    });
                }
            });
        }

        function initializeBranchManager(branchKey) {
            const config = getBranchConfig(branchKey);
            loadBranchPages(branchKey);
            renderBranchPages(branchKey);
            document.getElementById(config.addBtnId).addEventListener('click', (event) => {
                event.preventDefault();
                event.stopPropagation();
                openBranchCreateForm(branchKey);
            });
            document.getElementById(config.createSaveBtnId).addEventListener('click', (event) => {
                event.preventDefault();
                event.stopPropagation();
                createBranchPage(branchKey);
            });
            document.getElementById(config.createCancelBtnId).addEventListener('click', (event) => {
                event.preventDefault();
                event.stopPropagation();
                closeBranchCreateForm(branchKey);
            });
            document.getElementById('documentCreatePrivacyControls')?.addEventListener('click', (event) => {
