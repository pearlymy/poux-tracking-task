        function normalizeTaskCommentItem(item, fallbackIndex = 0) {
            if (!item) return null;
            const createdBy = normalizeUserKey(item.created_by || item.createdBy || CURRENT_USER_ID);
            return {
                id: item.id || `tcm_${Date.now()}_${fallbackIndex}`,
                created_by: createdBy && USERS[createdBy] ? createdBy : CURRENT_USER_ID,
                created_at: item.created_at || item.createdAt || new Date().toISOString(),
                content_html: sanitizeTaskCommentHtml(item.content_html || item.contentHtml || item.content || ''),
                reply_to_id: item.reply_to_id || item.replyToId || '',
                reactions: normalizeTaskCommentReactions(item.reactions || {})
            };
        }

        function normalizeTaskCommentReactions(reactions) {
            const normalized = {};
            TASK_COMMENT_REACTION_OPTIONS.forEach(({ key }) => {
                normalized[key] = Array.from(new Set(
                    (Array.isArray(reactions?.[key]) ? reactions[key] : [])
                        .map((userKey) => normalizeUserKey(userKey))
                        .filter((userKey) => userKey && USERS[userKey])
                ));
            });
            return normalized;
        }

        function sanitizeTaskCommentNode(node) {
            if (!node) return null;
            if (node.nodeType === Node.TEXT_NODE) {
                return document.createTextNode(node.textContent || '');
            }
            if (node.nodeType !== Node.ELEMENT_NODE) {
                return null;
            }

            const tagName = node.tagName.toLowerCase();
            const allowedTags = new Set(['b', 'strong', 'i', 'em', 'u', 'br', 'p', 'div', 'ul', 'ol', 'li', 'a', 'span']);
            if (!allowedTags.has(tagName)) {
                const fragment = document.createDocumentFragment();
                Array.from(node.childNodes).forEach((childNode) => {
                    const sanitizedChild = sanitizeTaskCommentNode(childNode);
                    if (sanitizedChild) fragment.appendChild(sanitizedChild);
                });
                return fragment;
            }

            const cleanNode = document.createElement(tagName);
            if (tagName === 'a') {
                const href = String(node.getAttribute('href') || '').trim();
                if (/^https?:\/\//i.test(href)) {
                    cleanNode.setAttribute('href', href);
                    cleanNode.setAttribute('target', '_blank');
                    cleanNode.setAttribute('rel', 'noopener noreferrer');
                }
            }
            if (tagName === 'span') {
                const userKey = normalizeUserKey(node.getAttribute('data-user-key') || '');
                if (userKey && USERS[userKey] && node.classList.contains('task-comment-mention')) {
                    cleanNode.className = 'task-comment-mention';
                    cleanNode.setAttribute('data-user-key', userKey);
                    cleanNode.textContent = `@${USERS[userKey].full_name || userKey}`;
                    return cleanNode;
                }
            }

            Array.from(node.childNodes).forEach((childNode) => {
                const sanitizedChild = sanitizeTaskCommentNode(childNode);
                if (sanitizedChild) cleanNode.appendChild(sanitizedChild);
            });
            return cleanNode;
        }

        function sanitizeTaskCommentHtml(value) {
            const template = document.createElement('template');
            template.innerHTML = String(value || '');
            const wrapper = document.createElement('div');
            Array.from(template.content.childNodes).forEach((childNode) => {
                const sanitizedNode = sanitizeTaskCommentNode(childNode);
                if (sanitizedNode) wrapper.appendChild(sanitizedNode);
            });
            return wrapper.innerHTML.trim();
        }

        function getTaskCommentPlainText(value) {
            const wrapper = document.createElement('div');
            wrapper.innerHTML = String(value || '');
            return (wrapper.textContent || '').replace(/\u00a0/g, ' ').replace(/\s+/g, ' ').trim();
        }

        function formatTaskCommentTimestamp(value) {
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '';
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            const today = new Date();
            const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate());
            const commentDateStart = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            const diffDays = Math.floor((todayStart - commentDateStart) / 86400000);
            const timeLabel = `${hours}:${minutes}`;
            const dateTimeLabel = `${day}/${month}/${year} ${timeLabel}`;
            if (diffDays <= 0) return `Hôm nay ${timeLabel}`;
            return `${diffDays} ngày trước · ${dateTimeLabel}`;
        }

        function getTaskCommentShortcutKeys() {
            return IS_MAC_OS ? ['Cmd', 'Enter'] : ['Ctrl', 'Enter'];
        }

        function getTaskCommentById(ticketState, commentId) {
            if (!ticketState || !commentId) return null;
            return (ticketState.comments || []).map((item, index) => normalizeTaskCommentItem(item, index)).find((item) => item?.id === commentId) || null;
        }

        function getTaskCommentPreviewText(comment) {
            if (!comment) return '';
            const plainText = getTaskCommentPlainText(comment.content_html || '');
            if (!plainText) return '';
