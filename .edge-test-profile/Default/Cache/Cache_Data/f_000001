        }

        .kanban-column[data-color-theme="indigo"] .kanban-dot { background: #8b5cf6; }
        .kanban-column[data-color-theme="indigo"] .kanban-column-title { color: #6d28d9; }
        .kanban-column[data-color-theme="indigo"] .kanban-count { color: #7c3aed; border: 1px solid #ddd6fe; }
        .kanban-column[data-color-theme="indigo"] .kanban-menu-btn { color: #a78bfa; }
        .kanban-column[data-color-theme="indigo"] .kanban-menu-btn:hover { background: #ede9fe; }
        .kanban-column[data-color-theme="indigo"] .task-card { border: 1px solid #c4b5fd !important; }
        .kanban-column[data-color-theme="indigo"] .task-card:hover {
