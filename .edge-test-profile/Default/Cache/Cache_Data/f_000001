            event?.stopPropagation?.();
            const nextFilter = ['all', 'incomplete', 'done'].includes(filterValue) ? filterValue : 'all';
            taskDetailChecklistStatusFilter = nextFilter;
            localStorage.setItem(TASK_CHECKLIST_STATUS_FILTER_STORAGE_KEY, nextFilter);
            renderTaskDetailsDrawer();
        }

        function toggleTaskChecklistCollapse(event) {
            event?.stopPropagation?.();
            isTaskChecklistCollapsed = !isTaskChecklistCollapsed;
            localStorage.setItem(TASK_CHECKLIST_COLLAPSED_STORAGE_KEY, isTaskChecklistCollapsed ? 'true' : 'false');
