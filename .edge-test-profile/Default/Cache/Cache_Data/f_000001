                .filter(Boolean)
                .filter((term, index, terms) => terms.indexOf(term) === index);

        const escapeRegExpFast = (value) => String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

        const highlightTextFast = (text, query) => {
            const source = String(text || "");
            const term = String(query || "").trim();
            if (!source || !term) return source;
            const parts = source.split(new RegExp("(" + escapeRegExpFast(term) + ")", "gi"));
            if (parts.length === 1) return source;
            return parts.map((part, index) =>
                part.toLowerCase() === term.toLowerCase()
                    ? h("mark", {
                        key: `match-${index}`,
                        className: "animate-flash-once bg-amber-200 text-amber-950 rounded-sm px-0.5 font-medium bg-opacity-70"
