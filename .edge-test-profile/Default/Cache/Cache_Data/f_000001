            isRoleScopeLovOpen = false;
            if (currentRoleDraft?.is_new) {
                currentRoleSelectionId = previousRoleSelectionId || ADMIN_SEED.roles[0]?.id || '';
            }
            currentRoleDraft = null;
            currentRoleDetailMode = 'view';
            renderAdminRolesPanel();
        }

        function saveRoleChanges() {
            if (!currentRoleDraft) return;
            const draft = {
                ...currentRoleDraft,
                code: String(currentRoleDraft.code || '').trim().toUpperCase().replace(/\s+/g, '_'),
                name: String(currentRoleDraft.name || '').trim(),
                permission_ids: Array.from(new Set(currentRoleDraft.permission_ids || []))
            };
            if (!draft.name || !draft.code) {
                showAdminToast('Tên role và mã role không được để trống.');
                return;
            }
            const duplicatedRole = ADMIN_SEED.roles.find((item) => item.id !== draft.id && item.code === draft.code);
            if (duplicatedRole) {
                showAdminToast(`Code ${draft.code} đã tồn tại.`);
                return;
            }

            const nextRole = {
                id: draft.id,
                code: draft.code,
                name: draft.name,
                scope_type: draft.scope_type,
                is_system: draft.is_system,
                is_active: draft.is_active
            };

            if (draft.is_new) {
                ADMIN_SEED.roles.push(nextRole);
                addAuditLog('Permission', 'CREATE_ROLE', `Tạo role ${draft.code}`);
                showAdminToast(`Đã tạo role ${draft.code}.`);
            } else {
                const role = getSeedRoleById(draft.id);
                if (!role) return;
                Object.assign(role, nextRole);
                addAuditLog('Permission', 'UPDATE_ROLE', `Lưu thay đổi cho ${draft.code}`);
                showAdminToast(`Đã lưu thay đổi cho ${draft.code}.`);
            }

            ADMIN_SEED.rolePermissions = ADMIN_SEED.rolePermissions.filter((item) => item.role_id !== draft.id);
            draft.permission_ids.forEach((permissionId) => {
                ADMIN_SEED.rolePermissions.push({ role_id: draft.id, permission_id: permissionId });
            });

            if (draft.scope_type === 'GLOBAL') {
                ADMIN_SEED.userRoleAssignments.forEach((assignment) => {
                    if (assignment.role_id === draft.id) assignment.team_id = null;
                });
            }

            currentRoleSelectionId = draft.id;
            currentRoleDraft = null;
            currentRoleDetailMode = 'view';
            isRoleScopeLovOpen = false;
            renderAdminRolesPanel();
        }

        function getAvailableUsersForRole(role) {
            return ADMIN_SEED.users
                .filter((user) => user.is_active && (role?.scope_type === 'GLOBAL' || getUserPrimaryTeam(user.id)))
                .sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
        }

        function createRoleAssignment(roleId) {
            const role = getSeedRoleById(roleId);
            if (!role) return;
            const availableUsers = getAvailableUsersForRole(role);
            if (!availableUsers.length) {
                showAdminToast('Không có user phù hợp để gán role.');
                return;
            }
            const candidate = availableUsers.find((user) => {
                const teamId = role.scope_type === 'TEAM' ? (getUserPrimaryTeam(user.id)?.id || null) : null;
                return !ADMIN_SEED.userRoleAssignments.some((item) => (
                    item.role_id === role.id &&
                    item.user_id === user.id &&
                    item.team_id === teamId &&
                    item.is_active
                ));
            });
            if (!candidate) {
                showAdminToast('Tất cả user phù hợp đã được gán role này rồi.');
                return;
            }
            const defaultUser = candidate;
            const defaultTeam = role.scope_type === 'TEAM' ? getUserPrimaryTeam(defaultUser.id) : null;
            ADMIN_SEED.userRoleAssignments.push({
                id: `ura_${String(ADMIN_SEED.userRoleAssignments.length + 1).padStart(3, '0')}`,
                user_id: defaultUser.id,
                role_id: role.id,
                team_id: defaultTeam?.id || null,
                is_active: true
            });
            addAuditLog('Permission', 'CREATE_ASSIGNMENT', `Gán role ${role.code} cho ${defaultUser.full_name}`);
            showAdminToast(`Đã thêm gán quyền cho ${defaultUser.full_name}.`);
            renderAdminRolesPanel();
        }

        function updateRoleAssignmentField(assignmentId, field, value) {
            const assignment = ADMIN_SEED.userRoleAssignments.find((item) => item.id === assignmentId);
            if (!assignment) return;
            const role = getSeedRoleById(assignment.role_id);
            if (!role) return;
            const previousValue = {
                user_id: assignment.user_id,
                team_id: assignment.team_id,
                is_active: assignment.is_active
            };
            if (field === 'user_id') {
                assignment.user_id = value;
                if (role.scope_type === 'TEAM') {
                    assignment.team_id = getUserPrimaryTeam(value)?.id || null;
                }
            } else if (field === 'team_id') {
                assignment.team_id = value || null;
            } else if (field === 'is_active') {
                assignment.is_active = Boolean(value);
            }
            const duplicated = ADMIN_SEED.userRoleAssignments.find((item) => (
                item.id !== assignment.id &&
                item.role_id === assignment.role_id &&
                item.user_id === assignment.user_id &&
                item.team_id === assignment.team_id &&
                item.is_active
            ));
            if (duplicated) {
                assignment.user_id = previousValue.user_id;
                assignment.team_id = previousValue.team_id;
                assignment.is_active = previousValue.is_active;
                showAdminToast('Role này đã được gán cho user ở phạm vi đã chọn.');
                renderAdminRolesPanel();
                return;
            }
            const user = getSeedUserById(assignment.user_id);
            addAuditLog('Permission', 'UPDATE_ASSIGNMENT', `Cập nhật gán role ${role.code} cho ${user?.full_name || assignment.user_id}`);
            renderAdminRolesPanel();
        }

        function removeRoleAssignment(assignmentId) {
            const assignmentIndex = ADMIN_SEED.userRoleAssignments.findIndex((item) => item.id === assignmentId);
            if (assignmentIndex < 0) return;
            const assignment = ADMIN_SEED.userRoleAssignments[assignmentIndex];
            const role = getSeedRoleById(assignment.role_id);
            const user = getSeedUserById(assignment.user_id);
            ADMIN_SEED.userRoleAssignments.splice(assignmentIndex, 1);
            addAuditLog('Permission', 'DELETE_ASSIGNMENT', `Gỡ role ${role?.code || assignment.role_id} khỏi ${user?.full_name || assignment.user_id}`);
            showAdminToast('Đã gỡ gán quyền.');
            renderAdminRolesPanel();
        }

