        function getTaskListEntryStatusCode(entry) {
            const normalizedState = normalizeTicketState(entry?.ticketState);
            if (!normalizedState) return getDefaultStateCode().stateCode;
            return normalizedState.is_personal
                ? getDefaultStateCode().stateCode
                : (getStateConfig(entry?.assignee?.workflow_state)?.stateCode || getDefaultStateCode().stateCode);
        }

        function getTaskListEntryPicKey(entry) {
            const normalizedState = normalizeTicketState(entry?.ticketState);
            if (!normalizedState) return '';
            if (normalizedState.is_personal) return CURRENT_USER_ID;
            return normalizeUserKey(entry?.assignee?.user_key) || '';
        }

        function getTaskListEntryPicKeys(entry) {
            const normalizedState = normalizeTicketState(entry?.ticketState);
            if (!normalizedState) return [];
            if (normalizedState.is_personal) return [CURRENT_USER_ID];
            return (normalizedState.assignees || [])
                .map((record) => normalizeUserKey(record.user_key))
                .filter(Boolean);
        }

        function getTaskListDeadlineSortValue(entry) {
            const normalizedState = normalizeTicketState(entry?.ticketState);
            if (!normalizedState?.date_raw) return Number.MAX_SAFE_INTEGER;
            const timeValue = new Date(normalizedState.date_raw).getTime();
            return Number.isFinite(timeValue) ? timeValue : Number.MAX_SAFE_INTEGER;
        }

        function getFilteredTaskListEntries(entries) {
            const filteredEntries = entries.filter((entry) => {
                const picMatches = taskListPicFilter === 'all' || getTaskListEntryPicKeys(entry).includes(taskListPicFilter);
                const statusMatches = taskListStatusFilter === 'all' || getTaskListEntryStatusCode(entry) === taskListStatusFilter;
                return picMatches && statusMatches;
            });

            if (taskListDeadlineSort === 'asc') {
                return filteredEntries.slice().sort((a, b) => getTaskListDeadlineSortValue(a) - getTaskListDeadlineSortValue(b));
            }
            if (taskListDeadlineSort === 'desc') {
                return filteredEntries.slice().sort((a, b) => getTaskListDeadlineSortValue(b) - getTaskListDeadlineSortValue(a));
            }
            return filteredEntries;
        }

        function renderTaskListControls(entries = getVisibleBoardTicketEntries()) {
            const picFilterOptions = document.getElementById('taskListPicFilterOptions');
            const statusFilterOptions = document.getElementById('taskListStatusFilterOptions');
            const groupOptions = document.getElementById('taskListGroupOptions');

            if (picFilterOptions) {
                const picKeys = Array.from(new Set(entries.flatMap((entry) => getTaskListEntryPicKeys(entry)).filter(Boolean)))
                    .sort((a, b) => (USERS[a]?.sort || Number.MAX_SAFE_INTEGER) - (USERS[b]?.sort || Number.MAX_SAFE_INTEGER));
                if (taskListPicFilter !== 'all' && !picKeys.includes(taskListPicFilter)) taskListPicFilter = 'all';
                const optionItems = [
                    { value: 'all', label: 'Tất cả' },
                    ...picKeys.map((userKey) => ({ value: userKey, label: USERS[userKey]?.full_name || userKey }))
                ];
                picFilterOptions.innerHTML = optionItems.map((item, index) => {
                    const isActive = taskListPicFilter === item.value;
                    return `
                        <button type="button" class="task-list-filter-option ${isActive ? 'is-active' : ''}" data-task-list-pic-option="${escapeHtml(item.value)}" role="menuitemradio" aria-checked="${isActive ? 'true' : 'false'}" style="--task-list-option-index:${index}" onclick="selectTaskListPicFilter('${escapeHtml(item.value)}', event)">
                            <span>${escapeHtml(item.label)}</span>
                            <i class="fa-solid fa-check task-list-filter-option-check" aria-hidden="true"></i>
                        </button>
                    `;
                }).join('');
            }
            syncTaskListFilterButtons();

            if (statusFilterOptions) {
                const statusCodes = Array.from(new Set(entries.map((entry) => getTaskListEntryStatusCode(entry)).filter(Boolean)));
                if (taskListStatusFilter !== 'all' && !statusCodes.includes(taskListStatusFilter)) taskListStatusFilter = 'all';
                const optionItems = [
                    { value: 'all', label: 'Tất cả' },
                    ...getWorkflowStates()
                        .filter((state) => statusCodes.includes(state.stateCode))
                        .map((state) => ({ value: state.stateCode, label: state.stateName }))
                ];
                statusFilterOptions.innerHTML = optionItems.map((item, index) => {
                    const isActive = taskListStatusFilter === item.value;
                    return `
                        <button type="button" class="task-list-filter-option ${isActive ? 'is-active' : ''}" role="menuitemradio" aria-checked="${isActive ? 'true' : 'false'}" style="--task-list-option-index:${index}" onclick="selectTaskListStatusFilter('${escapeHtml(item.value)}', event)">
                            <span>${escapeHtml(item.label)}</span>
                            <i class="fa-solid fa-check task-list-filter-option-check" aria-hidden="true"></i>
                        </button>
                    `;
                }).join('');
            }

            if (groupOptions) {
                const optionItems = [
                    { value: 'none', label: 'Không group' },
                    { value: 'pic', label: 'Theo PIC' },
                    { value: 'status', label: 'Theo Status' },
                    { value: 'deadline', label: 'Theo ngày hết hạn' }
                ];
                const isGroupActionDisabled = taskListGroupMode === 'none';
                const groupActionsHtml = `
                    <div class="task-list-group-actions">
                        <button type="button" class="task-list-group-action ${isGroupActionDisabled ? 'is-disabled' : ''}" style="--task-list-option-index:0" onclick="collapseAllTaskListGroups(event)" ${isGroupActionDisabled ? 'disabled aria-disabled="true"' : ''}>
                            <i class="fa-solid fa-compress"></i>
                            <span>Thu tất cả</span>
                        </button>
                        <button type="button" class="task-list-group-action ${isGroupActionDisabled ? 'is-disabled' : ''}" style="--task-list-option-index:1" onclick="expandAllTaskListGroups(event)" ${isGroupActionDisabled ? 'disabled aria-disabled="true"' : ''}>
                            <i class="fa-solid fa-expand"></i>
                            <span>Mở tất cả</span>
                        </button>
                    </div>
                `;
                groupOptions.innerHTML = groupActionsHtml + optionItems.map((item, index) => {
                    const isActive = taskListGroupMode === item.value;
                    return `
                        <button type="button" class="task-list-filter-option ${isActive ? 'is-active' : ''}" role="menuitemradio" aria-checked="${isActive ? 'true' : 'false'}" style="--task-list-option-index:${index + 2}" onclick="selectTaskListGroupMode('${escapeHtml(item.value)}', event)">
                            <span>${escapeHtml(item.label)}</span>
                            <i class="fa-solid fa-check task-list-filter-option-check" aria-hidden="true"></i>
                        </button>
                    `;
                }).join('');
            }
            syncTaskListFilterButtons();
        }

        function handleTaskListControlChange() {
            renderTaskListView();
        }

        function selectTaskListPicFilter(value, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            taskListPicFilter = value || 'all';
            closeTaskListPopovers({ immediate: true });
            renderTaskListView();
        }

        function selectTaskListStatusFilter(value, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            taskListStatusFilter = value || 'all';
            closeTaskListPopovers({ immediate: true });
            renderTaskListView();
        }

        function selectTaskListDeadlineSort(value, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            taskListDeadlineSort = value === 'desc' ? 'desc' : 'asc';
            closeTaskListPopovers({ immediate: true });
            renderTaskListView();
        }

        function cycleTaskListDeadlineSort(event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            selectTaskListDeadlineSort(taskListDeadlineSort === 'desc' ? 'asc' : 'desc', event);
        }

        function selectTaskListGroupMode(value, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            taskListGroupMode = ['pic', 'status', 'deadline'].includes(value) ? value : 'none';
            taskListCollapsedGroups.clear();
            closeTaskListPopovers({ immediate: true });
            renderTaskListView();
        }

        function resetTaskListControls() {
            if (!hasActiveTaskListControls()) return;
            taskListPicFilter = 'all';
            taskListStatusFilter = 'all';
            taskListDeadlineSort = 'asc';
            taskListGroupMode = 'none';
            taskListCollapsedGroups.clear();
            closeTaskListPopovers({ immediate: true });
            renderTaskListView();
        }

        function hasActiveTaskListControls() {
            return taskListPicFilter !== 'all'
                || taskListStatusFilter !== 'all'
                || taskListDeadlineSort !== 'asc'
                || taskListGroupMode !== 'none';
        }

        function syncTaskListFilterButtons() {
            const configs = [
                { key: 'pic', active: taskListPicFilter !== 'all', buttonId: 'taskListPicFilterButton', popoverId: 'taskListPicFilterPopover' },
                { key: 'status', active: taskListStatusFilter !== 'all', buttonId: 'taskListStatusFilterButton', popoverId: 'taskListStatusFilterPopover' },
                { key: 'deadline', active: taskListDeadlineSort === 'desc', buttonId: 'taskListDeadlineSortButton' },
                { key: 'group', active: taskListGroupMode !== 'none', buttonId: 'taskListGroupButton', popoverId: 'taskListGroupPopover' }
            ];
            configs.forEach((config) => {
                const isOpen = openTaskListPopover === config.key;
                const isClosing = closingTaskListPopover === config.key;
                const button = document.getElementById(config.buttonId);
                const popover = document.getElementById(config.popoverId);
                if (button) {
                    if (config.key === 'pic') {
                        const picLabel = taskListPicFilter === 'all'
                            ? 'Lọc theo PIC'
                            : `PIC: ${USERS[taskListPicFilter]?.full_name || taskListPicFilter}`;
                        button.setAttribute('data-tooltip', picLabel);
                        button.removeAttribute('title');
                    }
                    if (config.key === 'status') {
                        const statusLabel = taskListStatusFilter === 'all'
                            ? 'Lọc theo status'
                            : `Status: ${(getStateConfig(taskListStatusFilter) || getDefaultStateCode()).stateName}`;
                        button.setAttribute('data-tooltip', statusLabel);
                        button.removeAttribute('title');
                    }
                    if (config.key === 'deadline') {
                        const isDesc = taskListDeadlineSort === 'desc';
                        const icon = button.querySelector('i');
                        if (icon) {
                            icon.className = `fa-solid ${isDesc ? 'fa-arrow-up-wide-short' : 'fa-arrow-down-short-wide'}`;
                        }
                        const label = isDesc ? 'xa nhất' : 'gần nhất';
                        const nextLabel = isDesc ? 'gần nhất' : 'xa nhất';
                        button.setAttribute('aria-label', `Sắp xếp ngày hết hạn: đang ${label}. Click để đổi sang ${nextLabel}`);
                        button.setAttribute('data-tooltip', `Sort hiện tại: ${label}`);
                        button.removeAttribute('title');
                        button.classList.toggle('is-sort-desc', isDesc);
                    }
                    if (config.key === 'group') {
                        const label = getTaskListGroupModeLabel(taskListGroupMode);
                        const labelNode = document.getElementById('taskListGroupButtonLabel');
                        if (labelNode) labelNode.textContent = taskListGroupMode === 'none' ? 'Group' : label;
                        button.setAttribute('aria-label', `Group list tracking: ${label}`);
                        button.setAttribute('title', `Group list tracking: ${label}`);
                    }
                    button.classList.toggle('is-active', config.active);
                    button.classList.toggle('is-open', isOpen);
                    button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                }
                if (popover) {
                    popover.classList.toggle('hidden', !isOpen && !isClosing);
                    popover.classList.toggle('is-open', isOpen);
                    popover.classList.toggle('is-closing', isClosing);
                }
            });

            const resetButton = document.getElementById('taskListResetButton');
            if (resetButton) {
                const hasActiveControls = hasActiveTaskListControls();
                resetButton.disabled = !hasActiveControls;
                resetButton.setAttribute('aria-disabled', hasActiveControls ? 'false' : 'true');
                resetButton.setAttribute('data-tooltip', hasActiveControls ? 'Bỏ hết filter' : 'Không có filter để bỏ');
            }
        }

        function toggleTaskListPicFilter(event) {
            toggleTaskListPopover('pic', event);
        }

        function closeTaskListPicFilter() {
            closeTaskListPopovers({ immediate: true });
        }

        function toggleTaskListPopover(popoverKey, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            if (openTaskListPopover === popoverKey) {
                closeTaskListPopovers();
                return;
            }
            clearTaskListPopoverCloseTimer();
            closingTaskListPopover = '';
            openTaskListPopover = popoverKey;
            syncTaskListFilterButtons();
        }

        function clearTaskListPopoverCloseTimer() {
            if (!taskListPopoverCloseTimeout) return;
            window.clearTimeout(taskListPopoverCloseTimeout);
            taskListPopoverCloseTimeout = null;
        }

        function finishTaskListPopoverClose(popoverKey) {
            if (popoverKey && closingTaskListPopover !== popoverKey) return;
            closingTaskListPopover = '';
            taskListPopoverCloseTimeout = null;
            syncTaskListFilterButtons();
        }

        function closeTaskListPopovers({ immediate = false } = {}) {
            const closingKey = openTaskListPopover || closingTaskListPopover;
            clearTaskListPopoverCloseTimer();
            if (!closingKey) {
                openTaskListPopover = '';
                closingTaskListPopover = '';
                syncTaskListFilterButtons();
                return;
            }
            openTaskListPopover = '';
            closingTaskListPopover = closingKey;
            const shouldCloseImmediately = immediate || window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
            if (shouldCloseImmediately) {
                closingTaskListPopover = '';
                taskListPopoverCloseTimeout = null;
                syncTaskListFilterButtons();
                return;
            }
            syncTaskListFilterButtons();
            taskListPopoverCloseTimeout = window.setTimeout(() => {
                finishTaskListPopoverClose(closingKey);
            }, getLovMotionDurationMs());
        }

        function renderTaskListDeadlineCell(ticketState) {
            const normalizedState = normalizeTicketState(ticketState);
            if (!normalizedState) return '';
            const { dateStr, statusTextHtml } = getTaskDateMeta(normalizedState.date_raw);
            return `
                <div class="task-list-deadline-cell">
                    <span class="task-list-date"><i class="fa-regular fa-calendar"></i>${escapeHtml(dateStr)}</span>
                    ${statusTextHtml || ''}
                </div>
            `;
        }

        function getTaskListRowValueClass(options = {}) {
            return `task-list-row-value${options.staticValues ? ' is-static' : ''}`;
        }

        function renderTaskListRow(entry, index = 0, options = {}) {
            const { ticketState, assignee } = entry || {};
            const normalizedState = normalizeTicketState(ticketState);
            if (!normalizedState) return '';
            const displayIndex = Math.max(1, (Number.isFinite(index) ? index : 0) + 1);
            const rowIndex = Math.min(Number.isFinite(index) ? index : 0, 8);
            const valueClass = getTaskListRowValueClass(options);
            const rowClass = `task-list-row${options.softEnter ? ' is-soft-enter' : ''}`;
            return `
                <div class="${rowClass}" style="--row-index:${rowIndex}" data-ticket-id="${escapeHtml(normalizedState.ticket_id)}" onclick="openTaskDetailsDrawer('${escapeHtml(normalizedState.ticket_id)}')">
                    <div class="task-list-title ${valueClass}"><span class="task-list-index">${displayIndex}.</span><span>${escapeHtml(normalizedState.title || 'Task chưa đặt tên')}</span></div>
                    <div class="task-list-desc ${valueClass}">${escapeHtml(normalizedState.desc || 'Chưa có mô tả')}</div>
                    <div class="task-list-pic-cell ${valueClass}">${renderTaskListPicCell(normalizedState, assignee)}</div>
                    <div class="${valueClass}">${renderTaskListStatusCell(normalizedState, assignee)}</div>
                    <div class="${valueClass}">${renderTaskListDeadlineCell(normalizedState)}</div>
                </div>
            `;
        }

        function renderTaskListGroupRow(entry, index, options = {}) {
            const rowIndex = Math.min(Number.isFinite(index) ? index : 0, 8);
            const { ticketState, assignee } = entry || {};
            const normalizedState = normalizeTicketState(ticketState);
            if (!normalizedState) return '';
            const displayIndex = Math.max(1, (Number.isFinite(index) ? index : 0) + 1);
            const valueClass = getTaskListRowValueClass(options);
            const rowClass = `task-list-row${options.softEnter ? ' is-soft-enter' : ''}`;
            return `
                <div class="${rowClass}" style="--row-index:${rowIndex}" data-ticket-id="${escapeHtml(normalizedState.ticket_id)}" onclick="openTaskDetailsDrawer('${escapeHtml(normalizedState.ticket_id)}')">
                    <div class="task-list-title ${valueClass}"><span class="task-list-index">${displayIndex}.</span><span>${escapeHtml(normalizedState.title || 'Task chưa đặt tên')}</span></div>
                    <div class="task-list-desc ${valueClass}">${escapeHtml(normalizedState.desc || 'Chưa có mô tả')}</div>
                    <div class="task-list-pic-cell ${valueClass}">${renderTaskListPicCell(normalizedState, assignee)}</div>
                    <div class="${valueClass}">${renderTaskListStatusCell(normalizedState, assignee)}</div>
                    <div class="${valueClass}">${renderTaskListDeadlineCell(normalizedState)}</div>
                </div>
            `;
        }

        function getTaskListGroupModeLabel(mode) {
            if (mode === 'pic') return 'Theo PIC';
            if (mode === 'status') return 'Theo Status';
            if (mode === 'deadline') return 'Theo ngày hết hạn';
            return 'Không group';
        }

        function getTaskListGroupMeta(entry, mode) {
            const normalizedState = normalizeTicketState(entry?.ticketState);
            if (mode === 'pic') {
                const picKey = getTaskListEntryPicKey(entry);
                const user = USERS[picKey];
                return {
                    key: picKey || 'unassigned',
                    label: user?.full_name || (picKey ? picKey : 'Chưa giao'),
                    icon: 'fa-user',
                    typeLabel: 'PIC',
                    accentColor: user?.color || '#2563eb'
                };
            }
            if (mode === 'status') {
                const stateCode = getTaskListEntryStatusCode(entry);
                const stateMeta = getStateConfig(stateCode) || getDefaultStateCode();
                const statusColor = getColorOptionMeta(stateMeta.colorTheme).hex || '#7c3aed';
                return {
                    key: stateMeta.stateCode,
                    label: stateMeta.stateName,
                    icon: 'fa-circle-dot',
                    typeLabel: 'STATUS',
                    accentColor: statusColor
                };
            }
            if (mode === 'deadline') {
                if (!normalizedState?.date_raw) {
                    return { key: 'no-date', label: 'Chưa có hạn', icon: 'fa-calendar-xmark', typeLabel: 'DEADLINE', accentColor: '#94a3b8' };
                }
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const taskDate = new Date(normalizedState.date_raw);
                taskDate.setHours(0, 0, 0, 0);
                const diffDays = Math.ceil((taskDate - today) / (1000 * 60 * 60 * 24));
                if (diffDays < 0) return { key: 'overdue', label: 'Trễ hạn', icon: 'fa-triangle-exclamation', typeLabel: 'DEADLINE', accentColor: '#ef4444' };
                if (diffDays === 0) return { key: 'today', label: 'Hôm nay', icon: 'fa-bolt', typeLabel: 'DEADLINE', accentColor: '#f59e0b' };
                if (diffDays <= 7) return { key: 'next-7', label: '7 ngày tới', icon: 'fa-calendar-week', typeLabel: 'DEADLINE', accentColor: '#2563eb' };
                return { key: 'later', label: 'Sau đó', icon: 'fa-calendar-days', typeLabel: 'DEADLINE', accentColor: '#64748b' };
            }
            return { key: 'none', label: '', icon: 'fa-layer-group', typeLabel: 'GROUP', accentColor: '#2563eb' };
        }

        function getTaskListGroupOrder(mode) {
            if (mode === 'pic') {
                return getCurrentSortedTeamUserKeys().concat(CURRENT_USER_ID, 'unassigned')
                    .filter((key, index, keys) => key && keys.indexOf(key) === index);
            }
            if (mode === 'status') {
                return getWorkflowStates().map((state) => state.stateCode);
            }
            if (mode === 'deadline') {
                return taskListDeadlineSort === 'desc'
                    ? ['later', 'next-7', 'today', 'overdue', 'no-date']
                    : ['overdue', 'today', 'next-7', 'later', 'no-date'];
            }
            return [];
        }

        function groupTaskListEntries(entries) {
            const groupsByKey = new Map();
            entries.forEach((entry) => {
                const meta = getTaskListGroupMeta(entry, taskListGroupMode);
                if (!groupsByKey.has(meta.key)) {
                    groupsByKey.set(meta.key, { ...meta, entries: [] });
                }
                groupsByKey.get(meta.key).entries.push(entry);
            });

            const order = getTaskListGroupOrder(taskListGroupMode);
            return Array.from(groupsByKey.values()).sort((a, b) => {
                const orderA = order.indexOf(a.key);
                const orderB = order.indexOf(b.key);
                if (orderA !== -1 || orderB !== -1) {
                    return (orderA === -1 ? Number.MAX_SAFE_INTEGER : orderA) - (orderB === -1 ? Number.MAX_SAFE_INTEGER : orderB);
                }
                return a.label.localeCompare(b.label, 'vi');
            });
        }

        function getCurrentTaskListGroups() {
            if (taskListGroupMode === 'none') return [];
            return groupTaskListEntries(getFilteredTaskListEntries(getVisibleBoardTicketEntries()));
        }

        function getTaskListGroupSection(groupKey) {
            if (!groupKey) return null;
            if (window.CSS?.escape) {
                return document.querySelector(`.task-list-group-section[data-task-list-group="${CSS.escape(groupKey)}"]`);
            }
            return Array.from(document.querySelectorAll('.task-list-group-section'))
                .find((section) => section.dataset.taskListGroup === groupKey) || null;
        }

        function toggleTaskListGroupCollapse(groupKey, event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            if (!groupKey) return;
            const section = getTaskListGroupSection(groupKey);
            const heading = section?.querySelector('.task-list-group-heading');
            const groupLabel = section?.dataset.taskListGroupLabel || groupKey;
            const willCollapse = !taskListCollapsedGroups.has(groupKey);

            if (willCollapse) {
                taskListCollapsedGroups.add(groupKey);
            } else {
                taskListCollapsedGroups.delete(groupKey);
            }

            if (section) section.classList.toggle('is-collapsed', willCollapse);
            if (heading) {
                heading.setAttribute('aria-expanded', willCollapse ? 'false' : 'true');
                heading.setAttribute('aria-label', `${willCollapse ? 'Mở' : 'Thu gọn'} nhóm ${groupLabel}`);
            }
        }

        function collapseAllTaskListGroups(event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            const groups = getCurrentTaskListGroups();
            if (!groups.length) return;
            taskListCollapsedGroups = new Set(groups.map((group) => group.key));
            closeTaskListPopovers({ immediate: true });
            syncTaskListGroupCollapseDom();
        }

        function expandAllTaskListGroups(event) {
            event?.preventDefault?.();
            event?.stopPropagation?.();
            taskListCollapsedGroups.clear();
            closeTaskListPopovers({ immediate: true });
            syncTaskListGroupCollapseDom();
        }

        function syncTaskListGroupCollapseDom() {
            document.querySelectorAll('.task-list-group-section').forEach((section) => {
                const groupKey = section.dataset.taskListGroup;
                const groupLabel = section.dataset.taskListGroupLabel || groupKey;
                const isCollapsed = taskListCollapsedGroups.has(groupKey);
                const heading = section.querySelector('.task-list-group-heading');
                section.classList.toggle('is-collapsed', isCollapsed);
                if (heading) {
                    heading.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
                    heading.setAttribute('aria-label', `${isCollapsed ? 'Mở' : 'Thu gọn'} nhóm ${groupLabel}`);
                }
            });
        }

        function pruneTaskListCollapsedGroups(groups) {
            const visibleKeys = new Set(groups.map((group) => group.key));
            taskListCollapsedGroups.forEach((groupKey) => {
                if (!visibleKeys.has(groupKey)) taskListCollapsedGroups.delete(groupKey);
            });
        }

        function renderTaskListGroupedView(entries, options = {}) {
            const groups = groupTaskListEntries(entries);
            pruneTaskListCollapsedGroups(groups);
            return groups.map((group) => {
                const isCollapsed = taskListCollapsedGroups.has(group.key);
                const actionLabel = `${isCollapsed ? 'Mở' : 'Thu gọn'} nhóm ${group.label}`;
                return `
                <div class="task-list-group-section ${isCollapsed ? 'is-collapsed' : ''}" data-task-list-group="${escapeHtml(group.key)}" data-task-list-group-label="${escapeHtml(group.label)}" style="--group-accent:${escapeHtml(group.accentColor || '#2563eb')}">
                    <button type="button" class="task-list-group-heading" data-task-list-group-toggle="${escapeHtml(group.key)}" onclick="toggleTaskListGroupCollapse(this.dataset.taskListGroupToggle, event)" aria-expanded="${isCollapsed ? 'false' : 'true'}" aria-label="${escapeHtml(actionLabel)}">
                        <div class="task-list-group-title">
                            <span class="task-list-group-toggle" aria-hidden="true">
                                <i class="fa-solid fa-chevron-right"></i>
                            </span>
                            <span class="task-list-group-icon">
                                <i class="fa-solid ${escapeHtml(group.icon)}" aria-hidden="true"></i>
                            </span>
                            <span>${escapeHtml(group.label)}</span>
                        </div>
                        <span class="task-list-group-count">${group.entries.length} task</span>
                    </button>
                    <div class="task-list-group-body">
                        <div class="task-list-group-body-inner">
                            ${group.entries.map((entry, index) => renderTaskListGroupRow(entry, index, options)).join('')}
                        </div>
                    </div>
                </div>
            `;
            }).join('');
        }

        function clearTrackingSkeletonTimer() {
            if (!trackingSkeletonTimeout) return;
            window.clearTimeout(trackingSkeletonTimeout);
            trackingSkeletonTimeout = null;
        }

