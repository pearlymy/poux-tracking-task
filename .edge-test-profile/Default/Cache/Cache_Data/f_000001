                { id: 'blue', hex: '#3b82f6' }, { id: 'indigo', hex: '#6366f1' }, { id: 'violet', hex: '#8b5cf6' },
                { id: 'purple', hex: '#a855f7' }, { id: 'pink', hex: '#ec4899' }
            ];
            panel.innerHTML = `
                <div class="rounded-[24px] border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
                        <div>
                            <h2 class="text-xl font-extrabold text-slate-900">Workflow / State</h2>
                            <p class="mt-1 text-sm text-slate-500">Chỉ hỗ trợ đổi thứ tự, chỉnh wording và thêm state mới.</p>
                        </div>
                        <button type="button" class="app-btn-primary rounded-xl px-4 py-2.5 text-sm" onclick="createStateDraft()">+ Tạo state</button>
                    </div>
                    <div class="mt-6 grid gap-4 lg:grid-cols-2">
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                            <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-slate-400">Thứ tự hiện tại</p>
                            <div class="state-order-list mt-4 space-y-3">
                                ${sortedStates.map((state) => {
                const colorMeta = getColorOptionMeta(state.color_theme);
                const isActive = selectedState?.id === state.id;
                return `
                                        <div
                                            class="state-order-item ${isActive ? 'is-active' : ''}"
                                            data-state-id="${escapeHtml(state.id)}"
                                            onclick="setActiveState('${escapeHtml(state.id)}')"
                                        >
                                            <span class="font-bold" style="color:${colorMeta.hex}">${state.display_order}. ${escapeHtml(state.label)}</span>
                                            <button type="button" class="state-order-handle" onmousedown="startStatePointerDrag(event, '${escapeHtml(state.id)}')" aria-label="Kéo thả state">
                                                <i class="fa-solid fa-grip-vertical"></i>
                                            </button>
                                        </div>
                                    `;
            }).join('')}
                            </div>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                            <div class="flex items-center justify-between gap-3">
                                <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-slate-400">Chi tiết state</p>
                                ${isStateEditMode
                    ? `
                                        <div class="flex justify-end gap-3">
                                            <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700" onclick="cancelStateChanges()">Hủy</button>
                                            <button type="button" class="app-btn-primary rounded-xl px-4 py-2 text-sm" onclick="saveStateChanges()">Lưu</button>
                                        </div>
                                    `
                    : `
                                        <button type="button" class="org-action-btn is-icon tooltip-btn" data-tooltip="Chỉnh sửa state" onclick="setStateDetailMode('edit')">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                    `}
                            </div>
                            <div class="mt-4 space-y-4">
                                ${isStateEditMode ? `
                                    <label class="block text-sm font-bold text-slate-700">Mã state<input id="stateCode" type="text" value="${escapeHtml(selectedState.code)}" placeholder="Nhập mã state" class="org-field-input mt-2 w-full text-sm font-normal" oninput="if (this.value.trim()) clearStateFieldError('code')"></label>
                                    <label class="block text-sm font-bold text-slate-700">Wording hiển thị<input id="stateLabel" type="text" value="${escapeHtml(selectedState.label)}" placeholder="Nhập wording hiển thị" class="org-field-input mt-2 w-full text-sm font-normal" oninput="if (this.value.trim()) clearStateFieldError('label')"></label>
                                    <label class="block text-sm font-bold text-slate-700">Description<textarea id="stateDescription" class="org-field-input org-field-textarea mt-2 w-full text-sm font-normal" rows="1" placeholder="Nhập mô tả state">${escapeHtml(selectedState.description || '')}</textarea></label>
                                    <div>
                                        <span class="block text-sm font-bold text-slate-700">Màu cột</span>
                                        <div class="member-single-lov state-color-lov mt-2">
                                            <button type="button" class="org-field-input member-lov-trigger ${isStateColorLovOpen ? 'is-open' : ''}" onclick="toggleStateColorLov(event)">
                                                <span class="member-lov-copy">
                                                    <span class="member-lov-value font-medium inline-flex items-center gap-3">
                                                        <span class="admin-color-chip-swatch" style="background:${getColorOptionMeta(selectedState.color_theme).hex}"></span>
                                                        <span>${escapeHtml(selectedState.color_theme)}</span>
                                                    </span>
                                                </span>
                                                <i class="fa-solid fa-chevron-down text-sm text-slate-500"></i>
                                            </button>
                                            <div class="member-single-lov-panel ${isStateColorLovOpen ? '' : 'hidden'}" onclick="event.stopPropagation()">
                                                <div class="member-single-lov-list">
                                                    ${colorOptions.map((option) => `
                                                        <button type="button" class="member-single-lov-item ${selectedState.color_theme === option.id ? 'is-active' : ''}" onclick="updateStateDraftColor('${escapeHtml(option.id)}')">
                                                            <span class="member-color-lov-item">
                                                                <span class="member-color-lov-swatch" style="background:${option.hex}"></span>
                                                                <span>${escapeHtml(option.id)}</span>
                                                            </span>
                                                        </button>
                                                    `).join('')}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                ` : `
                                    <div class="grid gap-4">
                                        <div>
                                            <span class="block text-sm font-bold text-slate-700">Mã state</span>
                                            <div class="mt-2 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-500">${escapeHtml(selectedState.code)}</div>
                                        </div>
                                        <div>
                                            <span class="block text-sm font-bold text-slate-700">Wording hiển thị</span>
                                            <div class="mt-2 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-500">${escapeHtml(selectedState.label)}</div>
                                        </div>
                                        <div>
                                            <span class="block text-sm font-bold text-slate-700">Description</span>
                                            <div class="mt-2 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-500">${escapeHtml(selectedState.description || 'Chưa có mô tả')}</div>
                                        </div>
                                        <div>
                                            <span class="block text-sm font-bold text-slate-700">Màu cột</span>
                                            <div class="mt-2 inline-flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-500">
                                                <span class="admin-color-chip-swatch" style="background:${getColorOptionMeta(selectedState.color_theme).hex}"></span>
                                                <span>${escapeHtml(selectedState.color_theme)}</span>
                                            </div>
                                        </div>
                                    </div>
                                `}
                            </div>
                        </div>
                    </div>
                </div>
            `;
            if (isStateEditMode) {
                initializeStateDescriptionInput();
            }
        }

        function setActiveState(stateId) {
            if (!getSeedStateById(stateId)) return;
            currentStateSelectionId = stateId;
            currentStateDetailMode = 'view';
            currentStateDraft = null;
            isStateColorLovOpen = false;
            renderAdminStatesPanel();
        }

        function setStateDetailMode(mode) {
            currentStateDetailMode = mode === 'edit' ? 'edit' : 'view';
            if (currentStateDetailMode === 'edit') {
                const state = getStateBySelection();
                currentStateDraft = buildStateDraft(state);
            } else {
                currentStateDraft = null;
                isStateColorLovOpen = false;
            }
            renderAdminStatesPanel();
        }

        function toggleStateColorLov(event) {
            event?.stopPropagation?.();
            isStateColorLovOpen = !isStateColorLovOpen;
            renderAdminStatesPanel();
        }

        function closeStateColorLov() {
            if (!isStateColorLovOpen) return;
            isStateColorLovOpen = false;
            renderAdminStatesPanel();
        }

        function updateStateDraftColor(colorId) {
            if (!currentStateDraft) return;
            currentStateDraft = {
                ...currentStateDraft,
                color_theme: colorId
            };
            isStateColorLovOpen = false;
            renderAdminStatesPanel();
        }

        function cancelStateChanges() {
            if (currentStateDraft?.is_new) {
                currentStateSelectionId = ADMIN_SEED.states[0]?.id || '';
            }
            currentStateDraft = null;
            currentStateDetailMode = 'view';
            isStateColorLovOpen = false;
            renderAdminStatesPanel();
        }

        function saveStateChanges() {
            const state = getSeedStateById(currentStateSelectionId);
            if (!currentStateDraft) return;

            const nextCode = String(document.getElementById('stateCode')?.value || '').trim().toUpperCase().replace(/\s+/g, '_');
            const nextLabel = String(document.getElementById('stateLabel')?.value || '').trim();
            const nextDescription = String(document.getElementById('stateDescription')?.value || '').trim();

            clearStateValidation();
            if (!nextCode || !nextLabel) {
                if (!nextCode) markStateFieldError('code');
                if (!nextLabel) markStateFieldError('label');
                showAdminToast('Mã state và wording không được để trống.');
                return;
            }

            const duplicatedState = ADMIN_SEED.states.find((item) => item.id !== currentStateDraft.id && item.code === nextCode);
            if (duplicatedState) {
                markStateFieldError('code');
                showAdminToast(`Code ${nextCode} đã tồn tại.`);
                return;
            }

            const nextState = {
                id: currentStateDraft.id,
                code: nextCode,
                label: nextLabel,
                description: nextDescription,
                color_theme: currentStateDraft.color_theme,
                display_order: currentStateDraft.display_order,
                is_active: true
            };

            if (currentStateDraft.is_new) {
                ADMIN_SEED.states.push(nextState);
                showAdminToast(`Đã tạo state ${nextState.code}.`);
            } else if (state) {
                state.code = nextCode;
                state.label = nextLabel;
                state.description = nextDescription;
                state.color_theme = currentStateDraft.color_theme;
                showAdminToast(`Đã lưu thay đổi cho state ${state.code}.`);
            } else {
                return;
            }

            currentStateDraft = null;
            currentStateDetailMode = 'view';
            isStateColorLovOpen = false;
            currentStateSelectionId = nextState.id;
            renderAdminStatesPanel();
            syncWorkflowStatesToBoard();
        }

        function ensureStatePlaceholder() {
            if (currentStatePlaceholderEl?.isConnected) return currentStatePlaceholderEl;
            const placeholder = document.createElement('div');
            placeholder.className = 'state-order-placeholder';
            currentStatePlaceholderEl = placeholder;
            return placeholder;
        }

        function getStatePlaceholderInsertIndex(container) {
            if (!container || !currentStatePlaceholderEl?.isConnected) return -1;
            const siblings = Array.from(container.children);
            const placeholderIndex = siblings.indexOf(currentStatePlaceholderEl);
            if (placeholderIndex < 0) return -1;
            return siblings
                .slice(0, placeholderIndex)
                .filter((item) => item.classList.contains('state-order-item') && !item.classList.contains('is-dragging'))
                .length;
        }

        function startStatePointerDrag(event, stateId) {
            if (event.button !== 0) return;
            event.preventDefault();
            event.stopPropagation();
            const item = event.currentTarget.closest('.state-order-item');
            const container = item?.parentNode;
            if (!item || !container) return;

            currentStateDragId = stateId;
            currentStateDraggedEl = item;
            const rect = item.getBoundingClientRect();
            currentStateDragOffsetY = event.clientY - rect.top;
            const placeholder = ensureStatePlaceholder();
            placeholder.style.height = `${rect.height}px`;
            container.insertBefore(placeholder, item.nextSibling);

            item.classList.add('is-dragging', 'is-floating');
            item.style.width = `${rect.width}px`;
            item.style.left = `${rect.left}px`;
            item.style.top = `${event.clientY - currentStateDragOffsetY}px`;
        }

        function handleStatePointerDragMove(event) {
            if (!currentStateDragId || !currentStateDraggedEl) return;
            event.preventDefault();

            currentStateDraggedEl.style.top = `${event.clientY - currentStateDragOffsetY}px`;
            const placeholder = ensureStatePlaceholder();
            const container = document.querySelector('[data-admin-panel="states"] .state-order-list');
            if (!container) return;

            const items = Array.from(container.querySelectorAll('.state-order-item:not(.is-dragging)'));
            if (!items.length) {
                container.appendChild(placeholder);
                return;
            }

            let inserted = false;
            for (const item of items) {
                const rect = item.getBoundingClientRect();
                if (event.clientY < rect.top + rect.height / 2) {
                    container.insertBefore(placeholder, item);
                    inserted = true;
                    break;
                }
            }

            if (!inserted) {
                container.appendChild(placeholder);
            }
        }

        function finishStatePointerDrag() {
            if (!currentStateDragId || !currentStateDraggedEl) {
                handleStateDragEnd();
                return;
            }

            const container = document.querySelector('[data-admin-panel="states"] .state-order-list');
            const sourceStateId = currentStateDragId;
            if (!container) {
                handleStateDragEnd();
                return;
            }

            const sortedStates = ADMIN_SEED.states.slice().sort((a, b) => a.display_order - b.display_order);
            const sourceIndex = sortedStates.findIndex((state) => state.id === sourceStateId);
            const insertIndex = getStatePlaceholderInsertIndex(container);
            if (sourceIndex < 0 || insertIndex < 0) {
                handleStateDragEnd();
                renderAdminStatesPanel();
                return;
            }

            const [movedState] = sortedStates.splice(sourceIndex, 1);
            sortedStates.splice(insertIndex, 0, movedState);
            sortedStates.forEach((state, index) => {
                state.display_order = index + 1;
            });

            currentStateSelectionId = movedState.id;
            showAdminToast(`Đã cập nhật thứ tự state ${movedState.label}.`);
            handleStateDragEnd();
            renderAdminStatesPanel();
            syncWorkflowStatesToBoard();
        }

        function handleStateDragEnd() {
            currentStateDragId = null;
            currentStateDraggedEl?.classList.remove('is-dragging', 'is-floating');
            if (currentStateDraggedEl) {
                currentStateDraggedEl.style.width = '';
                currentStateDraggedEl.style.left = '';
                currentStateDraggedEl.style.top = '';
            }
            currentStateDraggedEl = null;
            currentStateDragOffsetY = 0;
            currentStatePlaceholderEl?.remove();
            currentStatePlaceholderEl = null;
            document.querySelectorAll('[data-admin-panel="states"] .state-order-item').forEach((item) => {
                item.classList.remove('is-dragging', 'is-drop-target', 'is-floating');
            });
        }

        function renderAdminLogsPanel() {
            const panel = document.querySelector('[data-admin-panel="logs"]');
            if (!panel) return;
            panel.innerHTML = `
                <div class="rounded-[24px] border border-slate-200 bg-white p-6 shadow-sm">
                    <h2 class="text-xl font-extrabold text-slate-900">Nhật ký hệ thống</h2>
                    <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
                        <table class="admin-table">
                            <thead><tr><th>Thời gian</th><th>User</th><th>Module</th><th>Hành động</th><th>Chi tiết</th></tr></thead>
                            <tbody class="bg-white">
                                ${ADMIN_SEED.auditLogs.map((log) => `
                                    <tr>
                                        <td>${escapeHtml(log.time)}</td>
                                        <td>${escapeHtml(log.user)}</td>
                                        <td>${escapeHtml(log.module)}</td>
                                        <td>${escapeHtml(log.action)}</td>
                                        <td>${escapeHtml(log.detail)}</td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            `;
        }

        function renderAdminView() {
            renderAdminOrgPanel();
            renderAdminRolesPanel();
            renderAdminStatesPanel();
            renderAdminLogsPanel();
            setActiveAdminTab(currentAdminTab);
        }

        renderAdminView();
        initializeAdminTabs();
        document.addEventListener('mousemove', handleStatePointerDragMove);
        document.addEventListener('mouseup', finishStatePointerDrag);
        document.addEventListener('click', () => {
            closeTaskChecklistAssigneeLov();
            closeTaskChecklistDatePicker();
            closeMemberTeamLov();
            closeMemberSingleLov();
            closeRoleScopeLov();
            closeStateColorLov();
            closeTaskCommentReactionMenu();
            closeAssigneeStatusLov();
            closeTaskListPopovers();
        });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && document.querySelector('.task-detail-drawer-layer.is-open')) {
                closeTaskDetailsDrawer();
            }
            if (e.key === 'Escape') {
                closeTaskListPopovers();
            }
        });

        // ==========================================
        renderKanbanBoard();
        initializeKanbanScrollNav();
        initializeTaskListColumnResize();
        initializeTaskViewSwitch();
        applyUIPermissions();
        initSortableColumns();
        loadBoardState();
        initializeBranchManager('document');
        initializeTeamSelector();
        initializeSelectableNav();
        initializeSelectableMembers();
        initializeProfileCard();
        initializeCurrentUserProfile();
        const initialRouteParams = new URLSearchParams(window.location.search);
        const initialDocumentPageId = initialRouteParams.get('documentPage') || initialRouteParams.get('scope') || null;
        if (initialRouteParams.get('workspace') === 'document' || initialDocumentPageId) {
            preferredNavTarget = 'documentMenu';
            preferredNavLink = null;
            showDocumentWorkspace(initialDocumentPageId || getBranchState('document').activeId);
            if (!accordionState.documentMenu) toggleAccordion('documentMenu', 'documentChevron');
        } else if (isTrackingRoute(getTrackingRouteFromUrl())) {
            handleAppRouteFromUrl({ replaceUrl: true });
        } else {
            setWorkspaceView("board");
            toggleAccordion('trackingMenu', 'trackingChevron');
        }
        window.addEventListener('popstate', () => handleAppRouteFromUrl({ replaceUrl: false }));
        function autoResize(textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = textarea.scrollHeight + 'px';
        }

        const inlineDesc = document.getElementById('inlineDesc');
        if (inlineDesc) {
            inlineDesc.addEventListener('input', function () {
                autoResize(this);
            });
        }
    </script>
</body>

</html>


