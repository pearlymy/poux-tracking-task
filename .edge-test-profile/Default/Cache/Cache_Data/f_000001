        }

        function loadBranchPages(branchKey) {
            const config = getBranchConfig(branchKey);
            const state = getBranchState(branchKey);
            const savedPages = localStorage.getItem(config.storageKey);
            if (savedPages) {
                try {
                    const parsedPages = JSON.parse(savedPages);
                    if (Array.isArray(parsedPages) && parsedPages.length > 0) {
                        const normalizedPages = normalizeBranchItems(parsedPages, config);
                        if (!normalizedPages.length) throw new Error('No valid document pages');
                        state.pages = normalizedPages;
                        if (!getBranchPage(branchKey, state.activeId)) {
                            state.activeId = getFirstBranchPage(branchKey)?.id || null;
                        }
                        saveBranchPages(branchKey);
                        return;
                    }
                } catch (error) {
                }
            }
            state.pages = normalizeBranchItems(config.defaultPages, config);
        }

        function saveBranchPages(branchKey) {
            const config = getBranchConfig(branchKey);
            localStorage.setItem(config.storageKey, JSON.stringify(getBranchState(branchKey).pages));
        }

        function initializeBranchSortable(branchKey) {
            const config = getBranchConfig(branchKey);
            const state = getBranchState(branchKey);
            const list = document.getElementById(config.listId);
            if (!list || typeof Sortable === 'undefined' || list.dataset.sortableInitialized === 'true') return;

            new Sortable(list, {
                animation: 150,
                filter: '.is-editing, .document-inline-form, .document-page-actions, button, input',
                preventOnFilter: false,
                ghostClass: 'document-branch-ghost',
                dragClass: 'document-branch-drag',
                onStart: () => {
                    state.deleteConfirmId = null;
                },
                onEnd: () => {
                    const orderedIds = Array.from(list.querySelectorAll(`[${config.rowAttr}]`))
                        .map((row) => row.getAttribute(config.rowAttr))
                        .filter(Boolean);
                    const itemById = new Map(state.pages.map((item) => [item.id, item]));
                    const orderedVisibleItems = orderedIds.map((id) => itemById.get(id)).filter(Boolean);
                    let visibleIndex = 0;
                    state.pages = state.pages.map((item) => {
                        if (!orderedIds.includes(item.id)) return item;
                        const nextItem = orderedVisibleItems[visibleIndex];
                        visibleIndex += 1;
                        return nextItem || item;
                    });
                    saveBranchPages(branchKey);
                    renderBranchPages(branchKey);
                }
            });

            list.dataset.sortableInitialized = 'true';
        }

