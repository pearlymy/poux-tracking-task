    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        /* CSS MỚI CỦA BẠN (CÁC BIẾN & STYLE FORM) */
        :root {
            --app-primary: #2563EB;
            --app-primary-hover: #1D4ED8;
            --app-primary-gradient: linear-gradient(135deg, #0575e6 0%, #021b79 100%);
            --app-primary-gradient-hover: linear-gradient(135deg, #0468cf 0%, #01165f 100%);
            --app-primary-soft: #EFF6FF;
            --app-primary-soft-hover: #DBEAFE;
            --app-primary-border: #BFDBFE;
            --app-primary-text: #2563EB;
            --app-primary-text-strong: #1E40AF;
            --app-primary-ring: rgba(37, 99, 235, 0.12);
            --app-primary-shadow: rgba(2, 27, 121, 0.34);
            --po-primary: var(--app-primary);
            --po-primary-hover: var(--app-primary-hover);
            --po-primary-light: var(--app-primary-soft);
            --po-primary-dark: var(--app-primary-text-strong);
            --po-bg-light: #F8FAFC;
            --po-border: #E2E8F0;
            --po-text-main: #1E293B;
            --po-text-muted: #64748B;
            --po-alert-bg: var(--app-primary-soft);
            --po-alert-text: var(--app-primary-text-strong);
            --lov-duration: 260ms;
            --lov-close-duration: 180ms;
            --lov-option-duration: 220ms;
            --lov-ease: cubic-bezier(0.22, 1, 0.36, 1);
            --lov-exit-ease: cubic-bezier(0.4, 0, 1, 1);
            --lov-translate: -6px;
            --lov-option-translate: 5px;
            --lov-scale: 0.97;
            --appear-duration: 280ms;
            --appear-item-duration: 240ms;
            --appear-ease: cubic-bezier(0.22, 1, 0.36, 1);
            --appear-translate: 8px;
            --appear-scale: 0.985;
            --tooltip-bg: #0f172a;
            --tooltip-color: #ffffff;
            --tooltip-offset: 0.55rem;
            --tooltip-arrow-offset: 0.33rem;
            --tooltip-side-offset: 10px;
            --tooltip-side-arrow-offset: 6px;
        }

        .app-btn-primary,
        .app-btn-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            font-weight: 700;
            line-height: 1.25;
            transition:
                background-color 0.18s ease,
                border-color 0.18s ease,
                color 0.18s ease,
                box-shadow 0.18s ease,
                transform 0.18s ease;
        }

        .app-btn-primary {
            border: 0;
            background: var(--app-primary-gradient);
            color: #fff;
            outline: none;
            box-shadow: 0 12px 22px -10px var(--app-primary-shadow);
        }

        .app-btn-primary:hover {
            background: var(--app-primary-gradient-hover);
            color: #fff;
        }

        .app-btn-primary:focus-visible {
            box-shadow: 0 0 0 4px var(--app-primary-ring), 0 12px 22px -10px var(--app-primary-shadow);
        }

        .app-btn-primary:active {
            transform: scale(0.95);
        }

        .app-btn-primary:disabled {
            cursor: not-allowed;
            opacity: 0.5;
            transform: none;
        }

        .app-btn-secondary {
            border: 1px solid var(--po-border);
            background: #fff;
            color: var(--po-text-muted);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
        }

        .app-btn-secondary:hover {
            border-color: var(--app-primary-border);
            background: var(--app-primary-soft);
            color: var(--app-primary-text);
        }

        .app-icon-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--po-border);
            background: #fff;
            color: var(--po-text-muted);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
            transition:
                background-color 0.18s ease,
                border-color 0.18s ease,
                color 0.18s ease,
                box-shadow 0.18s ease;
        }

        .app-icon-btn:hover {
            border-color: var(--app-primary-border);
            background: var(--app-primary-soft);
            color: var(--app-primary-text);
        }

        .app-page-btn {
            border: 1px solid var(--po-border);
            background: #fff;
            color: var(--po-text-muted);
        }

        .app-page-btn:hover {
            background: #f8fafc;
            color: var(--app-primary-text);
        }

        .app-page-btn.is-active {
            border-color: var(--app-primary);
            background: var(--app-primary);
            color: #fff;
        }

        .po-modal {
            background: #FFFFFF;
            width: 100%;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 10px -2px rgba(0, 0, 0, 0.1);
            border: 1px solid var(--po-border);
            margin-bottom: 16px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            color: var(--po-text-muted);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .po-input,
        .po-textarea {
            width: 100%;
            border: 1px solid var(--po-border);
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 13px;
            color: var(--po-text-main);
            outline: none;
            transition: 0.2s;
        }

        .po-input::placeholder,
        .po-textarea::placeholder {
            color: #94A3B8;
        }

        .po-input:focus,
        .po-textarea:focus {
            border-color: var(--po-primary);
            box-shadow: 0 0 0 3px var(--app-primary-ring);
        }

        .po-textarea {
            height: 70px;
            resize: none;
        }

        .row-flex {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .po-select {
            border: 1px solid var(--po-border);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 13px;
            color: var(--po-text-main);
            outline: none;
            background: #fff;
            cursor: pointer;
        }

        .tags-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            border: 1px solid var(--po-border);
            padding: 8px;
            border-radius: 8px;
            min-height: 42px;
            align-items: center;
        }

        .po-tag {
            background: var(--po-bg-light);
            border: 1px solid var(--po-border);
            color: var(--po-text-main);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .po-tag:hover {
            background: #E2E8F0;
        }

        /* Trạng thái Tag được chọn */
        .po-tag-active {
            background: var(--po-primary) !important;
            color: white !important;
            border-color: var(--po-primary) !important;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 12px;
            margin-top: 8px;
        }

        .btn-cancel {
            background: transparent;
            border: none;
            color: var(--po-text-muted);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-cancel:hover {
            color: var(--po-text-main);
        }

        .btn-submit {
            background: var(--app-primary-gradient);
            color: white;
            border: 0;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            outline: none;
            box-shadow: 0 12px 22px -10px var(--app-primary-shadow);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .btn-submit:hover {
            background: var(--app-primary-gradient-hover);
            transform: translateY(-1px);
        }

        .btn-submit:focus-visible {
            box-shadow: 0 0 0 4px var(--app-primary-ring), 0 12px 22px -10px var(--app-primary-shadow);
        }

        .btn-submit:disabled {
            cursor: not-allowed;
            opacity: 0.5;
            transform: none;
        }

        /* CSS TỔNG QUAN (GIỮ NGUYÊN) */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9;
            color: #1e293b;
            overflow-x: auto;
        }

        ::-webkit-scrollbar {
            height: 10px;
            width: 8px;
        }

        ::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 20px;
            border: 2px solid #f1f5f9;
        }

        ::-webkit-scrollbar-thumb:hover {
            background-color: #94a3b8;
        }

/* --- HIỆU ỨNG KÉO THẢ (PO WORKSPACE STYLE) --- */
        .sortable-ghost {
            background-color: #f8fafc !important; /* Nền xám nhạt */
            border: 2px dashed #94a3b8 !important; /* Viền đứt nét */
            border-radius: 12px !important;
            opacity: 1 !important;
        }

        .sortable-ghost > * {
            opacity: 0 !important; /* Ẩn toàn bộ nội dung chữ bên trong vùng rớt xuống */
            visibility: hidden !important; 
        }

        .sortable-drag {
            cursor: grabbing !important;
            background-color: #ffffff !important;
            box-shadow: 0 25px 50px -12px rgba(37, 99, 235, 0.25) !important; /* Bóng đổ xanh dương */
            border: 1px solid #3b82f6 !important;
            border-radius: 12px !important;
            opacity: 1 !important;
            transform: rotate(3deg) scale(1.02) !important; /* Nghiêng 3 độ, to lên 2% */
            z-index: 99999 !important;
            transition: none !important; /* BẮT BUỘC: Tắt transition để thẻ không bị lag trễ so với chuột */
        }

        .kanban-list>div {
            transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1);
        }

        .task-card {
            cursor: grab;
        }

        .task-card.is-status-lov-open {
            z-index: 80;
        }

        .task-card:active {
            cursor: grabbing;
        }

        .kanban-list {
            counter-reset: task-counter;
        }

        .task-title::before {
            counter-increment: task-counter;
            content: counter(task-counter) ". ";
            color: #94a3b8;
            font-weight: 700;
        }

        .kanban-column {
            width: 360px;
            flex-shrink: 0;
            border-radius: 1rem;
            display: flex;
            flex-direction: column;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
        }

        .kanban-column-header {
            padding: 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top-left-radius: 1rem;
            border-top-right-radius: 1rem;
        }

        .kanban-column-title {
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .kanban-count {
            padding: 0.125rem 0.5rem;
            border-radius: 0.375rem;
            font-size: 11px;
            font-weight: 700;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
            margin-left: 0.25rem;
            background: #ffffff;
        }

        .kanban-add-wrap {
            padding: 1rem 1rem 0.25rem;
        }

        .kanban-list-body {
            padding: 1rem;
            padding-top: 0.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            min-height: 150px;
        }

        .kanban-column[data-color-theme="slate"] {
            background: rgba(248, 250, 252, 0.8);
            border: 1px solid rgba(226, 232, 240, 0.8);
