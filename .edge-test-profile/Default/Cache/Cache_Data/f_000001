                : null;
            const [page, setPage] = useState(initialPage);

            const showPage = (nextPage) => {
                if (!nextPage) {
                    window.POUX_DOCUMENT_WORKSPACE_ACTIVE = true;
                    window.POUX_DOCUMENT_WORKSPACE_PAGE = null;
                    window.POUX_PENDING_DOCUMENT_PAGE = null;
                    setPage(null);
                    return;
                }
                const normalizedPage = normalizeWorkspacePage(nextPage);
                window.POUX_DOCUMENT_WORKSPACE_ACTIVE = true;
                window.POUX_DOCUMENT_WORKSPACE_PAGE = normalizedPage;
                window.POUX_PENDING_DOCUMENT_PAGE = normalizedPage;
                setPage(normalizedPage);
            };

            useEffect(() => {
                window.PouxDocumentWorkspace = { showPage };
                window.dispatchEvent(new CustomEvent("poux-document-workspace-ready"));
                if (window.POUX_DOCUMENT_WORKSPACE_ACTIVE && window.POUX_PENDING_DOCUMENT_PAGE) {
                    showPage(window.POUX_PENDING_DOCUMENT_PAGE);
                }
                return () => {
                    if (window.PouxDocumentWorkspace?.showPage === showPage) {
                        delete window.PouxDocumentWorkspace;
                    }
                };
            }, []);

            if (!page) return null;
            window.POUX_DOCUMENT_WORKSPACE_PAGE = page;
            return h(App, { key: page.id, page });
